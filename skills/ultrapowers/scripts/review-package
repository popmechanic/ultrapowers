#!/usr/bin/env bash
# Generate a review package: commit list, stat summary, and the net diff with
# extended context, written to a file the reviewer reads in one call. Using the
# recorded per-task BASE (not HEAD~1) keeps multi-commit tasks intact.
#
# Usage: review-package BASE HEAD [OUTFILE]
#
# Default OUTFILE: <main-repo-root>/.superpowers/ultra/review-<base7>..<head7>.diff.
# Unlike v6's per-worktree `git rev-parse --git-path sdd`, ultrapowers' implementer
# and reviewer run in DIFFERENT linked worktrees, so the packet must live somewhere
# both can see. We derive it from the RESOLVED PARENT of --git-common-dir (the main
# repo root, identical for every linked worktree) and write under .superpowers/ —
# already gitignored — so the scratch stays SHARED across worktrees yet escapes the
# protected .git/ that superpowers fled in v6.0.3. Do NOT switch to a worktree-relative
# .superpowers/ off the CWD: that would hand each worktree a different dir and break sharing.
#
# Echoes the final output path on stdout so callers learn where it wrote.
set -euo pipefail

if [ $# -lt 2 ] || [ $# -gt 3 ]; then
  echo "usage: review-package BASE HEAD [OUTFILE]" >&2
  exit 2
fi

base=$1
head=$2

git rev-parse --verify --quiet "$base" >/dev/null || { echo "bad BASE: $base" >&2; exit 2; }
git rev-parse --verify --quiet "$head" >/dev/null || { echo "bad HEAD: $head" >&2; exit 2; }

if [ $# -eq 3 ]; then
  out=$3
else
  common=$(git rev-parse --git-common-dir)
  common=$(cd "$common" && pwd)          # absolutize (handles the bare ".git" case)
  dir="$(dirname "$common")/.superpowers/ultra"   # main repo root, shared by every worktree
  mkdir -p "$dir"
  dir=$(cd "$dir" && pwd)   # absolute, so the echoed path works from any cwd
  out="$dir/review-$(git rev-parse --short "$base")..$(git rev-parse --short "$head").diff"
fi

{
  echo "# Review package: ${base}..${head}"
  echo
  echo "## Commits"
  # Include the base commit itself so the reviewer sees the full picture, then
  # all commits that followed up to HEAD.
  git show --no-patch --oneline "${base}"
  git log --oneline "${base}..${head}"
  echo
  echo "## Files changed"
  git diff --stat "${base}..${head}"
  echo
  echo "## Diff"
  git diff -U10 "${base}..${head}"
} > "$out"

commits=$(git rev-list --count "${base}..${head}")
echo "wrote ${out}: ${commits} commit(s), $(wc -c < "$out" | tr -d ' ') bytes" >&2
echo "${out}"
