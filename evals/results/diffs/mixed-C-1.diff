+"""Serialization helpers for apistub schema objects."""
+
+import json
+
+from apistub.schema import User
+
+
+def to_json(user: User) -> str:
+    """Serialize a ``User`` to a JSON string.
+
+    The resulting object has keys ``id``, ``name``, ``email`` in exactly that
+    insertion order, using ``json.dumps`` default separators.
+    """
+    return json.dumps({"id": user.id, "name": user.name, "email": user.email})
