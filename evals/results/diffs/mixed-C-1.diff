+import json
+
+from apistub import schema
+from apistub.serialize import to_json
+
+
+def test_to_json_example():
+    result = to_json(schema.User(1, "Ada", "ada@ex.com"))
+    assert result == '{"id": 1, "name": "Ada", "email": "ada@ex.com"}'
+
+
+def test_to_json_returns_string():
+    result = to_json(schema.User(1, "Ada", "ada@ex.com"))
+    assert isinstance(result, str)
+
+
+def test_to_json_key_order():
+    result = to_json(schema.User(7, "Grace", "grace@ex.com"))
+    assert list(json.loads(result).keys()) == ["id", "name", "email"]
+
+
+def test_to_json_round_trips_values():
+    user = schema.User(42, "Linus", "linus@ex.com")
+    assert json.loads(to_json(user)) == {
+        "id": 42,
+        "name": "Linus",
+        "email": "linus@ex.com",
+    }
+
+
+def test_to_json_default_separators():
+    # Default separators are ", " and ": " (with spaces).
+    result = to_json(schema.User(2, "Bob", "bob@ex.com"))
+    assert ", " in result
+    assert ": " in result
