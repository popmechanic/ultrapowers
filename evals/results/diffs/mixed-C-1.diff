+import json
+
+from apistub.app import route
+from apistub.handlers import create_user, get_user
+from apistub.serialize import to_json
+from apistub.store import MemoryStore
+
+
+def test_route_post_users_delegates_to_create_user():
+    store = MemoryStore()
+    payload = {"name": "Ada", "email": "ada@ex.com"}
+    status, body = route(store, "POST", "/users", payload)
+    assert status == 201
+    assert json.loads(body) == {"id": 1, "name": "Ada", "email": "ada@ex.com"}
+
+
+def test_route_post_users_matches_create_user_directly():
+    store_a = MemoryStore()
+    store_b = MemoryStore()
+    payload = {"name": "Grace", "email": "grace@ex.com"}
+    assert route(store_a, "POST", "/users", payload) == create_user(store_b, payload)
+
+
+def test_route_post_users_invalid_payload_returns_400():
+    store = MemoryStore()
+    status, body = route(store, "POST", "/users", {})
+    assert status == 400
+    assert json.loads(body) == {"errors": ["missing: name", "missing: email"]}
+
+
+def test_route_get_user_found_delegates_to_get_user():
+    store = MemoryStore()
+    user = store.add("Ada", "ada@ex.com")
+    status, body = route(store, "GET", "/users/1")
+    assert status == 200
+    assert body == to_json(user)
+    assert json.loads(body) == {"id": 1, "name": "Ada", "email": "ada@ex.com"}
+
+
+def test_route_get_user_parses_digits_as_int():
+    store = MemoryStore()
+    store.add("Ada", "ada@ex.com")
+    store.add("Grace", "grace@ex.com")
+    status, body = route(store, "GET", "/users/2")
+    assert status == 200
+    assert json.loads(body)["id"] == 2
+
+
+def test_route_get_user_matches_get_user_directly():
+    store = MemoryStore()
+    store.add("Ada", "ada@ex.com")
+    assert route(store, "GET", "/users/1") == get_user(store, 1)
+
+
+def test_route_get_user_missing_returns_404_not_found():
+    store = MemoryStore()
+    status, body = route(store, "GET", "/users/999")
+    assert status == 404
+    assert json.loads(body) == {"errors": ["not found"]}
+
+
+def test_route_get_user_multi_digit_id():
+    store = MemoryStore()
+    for i in range(12):
+        store.add(f"user{i}", f"user{i}@ex.com")
+    status, body = route(store, "GET", "/users/12")
+    assert status == 200
+    assert json.loads(body)["id"] == 12
+
+
+def test_route_unknown_path_returns_404_no_route():
+    store = MemoryStore()
+    status, body = route(store, "GET", "/widgets")
+    assert status == 404
+    assert json.loads(body) == {"errors": ["no route"]}
+
+
+def test_route_wrong_method_on_users_returns_no_route():
+    store = MemoryStore()
+    status, body = route(store, "GET", "/users")
+    assert status == 404
+    assert json.loads(body) == {"errors": ["no route"]}
+
+
+def test_route_post_to_user_id_returns_no_route():
+    store = MemoryStore()
+    status, body = route(store, "POST", "/users/1", {"name": "Ada", "email": "ada@ex.com"})
+    assert status == 404
+    assert json.loads(body) == {"errors": ["no route"]}
+
+
+def test_route_non_digit_user_id_returns_no_route():
+    store = MemoryStore()
+    store.add("Ada", "ada@ex.com")
+    status, body = route(store, "GET", "/users/abc")
+    assert status == 404
+    assert json.loads(body) == {"errors": ["no route"]}
+
+
+def test_route_root_path_returns_no_route():
+    store = MemoryStore()
+    status, body = route(store, "GET", "/")
+    assert status == 404
+    assert json.loads(body) == {"errors": ["no route"]}
+
+
+def test_route_returns_tuple_of_int_and_str():
+    store = MemoryStore()
+    status, body = route(store, "GET", "/nope")
+    assert isinstance(status, int)
+    assert isinstance(body, str)
