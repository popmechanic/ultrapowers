+from apistub.validate import validate_payload
+
+
+def test_valid_payload_returns_empty_list():
+    assert validate_payload({"name": "Ada", "email": "ada@example.com"}) == []
+
+
+def test_missing_fields_in_fields_order():
+    assert validate_payload({}) == ["missing: name", "missing: email"]
+
+
+def test_missing_single_field():
+    assert validate_payload({"name": "Ada"}) == ["missing: email"]
+
+
+def test_wrong_type_for_field():
+    errors = validate_payload({"name": 123, "email": "ada@example.com"})
+    assert errors == ["wrong type: name"]
+
+
+def test_wrong_type_skips_email_at_sign_check():
+    # email is not a str, so the "@" check must not run.
+    errors = validate_payload({"name": "Ada", "email": 5})
+    assert errors == ["wrong type: email"]
+
+
+def test_invalid_email_missing_at_sign():
+    errors = validate_payload({"name": "Ada", "email": "ada.example.com"})
+    assert errors == ["invalid: email"]
+
+
+def test_missing_email_does_not_trigger_invalid_email():
+    errors = validate_payload({"name": "Ada"})
+    assert errors == ["missing: email"]
+
+
+def test_unknown_keys_are_ignored():
+    payload = {"name": "Ada", "email": "ada@example.com", "extra": "ignored"}
+    assert validate_payload(payload) == []
+
+
+def test_multiple_errors_in_fields_order_then_email_check():
+    # name wrong type, email present str without "@": both errors, email check last.
+    errors = validate_payload({"name": 1, "email": "no-at-sign"})
+    assert errors == ["wrong type: name", "invalid: email"]
+
+
+def test_bool_is_not_a_valid_str_name():
+    # bool is an int, not a str, so name must be flagged as wrong type.
+    errors = validate_payload({"name": True, "email": "ada@example.com"})
+    assert errors == ["wrong type: name"]
