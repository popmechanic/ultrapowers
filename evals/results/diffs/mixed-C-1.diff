@@ -0,0 +1,34 @@
+"""Minimal in-memory request router.
+
+Maps a ``(method, path)`` pair to a handler in :mod:`apistub.handlers`.
+Unmatched requests yield ``(404, json.dumps({"errors": ["no route"]}))``.
+No network code; ``route`` operates on a plain store object.
+"""
+
+import json
+import re
+
+from apistub.handlers import create_user, get_user
+from apistub.store import MemoryStore
+
+_GET_USER = re.compile(r"^/users/(\d+)$")
+
+
+def route(store: MemoryStore, method: str, path: str, payload: dict = None):
+    """Dispatch a request to the matching handler.
+
+    - ``("POST", "/users")`` -> ``create_user(store, payload)``.
+    - ``("GET", "/users/<digits>")`` -> ``get_user(store, int(<digits>))``.
+    - anything else -> ``(404, json.dumps({"errors": ["no route"]}))``.
+
+    Each branch returns the handler's ``(status: int, body: str)`` tuple.
+    """
+    if method == "POST" and path == "/users":
+        return create_user(store, payload)
+
+    if method == "GET":
+        match = _GET_USER.match(path)
+        if match:
+            return get_user(store, int(match.group(1)))
+
+    return 404, json.dumps({"errors": ["no route"]})
