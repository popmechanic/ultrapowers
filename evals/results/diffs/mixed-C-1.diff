+from apistub import schema
+from apistub.store import MemoryStore
+
+
+def test_add_returns_user_with_id_starting_at_one():
+    store = MemoryStore()
+    user = store.add("Ada", "ada@ex.com")
+    assert isinstance(user, schema.User)
+    assert user.id == 1
+    assert user.name == "Ada"
+    assert user.email == "ada@ex.com"
+
+
+def test_add_auto_increments_id():
+    store = MemoryStore()
+    first = store.add("Ada", "ada@ex.com")
+    second = store.add("Grace", "grace@ex.com")
+    third = store.add("Linus", "linus@ex.com")
+    assert first.id == 1
+    assert second.id == 2
+    assert third.id == 3
+
+
+def test_get_returns_user():
+    store = MemoryStore()
+    created = store.add("Ada", "ada@ex.com")
+    fetched = store.get(created.id)
+    assert fetched is created
+
+
+def test_get_missing_returns_none():
+    store = MemoryStore()
+    store.add("Ada", "ada@ex.com")
+    assert store.get(999) is None
+
+
+def test_get_on_empty_store_returns_none():
+    store = MemoryStore()
+    assert store.get(1) is None
+
+
+def test_list_returns_all_users_in_insertion_order():
+    store = MemoryStore()
+    a = store.add("Ada", "ada@ex.com")
+    b = store.add("Grace", "grace@ex.com")
+    c = store.add("Linus", "linus@ex.com")
+    assert store.list() == [a, b, c]
+
+
+def test_list_empty_store():
+    store = MemoryStore()
+    assert store.list() == []
+
+
+def test_stores_are_independent():
+    store_one = MemoryStore()
+    store_two = MemoryStore()
+    store_one.add("Ada", "ada@ex.com")
+    assert store_one.list() != []
+    assert store_two.list() == []
+    # ids are independent per-store, each starting at 1
+    user = store_two.add("Grace", "grace@ex.com")
+    assert user.id == 1
