+import json
+
+from apistub.handlers import create_user, get_user
+from apistub.serialize import to_json
+from apistub.store import MemoryStore
+
+
+def test_create_user_valid_returns_201_and_serialized_user():
+    store = MemoryStore()
+    status, body = create_user(store, {"name": "Ada", "email": "ada@ex.com"})
+    assert status == 201
+    assert body == to_json(store.get(1))
+    assert json.loads(body) == {"id": 1, "name": "Ada", "email": "ada@ex.com"}
+
+
+def test_create_user_persists_to_store():
+    store = MemoryStore()
+    create_user(store, {"name": "Ada", "email": "ada@ex.com"})
+    user = store.get(1)
+    assert user is not None
+    assert user.name == "Ada"
+    assert user.email == "ada@ex.com"
+
+
+def test_create_user_returns_tuple_of_int_and_str():
+    store = MemoryStore()
+    status, body = create_user(store, {"name": "Ada", "email": "ada@ex.com"})
+    assert isinstance(status, int)
+    assert isinstance(body, str)
+
+
+def test_create_user_invalid_returns_400_with_errors():
+    store = MemoryStore()
+    status, body = create_user(store, {})
+    assert status == 400
+    assert json.loads(body) == {"errors": ["missing: name", "missing: email"]}
+
+
+def test_create_user_invalid_does_not_add_to_store():
+    store = MemoryStore()
+    create_user(store, {})
+    assert store.list() == []
+    assert store.get(1) is None
+
+
+def test_create_user_invalid_email_returns_400():
+    store = MemoryStore()
+    status, body = create_user(store, {"name": "Ada", "email": "no-at-sign"})
+    assert status == 400
+    assert json.loads(body) == {"errors": ["invalid: email"]}
+
+
+def test_create_user_auto_increments_across_calls():
+    store = MemoryStore()
+    first_status, first_body = create_user(
+        store, {"name": "Ada", "email": "ada@ex.com"}
+    )
+    second_status, second_body = create_user(
+        store, {"name": "Grace", "email": "grace@ex.com"}
+    )
+    assert first_status == 201
+    assert second_status == 201
+    assert json.loads(first_body)["id"] == 1
+    assert json.loads(second_body)["id"] == 2
+
+
+def test_get_user_found_returns_200_and_serialized_user():
+    store = MemoryStore()
+    user = store.add("Ada", "ada@ex.com")
+    status, body = get_user(store, user.id)
+    assert status == 200
+    assert body == to_json(user)
+    assert json.loads(body) == {"id": 1, "name": "Ada", "email": "ada@ex.com"}
+
+
+def test_get_user_found_returns_tuple_of_int_and_str():
+    store = MemoryStore()
+    user = store.add("Ada", "ada@ex.com")
+    status, body = get_user(store, user.id)
+    assert isinstance(status, int)
+    assert isinstance(body, str)
+
+
+def test_get_user_missing_returns_404_with_errors():
+    store = MemoryStore()
+    status, body = get_user(store, 999)
+    assert status == 404
+    assert json.loads(body) == {"errors": ["not found"]}
+
+
+def test_get_user_missing_on_empty_store_returns_404():
+    store = MemoryStore()
+    status, body = get_user(store, 1)
+    assert status == 404
+    assert json.loads(body) == {"errors": ["not found"]}
