@@ -0,0 +1,25 @@
+"""Validation for user-creation payloads."""
+
+from apistub import schema
+
+
+def validate_payload(payload):
+    """Validate a user-creation payload.
+
+    Returns a list of error strings, empty when the payload is valid.
+    Fields are checked in ``schema.FIELDS`` insertion order. Unknown keys
+    are ignored.
+    """
+    errors = []
+
+    for key, expected_type in schema.FIELDS.items():
+        if key not in payload:
+            errors.append(f"missing: {key}")
+        elif not isinstance(payload[key], expected_type):
+            errors.append(f"wrong type: {key}")
+
+    email = payload.get("email")
+    if isinstance(email, str) and "@" not in email:
+        errors.append("invalid: email")
+
+    return errors
