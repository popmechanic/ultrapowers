+import dataclasses
+
+from apistub import schema
+
+
+def test_user_is_a_dataclass():
+    assert dataclasses.is_dataclass(schema.User)
+
+
+def test_user_fields_and_types():
+    fields = {f.name: f.type for f in dataclasses.fields(schema.User)}
+    assert fields == {"id": int, "name": str, "email": str}
+
+
+def test_user_construction():
+    user = schema.User(id=1, name="Ada", email="ada@example.com")
+    assert user.id == 1
+    assert user.name == "Ada"
+    assert user.email == "ada@example.com"
+
+
+def test_fields_constant_contents():
+    assert schema.FIELDS == {"name": str, "email": str}
+
+
+def test_fields_constant_insertion_order():
+    # Insertion order matters: "name" comes before "email".
+    assert list(schema.FIELDS) == ["name", "email"]
