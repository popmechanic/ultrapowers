@@ -0,0 +1,38 @@
+"""Request handlers joining validation, storage, and serialization.
+
+Each handler returns a ``(status: int, body: str)`` tuple. No network code;
+handlers operate on a plain store object and dict payloads.
+"""
+
+import json
+
+from apistub.serialize import to_json
+from apistub.store import MemoryStore
+from apistub.validate import validate_payload
+
+
+def create_user(store: MemoryStore, payload: dict):
+    """Validate and create a user.
+
+    On validation errors, return ``(400, json.dumps({"errors": errors}))``.
+    Otherwise add the user to ``store`` and return ``(201, to_json(user))``.
+    """
+    errors = validate_payload(payload)
+    if errors:
+        return 400, json.dumps({"errors": errors})
+
+    user = store.add(payload["name"], payload["email"])
+    return 201, to_json(user)
+
+
+def get_user(store: MemoryStore, user_id: int):
+    """Fetch a user by id.
+
+    Return ``(200, to_json(user))`` when found, otherwise
+    ``(404, json.dumps({"errors": ["not found"]}))``.
+    """
+    user = store.get(user_id)
+    if user is None:
+        return 404, json.dumps({"errors": ["not found"]})
+
+    return 200, to_json(user)
