@@ -0,0 +1,31 @@
+"""In-memory user store with auto-incrementing integer ids."""
+
+from typing import List, Optional
+
+from apistub import schema
+
+
+class MemoryStore:
+    """Holds users in memory, assigning ids starting at 1."""
+
+    def __init__(self) -> None:
+        self._users: List[schema.User] = []
+        self._next_id = 1
+
+    def add(self, name: str, email: str) -> schema.User:
+        """Create, store, and return a User with the next id."""
+        user = schema.User(id=self._next_id, name=name, email=email)
+        self._next_id += 1
+        self._users.append(user)
+        return user
+
+    def get(self, user_id: int) -> Optional[schema.User]:
+        """Return the user with the given id, or None if absent."""
+        for user in self._users:
+            if user.id == user_id:
+                return user
+        return None
+
+    def list(self) -> List[schema.User]:
+        """Return all users in insertion order."""
+        return list(self._users)
