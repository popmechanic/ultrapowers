+"""User schema definitions for the apistub users API."""
+
+from dataclasses import dataclass
+
+
+@dataclass
+class User:
+    """A user record."""
+
+    id: int
+    name: str
+    email: str
+
+
+# The creation-payload contract. Insertion order matters: "name" first.
+FIELDS = {"name": str, "email": str}
