@@ -0,0 +1,69 @@
+import pytest
+from textkit.titlecase import titlecase
+
+
+def test_basic_title():
+    assert titlecase("the lord of the rings") == "The Lord of the Rings"
+
+
+def test_first_word_always_capitalized():
+    assert titlecase("a tale of two cities") == "A Tale of Two Cities"
+
+
+def test_last_word_always_capitalized():
+    assert titlecase("the man in the") == "The Man in The"
+
+
+def test_minor_words_lowercase():
+    # All minor words in the middle; "up" is NOT a minor word so it capitalizes
+    assert titlecase("jack and jill went up the hill") == "Jack and Jill Went Up the Hill"
+
+
+def test_all_minor_words():
+    # first and last must be capitalized even if minor
+    assert titlecase("a an and as at but by for in of on or the to") == (
+        "A an and as at but by for in of on or the To"
+    )
+
+
+def test_empty_string():
+    assert titlecase("") == ""
+
+
+def test_whitespace_only():
+    assert titlecase("   ") == ""
+
+
+def test_extra_whitespace_collapsed():
+    assert titlecase("  hello   world  ") == "Hello World"
+
+
+def test_single_word():
+    assert titlecase("hello") == "Hello"
+
+
+def test_single_minor_word():
+    # Single word is both first and last — must be capitalized
+    assert titlecase("the") == "The"
+
+
+def test_two_words_both_minor():
+    # First and last, both minor — both capitalized
+    assert titlecase("the a") == "The A"
+
+
+def test_mixed_case_input():
+    # Input with mixed case should be normalized
+    assert titlecase("THE lord OF THE Rings") == "The Lord of the Rings"
+
+
+def test_all_minor_words_list():
+    minor = ["a", "an", "and", "as", "at", "but", "by", "for", "in", "of", "on", "or", "the", "to"]
+    # Each minor word in isolation → always capitalized (first == last)
+    for word in minor:
+        assert titlecase(word) == word.capitalize()
+
+
+def test_middle_minor_words_lowercase():
+    assert titlecase("go to the store") == "Go to the Store"
+    assert titlecase("a boy and a girl") == "A Boy and a Girl"
