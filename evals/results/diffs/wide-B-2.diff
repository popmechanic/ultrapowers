@@ -0,0 +1,9 @@
+def reverse_words(text: str) -> str:
+    """Return the words of *text* in reversed order, joined by single spaces.
+
+    Splits on any whitespace sequence so multiple spaces, tabs, and newlines
+    are all treated as word separators.  Empty or whitespace-only input
+    returns an empty string.
+    """
+    words = text.split()
+    return " ".join(reversed(words))
diff --git a/textkit/titlecase.py b/textkit/titlecase.py
new file mode 100644
index 0000000..073f918
--- /dev/null
+++ b/textkit/titlecase.py
@@ -0,0 +1,35 @@
+"""titlecase — capitalize a string using title-case rules."""
+
+_MINOR_WORDS = frozenset(
+    "a an and as at but by for in of on or the to".split()
+)
+
+
+def titlecase(text: str) -> str:
+    """Return *text* in title case.
+
+    Rules:
+    - Split on whitespace; rejoin with single spaces.
+    - Each word is capitalized (first letter upper, rest lower), EXCEPT minor
+      words (a an and as at but by for in of on or the to), which become fully
+      lowercase.
+    - The first and last words are always capitalized, even if minor.
+    - Empty or whitespace-only input returns "".
+    """
+    words = text.split()  # handles multiple spaces / leading/trailing whitespace
+    if not words:
+        return ""
+
+    result = []
+    last_index = len(words) - 1
+
+    for i, word in enumerate(words):
+        lower = word.lower()
+        if i == 0 or i == last_index:
+            result.append(lower.capitalize())
+        elif lower in _MINOR_WORDS:
+            result.append(lower)
+        else:
+            result.append(lower.capitalize())
+
+    return " ".join(result)
diff --git a/textkit/truncate.py b/textkit/truncate.py
new file mode 100644
index 0000000..3285820
--- /dev/null
+++ b/textkit/truncate.py
@@ -0,0 +1,17 @@
+def truncate(text: str, limit: int, ellipsis: str = "...") -> str:
+    """Return *text* truncated to *limit* characters.
+
+    If the text fits within the limit it is returned unchanged.
+    Otherwise the text is cut to ``limit - len(ellipsis)`` characters
+    (trailing whitespace stripped) and *ellipsis* is appended.
+
+    Raises ``ValueError`` when *limit* is smaller than ``len(ellipsis)``,
+    because there would be no room for any original content.
+    """
+    if limit < len(ellipsis):
+        raise ValueError(
+            f"limit ({limit}) must be >= len(ellipsis) ({len(ellipsis)})"
+        )
+    if len(text) <= limit:
+        return text
+    return text[: limit - len(ellipsis)].rstrip() + ellipsis
diff --git a/textkit/word_count.py b/textkit/word_count.py
new file mode 100644
index 0000000..5aeddc8
--- /dev/null
+++ b/textkit/word_count.py
@@ -0,0 +1,13 @@
+import re
+
+
+def word_count(text: str) -> dict[str, int]:
+    """Return a dict mapping each word to its occurrence count.
+
+    Words are maximal runs of [a-z0-9]+ after lowercasing the input.
+    """
+    words = re.findall(r"[a-z0-9]+", text.lower())
+    counts: dict[str, int] = {}
+    for word in words:
+        counts[word] = counts.get(word, 0) + 1
+    return counts
