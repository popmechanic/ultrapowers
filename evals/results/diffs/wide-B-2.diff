@@ -0,0 +1,43 @@
+from textkit.redact import redact
+
+
+def test_basic_replacement():
+    assert redact("Tell Alice that ALICE called", ["alice"]) == "Tell ***** that ***** called"
+
+
+def test_word_boundary_punctuation():
+    # "scandal!" should match "scandal" (boundary before "!")
+    assert redact("scandal!", ["scandal"]) == "*******!"
+
+
+def test_no_partial_match():
+    # "scandals" should NOT be redacted when word is "scandal"
+    assert redact("scandals", ["scandal"]) == "scandals"
+
+
+def test_empty_words_returns_unchanged():
+    assert redact("hello world", []) == "hello world"
+
+
+def test_case_insensitive():
+    # Should match lowercase, uppercase, mixed case
+    assert redact("Bob BOB bob", ["bob"]) == "*** *** ***"
+
+
+def test_multiple_words():
+    assert redact("Alice met Bob today", ["alice", "bob"]) == "***** met *** today"
+
+
+def test_no_match():
+    assert redact("hello world", ["foo"]) == "hello world"
+
+
+def test_whole_word_only():
+    # "cat" should not match inside "concatenate"
+    assert redact("the cat in concatenate", ["cat"]) == "the *** in concatenate"
+
+
+def test_replaces_with_same_length():
+    # Each star matches the length of the matched word
+    assert redact("Hi", ["hi"]) == "**"
+    assert redact("Hello", ["hello"]) == "*****"
