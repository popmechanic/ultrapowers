+import pytest
+from textkit.truncate import truncate
+
+
+def test_short_text_unchanged():
+    assert truncate("hello", 10) == "hello"
+
+
+def test_exact_limit_unchanged():
+    assert truncate("hello", 5) == "hello"
+
+
+def test_truncation_with_ellipsis():
+    assert truncate("hello brave world", 10) == "hello b..."
+
+
+def test_truncation_strips_trailing_space():
+    # text[:7] is "hello b" -> rstrip -> "hello b", + "..." -> "hello b..."
+    assert truncate("hello brave world", 10) == "hello b..."
+
+
+def test_custom_ellipsis():
+    assert truncate("hello brave world", 10, "..more") == "hell..more"
+
+
+def test_raises_if_limit_less_than_ellipsis():
+    with pytest.raises(ValueError):
+        truncate("hello", 2)
+
+
+def test_raises_if_limit_equals_ellipsis_length():
+    # limit == len("...") == 3: limit - len(ellipsis) == 0, OK? No: 3 < 3 is False so should NOT raise
+    # let's verify: 3 < 3 is False, so no error expected
+    result = truncate("hello", 3)
+    assert result == "..."
+
+
+def test_raises_if_limit_less_than_ellipsis_custom():
+    with pytest.raises(ValueError):
+        truncate("hello", 3, "...more")
+
+
+def test_empty_string_unchanged():
+    assert truncate("", 5) == ""
