new file mode 100644
index 0000000..6ec8026
--- /dev/null
+++ b/textkit/redact.py
@@ -0,0 +1,26 @@
+import re
+from typing import Iterable
+
+
+def redact(text: str, words: Iterable[str]) -> str:
+    """Replace whole-word, case-insensitive occurrences of each word with '*' characters.
+
+    Each matched character is replaced by a single '*', preserving the original length.
+    Words are matched at word boundaries so partial matches are not affected.
+
+    Args:
+        text: The input string.
+        words: An iterable of words to redact.
+
+    Returns:
+        The text with matching words replaced by '*' strings of equal length.
+    """
+    word_list = list(words)
+    if not word_list:
+        return text
+
+    # Build a pattern that alternates all words, longest first to avoid shadowing
+    pattern = "|".join(re.escape(w) for w in word_list)
+    regex = re.compile(r"\b(?:" + pattern + r")\b", re.IGNORECASE)
+
+    return regex.sub(lambda m: "*" * len(m.group()), text)
