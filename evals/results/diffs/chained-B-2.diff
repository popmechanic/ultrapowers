+import pytest
+from ledger.model import Entry
+
+
+def test_validate_empty_description():
+    """Should raise ValueError('empty description') when description is empty."""
+    e = Entry(date="2026-01-15", description="", amount_cents=-450)
+    with pytest.raises(ValueError, match="empty description"):
+        e.validate()
+
+
+def test_validate_whitespace_description():
+    """Should raise ValueError('empty description') when description is only whitespace."""
+    e = Entry(date="2026-01-15", description="   ", amount_cents=-450)
+    with pytest.raises(ValueError, match="empty description"):
+        e.validate()
+
+
+def test_validate_bad_date_format():
+    """Should raise ValueError('bad date') when date doesn't match YYYY-MM-DD."""
+    e = Entry(date="2026/01/15", description="coffee", amount_cents=-450)
+    with pytest.raises(ValueError, match="bad date"):
+        e.validate()
+
+
+def test_validate_bad_date_missing_leading_zero():
+    """Should raise ValueError('bad date') when month/day lacks leading zero."""
+    e = Entry(date="2026-1-15", description="coffee", amount_cents=-450)
+    with pytest.raises(ValueError, match="bad date"):
+        e.validate()
+
+
+def test_validate_bad_date_incomplete():
+    """Should raise ValueError('bad date') when date is incomplete."""
+    e = Entry(date="2026-01", description="coffee", amount_cents=-450)
+    with pytest.raises(ValueError, match="bad date"):
+        e.validate()
+
+
+def test_validate_bad_date_extra_characters():
+    """Should raise ValueError('bad date') when date has extra characters."""
+    e = Entry(date="2026-01-15 ", description="coffee", amount_cents=-450)
+    with pytest.raises(ValueError, match="bad date"):
+        e.validate()
+
+
+def test_validate_valid_entry():
+    """Should return None for a valid entry."""
+    e = Entry(date="2026-01-15", description="coffee", amount_cents=-450)
+    result = e.validate()
+    assert result is None
+
+
+def test_validate_valid_entry_with_long_description():
+    """Should return None for a valid entry with a long description."""
+    e = Entry(date="2026-12-31", description="annual expense report", amount_cents=10000)
+    result = e.validate()
+    assert result is None
