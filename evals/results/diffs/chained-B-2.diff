+from typing import List
+from ledger.model import Entry
+from ledger.balance import running_balance
+
+
+def format_cents(cents: int) -> str:
+    """Format an integer number of cents as a dollar string.
+
+    Args:
+        cents: Amount in cents (may be negative).
+
+    Returns:
+        Formatted string like "$10.00" or "-$4.50".
+    """
+    if cents < 0:
+        return f"-${-cents / 100:.2f}"
+    return f"${cents / 100:.2f}"
+
+
+def format_report(entries: List[Entry]) -> str:
+    """Format a list of entries as a plain-text report.
+
+    Each entry produces a line: "{date} {description} {formatted_amount}".
+    The final line is "TOTAL {formatted_total}", where the total is the last
+    value of running_balance (or 0 for an empty list).
+
+    Lines are joined with "\\n"; no trailing newline.
+
+    Args:
+        entries: List of Entry objects.
+
+    Returns:
+        Formatted report string.
+    """
+    balances = running_balance(entries)
+    total = balances[-1] if balances else 0
+
+    lines = [
+        f"{entry.date} {entry.description} {format_cents(entry.amount_cents)}"
+        for entry in entries
+    ]
+    lines.append(f"TOTAL {format_cents(total)}")
+    return "\n".join(lines)
