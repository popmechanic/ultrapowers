+import pytest
+from ledger.parse import parse_line
+from ledger.balance import running_balance
+
+
+def test_running_balance_empty_list():
+    """Should return empty list for empty entries."""
+    result = running_balance([])
+    assert result == []
+
+
+def test_running_balance_single_entry():
+    """Should return list with single amount for single entry."""
+    entries = [parse_line("2026-01-15|coffee|10.00")]
+    result = running_balance(entries)
+    assert result == [1000]
+
+
+def test_running_balance_positive_amounts():
+    """Should compute running balance with positive amounts."""
+    entries = [
+        parse_line("2026-01-15|salary|10.00"),
+        parse_line("2026-01-16|bonus|5.00"),
+        parse_line("2026-01-17|interest|2.50"),
+    ]
+    result = running_balance(entries)
+    assert result == [1000, 1500, 1750]
+
+
+def test_running_balance_negative_amounts():
+    """Should compute running balance with negative amounts."""
+    entries = [
+        parse_line("2026-01-15|expense|-10.00"),
+        parse_line("2026-01-16|expense|-5.00"),
+        parse_line("2026-01-17|expense|-2.50"),
+    ]
+    result = running_balance(entries)
+    assert result == [-1000, -1500, -1750]
+
+
+def test_running_balance_mixed_amounts():
+    """Should compute running balance with mixed positive and negative amounts."""
+    entries = [
+        parse_line("2026-01-15|salary|10.00"),
+        parse_line("2026-01-16|expense|-4.50"),
+        parse_line("2026-01-17|expense|2.00"),
+    ]
+    result = running_balance(entries)
+    # 10.00 -> 1000 cents
+    # 10.00 - 4.50 = 5.50 -> 550 cents
+    # 5.50 + 2.00 = 7.50 -> 750 cents
+    assert result == [1000, 550, 750]
+
+
+def test_running_balance_with_zero_amount():
+    """Should handle zero amount entries correctly."""
+    entries = [
+        parse_line("2026-01-15|transaction|10.00"),
+        parse_line("2026-01-16|no-op|0.00"),
+        parse_line("2026-01-17|transaction|5.00"),
+    ]
+    result = running_balance(entries)
+    assert result == [1000, 1000, 1500]
+
+
+def test_running_balance_many_entries():
+    """Should correctly compute running balance for many entries."""
+    entries = [
+        parse_line("2026-01-01|event|100.00"),
+        parse_line("2026-01-02|event|-50.00"),
+        parse_line("2026-01-03|event|25.00"),
+        parse_line("2026-01-04|event|-10.00"),
+        parse_line("2026-01-05|event|5.00"),
+    ]
+    result = running_balance(entries)
+    assert result == [10000, 5000, 7500, 6500, 7000]
