+    def test_nothing_on_stdout_on_error(self, tmp_path, capsys):
+        f = tmp_path / "ledger.txt"
+        f.write_text("not-valid-line\n")
+        main([str(f)])
+        captured = capsys.readouterr()
+        assert captured.out == ""
