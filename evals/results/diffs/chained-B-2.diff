+from typing import List
+from ledger.model import Entry
+
+
+def running_balance(entries: List[Entry]) -> List[int]:
+    """Compute running balance from a list of entries.
+
+    Takes a list of Entry objects and returns a list of cumulative sums
+    of the amount_cents field.
+
+    Args:
+        entries: List of Entry objects.
+
+    Returns:
+        List of cumulative sums. Empty list if input is empty.
+
+    Example:
+        >>> running_balance([Entry(..., amount_cents=1000), Entry(..., amount_cents=-450), Entry(..., amount_cents=200)])
+        [1000, 550, 750]
+    """
+    result = []
+    cumulative_sum = 0
+    for entry in entries:
+        cumulative_sum += entry.amount_cents
+        result.append(cumulative_sum)
+    return result
