+import sys
+from typing import List
+
+from ledger.parse import parse_line
+from ledger.report import format_report
+
+
+def main(argv: List[str]) -> int:
+    """CLI entry point for the ledger tool.
+
+    Args:
+        argv: List whose first element is the path to a ledger file.
+
+    Returns:
+        0 on success, 1 on any ValueError.
+    """
+    path = argv[0]
+    with open(path) as f:
+        lines = f.readlines()
+
+    entries = []
+    try:
+        for line in lines:
+            if not line.strip():
+                continue
+            entries.append(parse_line(line.rstrip("\n")))
+    except ValueError as exc:
+        print(f"error: {exc}", file=sys.stderr)
+        return 1
+
+    print(format_report(entries))
+    return 0
