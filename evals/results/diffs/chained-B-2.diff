+++ b/ledger/parse.py
@@ -0,0 +1,32 @@
+import re
+from ledger.model import Entry
+
+_AMOUNT_RE = re.compile(r'^-?\d+\.\d{2}$')
+
+
+def parse_line(line: str) -> Entry:
+    """Parse a pipe-delimited ledger line into an Entry.
+
+    The expected format is: DATE|DESCRIPTION|AMOUNT
+    where AMOUNT is dollars with exactly two decimal places (e.g. -4.50).
+
+    Raises:
+        ValueError: 'bad line' if the line does not contain exactly 3 pipe-delimited fields.
+        ValueError: 'bad amount' if the amount field does not match -?\\d+\\.\\d{2}.
+        ValueError: propagated from Entry.validate() if date or description is invalid.
+    """
+    fields = line.split('|')
+    if len(fields) != 3:
+        raise ValueError("bad line")
+
+    date, description, amount_str = fields
+
+    if not _AMOUNT_RE.match(amount_str):
+        raise ValueError("bad amount")
+
+    # Convert dollars to integer cents
+    amount_cents = round(float(amount_str) * 100)
+
+    entry = Entry(date=date, description=description, amount_cents=amount_cents)
+    entry.validate()
+    return entry
