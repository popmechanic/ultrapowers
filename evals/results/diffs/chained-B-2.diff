@@ -0,0 +1,110 @@
+import pytest
+from ledger.parse import parse_line
+from ledger.model import Entry
+
+
+# --- Field count tests ---
+
+def test_parse_line_valid():
+    """Should parse a valid line and return an Entry."""
+    entry = parse_line("2026-01-15|coffee|-4.50")
+    assert isinstance(entry, Entry)
+    assert entry.date == "2026-01-15"
+    assert entry.description == "coffee"
+    assert entry.amount_cents == -450
+
+
+def test_parse_line_positive_amount():
+    """Should parse a positive amount correctly."""
+    entry = parse_line("2026-03-01|salary|1500.00")
+    assert entry.amount_cents == 150000
+
+
+def test_parse_line_too_few_fields():
+    """Should raise ValueError('bad line') for fewer than 3 fields."""
+    with pytest.raises(ValueError, match="bad line"):
+        parse_line("2026-01-15|coffee")
+
+
+def test_parse_line_too_many_fields():
+    """Should raise ValueError('bad line') for more than 3 fields."""
+    with pytest.raises(ValueError, match="bad line"):
+        parse_line("2026-01-15|coffee|-4.50|extra")
+
+
+def test_parse_line_only_one_field():
+    """Should raise ValueError('bad line') for a single field."""
+    with pytest.raises(ValueError, match="bad line"):
+        parse_line("2026-01-15")
+
+
+def test_parse_line_empty_string():
+    """Should raise ValueError('bad line') for an empty string."""
+    with pytest.raises(ValueError, match="bad line"):
+        parse_line("")
+
+
+# --- Amount format tests ---
+
+def test_parse_line_amount_no_decimal():
+    """Should raise ValueError('bad amount') when amount has no decimal point."""
+    with pytest.raises(ValueError, match="bad amount"):
+        parse_line("2026-01-15|coffee|-450")
+
+
+def test_parse_line_amount_one_decimal_place():
+    """Should raise ValueError('bad amount') when amount has only one decimal place."""
+    with pytest.raises(ValueError, match="bad amount"):
+        parse_line("2026-01-15|coffee|-4.5")
+
+
+def test_parse_line_amount_three_decimal_places():
+    """Should raise ValueError('bad amount') when amount has three decimal places."""
+    with pytest.raises(ValueError, match="bad amount"):
+        parse_line("2026-01-15|coffee|-4.500")
+
+
+def test_parse_line_amount_non_numeric():
+    """Should raise ValueError('bad amount') for non-numeric amount."""
+    with pytest.raises(ValueError, match="bad amount"):
+        parse_line("2026-01-15|coffee|abc")
+
+
+def test_parse_line_amount_empty():
+    """Should raise ValueError('bad amount') for empty amount."""
+    with pytest.raises(ValueError, match="bad amount"):
+        parse_line("2026-01-15|coffee|")
+
+
+def test_parse_line_amount_double_minus():
+    """Should raise ValueError('bad amount') for double minus sign."""
+    with pytest.raises(ValueError, match="bad amount"):
+        parse_line("2026-01-15|coffee|--4.50")
+
+
+def test_parse_line_amount_zero():
+    """Should parse zero amount correctly."""
+    entry = parse_line("2026-01-15|coffee|0.00")
+    assert entry.amount_cents == 0
+
+
+# --- Integration with Entry.validate() ---
+
+def test_parse_line_bad_date_raises():
+    """Should propagate ValueError from Entry.validate() for a bad date."""
+    with pytest.raises(ValueError, match="bad date"):
+        parse_line("2026/01/15|coffee|-4.50")
+
+
+def test_parse_line_empty_description_raises():
+    """Should propagate ValueError from Entry.validate() for empty description."""
+    with pytest.raises(ValueError, match="empty description"):
+        parse_line("2026-01-15||-4.50")
+
+
+def test_parse_line_returns_entry_with_correct_fields():
+    """Returned Entry should have correct date and description fields."""
+    entry = parse_line("2026-12-31|annual expense|12345.67")
+    assert entry.date == "2026-12-31"
+    assert entry.description == "annual expense"
+    assert entry.amount_cents == 1234567
