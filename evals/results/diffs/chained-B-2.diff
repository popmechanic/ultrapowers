@@ -0,0 +1,59 @@
+import pytest
+from ledger.model import Entry
+from ledger.report import format_cents, format_report
+
+
+class TestFormatCents:
+    def test_positive(self):
+        assert format_cents(1000) == "$10.00"
+
+    def test_negative(self):
+        assert format_cents(-450) == "-$4.50"
+
+    def test_zero(self):
+        assert format_cents(0) == "$0.00"
+
+    def test_small_positive(self):
+        assert format_cents(1) == "$0.01"
+
+    def test_large_positive(self):
+        assert format_cents(123456) == "$1234.56"
+
+
+class TestFormatReport:
+    def test_empty_entries(self):
+        result = format_report([])
+        assert result == "TOTAL $0.00"
+
+    def test_single_entry(self):
+        entries = [Entry(date="2024-01-01", description="Coffee", amount_cents=500)]
+        result = format_report(entries)
+        assert result == "2024-01-01 Coffee $5.00\nTOTAL $5.00"
+
+    def test_multiple_entries(self):
+        entries = [
+            Entry(date="2024-01-01", description="Coffee", amount_cents=500),
+            Entry(date="2024-01-02", description="Lunch", amount_cents=1200),
+            Entry(date="2024-01-03", description="Refund", amount_cents=-300),
+        ]
+        result = format_report(entries)
+        lines = result.split("\n")
+        assert len(lines) == 4
+        assert lines[0] == "2024-01-01 Coffee $5.00"
+        assert lines[1] == "2024-01-02 Lunch $12.00"
+        assert lines[2] == "2024-01-03 Refund -$3.00"
+        assert lines[3] == "TOTAL $14.00"
+
+    def test_no_trailing_newline(self):
+        entries = [Entry(date="2024-01-01", description="Test", amount_cents=100)]
+        result = format_report(entries)
+        assert not result.endswith("\n")
+
+    def test_total_uses_running_balance_last_value(self):
+        entries = [
+            Entry(date="2024-01-01", description="A", amount_cents=1000),
+            Entry(date="2024-01-02", description="B", amount_cents=-450),
+        ]
+        result = format_report(entries)
+        # running_balance([1000, -450]) = [1000, 550], last value is 550
+        assert result.endswith("TOTAL $5.50")
