+        f = tmp_path / "ledger.txt"
+        f.write_text("2024-01-01|Coffee|5.00\n")
+        result = main([str(f)])
+        assert result == 0
+
+    def test_prints_report_to_stdout(self, tmp_path, capsys):
+        f = tmp_path / "ledger.txt"
+        f.write_text("2024-01-01|Coffee|5.00\n")
+        main([str(f)])
+        captured = capsys.readouterr()
+        assert "2024-01-01 Coffee $5.00" in captured.out
+        assert "TOTAL $5.00" in captured.out
+
+    def test_nothing_on_stderr_for_success(self, tmp_path, capsys):
+        f = tmp_path / "ledger.txt"
+        f.write_text("2024-01-01|Coffee|5.00\n")
+        main([str(f)])
+        captured = capsys.readouterr()
+        assert captured.err == ""
+
+    def test_skips_blank_lines(self, tmp_path, capsys):
+        f = tmp_path / "ledger.txt"
+        f.write_text("2024-01-01|Coffee|5.00\n\n   \n2024-01-02|Lunch|12.00\n")
+        result = main([str(f)])
+        assert result == 0
+        captured = capsys.readouterr()
+        assert "2024-01-01 Coffee $5.00" in captured.out
+        assert "2024-01-02 Lunch $12.00" in captured.out
+        assert "TOTAL $17.00" in captured.out
+
+    def test_empty_file(self, tmp_path, capsys):
+        f = tmp_path / "ledger.txt"
+        f.write_text("")
+        result = main([str(f)])
+        assert result == 0
+        captured = capsys.readouterr()
+        assert "TOTAL $0.00" in captured.out
+
+    def test_file_with_only_blank_lines(self, tmp_path, capsys):
+        f = tmp_path / "ledger.txt"
+        f.write_text("\n   \n\t\n")
+        result = main([str(f)])
+        assert result == 0
+        captured = capsys.readouterr()
+        assert "TOTAL $0.00" in captured.out
+
+    def test_multiple_entries(self, tmp_path, capsys):
+        f = tmp_path / "ledger.txt"
+        f.write_text(
+            "2024-01-01|Coffee|5.00\n"
+            "2024-01-02|Lunch|12.00\n"
+            "2024-01-03|Refund|-3.00\n"
+        )
+        result = main([str(f)])
+        assert result == 0
+        captured = capsys.readouterr()
+        lines = captured.out.strip().split("\n")
+        assert lines[0] == "2024-01-01 Coffee $5.00"
+        assert lines[1] == "2024-01-02 Lunch $12.00"
+        assert lines[2] == "2024-01-03 Refund -$3.00"
+        assert lines[3] == "TOTAL $14.00"
+
+
+class TestMainError:
+    def test_returns_one_on_bad_line(self, tmp_path, capsys):
+        f = tmp_path / "ledger.txt"
+        f.write_text("not-valid-line\n")
