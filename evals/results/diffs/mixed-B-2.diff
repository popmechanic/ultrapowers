+"""Tests for apistub.serialize.to_json."""
+import json
+
+import pytest
+
+from apistub.schema import User
+from apistub.serialize import to_json
+
+
+def test_to_json_basic():
+    user = User(1, "Ada", "ada@ex.com")
+    result = to_json(user)
+    assert result == '{"id": 1, "name": "Ada", "email": "ada@ex.com"}'
+
+
+def test_to_json_returns_string():
+    user = User(42, "Bob", "bob@example.com")
+    result = to_json(user)
+    assert isinstance(result, str)
+
+
+def test_to_json_valid_json():
+    user = User(7, "Carol", "carol@test.org")
+    result = to_json(user)
+    parsed = json.loads(result)
+    assert parsed["id"] == 7
+    assert parsed["name"] == "Carol"
+    assert parsed["email"] == "carol@test.org"
+
+
+def test_to_json_key_order():
+    user = User(99, "Dave", "dave@example.com")
+    result = to_json(user)
+    # Keys must appear in the order: id, name, email
+    id_pos = result.index('"id"')
+    name_pos = result.index('"name"')
+    email_pos = result.index('"email"')
+    assert id_pos < name_pos < email_pos
+
+
+def test_to_json_default_separators():
+    # Default separators means (', ', ': ') — no trailing whitespace trimming
+    user = User(1, "Ada", "ada@ex.com")
+    result = to_json(user)
+    # Should match json.dumps with default separators exactly
+    expected = json.dumps({"id": 1, "name": "Ada", "email": "ada@ex.com"})
+    assert result == expected
+
+
+def test_to_json_integer_id():
+    user = User(0, "Zero", "zero@example.com")
+    result = to_json(user)
+    parsed = json.loads(result)
+    assert parsed["id"] == 0
+
+
+def test_to_json_only_three_keys():
+    user = User(5, "Eve", "eve@example.com")
+    result = to_json(user)
+    parsed = json.loads(result)
+    assert set(parsed.keys()) == {"id", "name", "email"}
