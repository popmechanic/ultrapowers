@@ -0,0 +1,32 @@
+import dataclasses
+from apistub.schema import User, FIELDS
+
+
+def test_user_is_dataclass():
+    assert dataclasses.is_dataclass(User)
+
+
+def test_user_fields():
+    fields = {f.name: f.type for f in dataclasses.fields(User)}
+    assert fields == {"id": int, "name": str, "email": str}
+
+
+def test_user_instantiation():
+    u = User(id=1, name="Alice", email="alice@example.com")
+    assert u.id == 1
+    assert u.name == "Alice"
+    assert u.email == "alice@example.com"
+
+
+def test_fields_constant_keys():
+    assert list(FIELDS.keys()) == ["name", "email"]
+
+
+def test_fields_constant_values():
+    assert FIELDS == {"name": str, "email": str}
+
+
+def test_fields_insertion_order():
+    # name must appear before email
+    keys = list(FIELDS.keys())
+    assert keys.index("name") < keys.index("email")
