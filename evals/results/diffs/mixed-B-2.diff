+"""Tests for apistub.validate.validate_payload."""
+import pytest
+from apistub.validate import validate_payload
+
+
+def test_valid_payload_returns_empty_list():
+    payload = {"name": "Alice", "email": "alice@example.com"}
+    assert validate_payload(payload) == []
+
+
+def test_missing_name():
+    payload = {"email": "alice@example.com"}
+    errors = validate_payload(payload)
+    assert "missing: name" in errors
+
+
+def test_missing_email():
+    payload = {"name": "Alice"}
+    errors = validate_payload(payload)
+    assert "missing: email" in errors
+
+
+def test_missing_both_fields():
+    payload = {}
+    errors = validate_payload(payload)
+    assert errors == ["missing: name", "missing: email"]
+
+
+def test_wrong_type_name():
+    payload = {"name": 123, "email": "alice@example.com"}
+    errors = validate_payload(payload)
+    assert "wrong type: name" in errors
+
+
+def test_wrong_type_email():
+    payload = {"name": "Alice", "email": 42}
+    errors = validate_payload(payload)
+    assert "wrong type: email" in errors
+
+
+def test_invalid_email_no_at_sign():
+    payload = {"name": "Alice", "email": "notanemail"}
+    errors = validate_payload(payload)
+    assert "invalid: email" in errors
+
+
+def test_valid_email_with_at_sign():
+    payload = {"name": "Alice", "email": "alice@example.com"}
+    errors = validate_payload(payload)
+    assert "invalid: email" not in errors
+
+
+def test_unknown_keys_are_ignored():
+    payload = {"name": "Alice", "email": "alice@example.com", "extra": "ignored"}
+    assert validate_payload(payload) == []
+
+
+def test_errors_in_fields_order():
+    # FIELDS order is name first, then email; errors should reflect that order
+    payload = {}
+    errors = validate_payload(payload)
+    assert errors.index("missing: name") < errors.index("missing: email")
+
+
+def test_wrong_type_email_does_not_trigger_invalid_email():
+    # email is present but not a str, so invalid: email should NOT be appended
+    payload = {"name": "Alice", "email": 42}
+    errors = validate_payload(payload)
+    assert "invalid: email" not in errors
+    assert "wrong type: email" in errors
+
+
+def test_missing_email_does_not_trigger_invalid_email():
+    # email is absent, so invalid: email should NOT be appended
+    payload = {"name": "Alice"}
+    errors = validate_payload(payload)
+    assert "invalid: email" not in errors
+    assert "missing: email" in errors
+
+
+def test_wrong_type_name_only():
+    payload = {"name": [], "email": "alice@example.com"}
+    errors = validate_payload(payload)
+    assert errors == ["wrong type: name"]
+
+
+def test_both_fields_wrong_type():
+    payload = {"name": 1, "email": 2}
+    errors = validate_payload(payload)
+    assert errors == ["wrong type: name", "wrong type: email"]
