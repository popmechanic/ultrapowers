@@ -0,0 +1,23 @@
+"""Payload validation for apistub."""
+from apistub import schema
+
+
+def validate_payload(payload: dict) -> list:
+    """Validate a payload dict against schema.FIELDS.
+
+    Returns a list of error strings. An empty list means the payload is valid.
+    """
+    errors = []
+
+    for key, expected_type in schema.FIELDS.items():
+        if key not in payload:
+            errors.append(f"missing: {key}")
+        elif not isinstance(payload[key], expected_type):
+            errors.append(f"wrong type: {key}")
+
+    # Email format check: only when email is present and is a str
+    if "email" in payload and isinstance(payload["email"], str):
+        if "@" not in payload["email"]:
+            errors.append("invalid: email")
+
+    return errors
