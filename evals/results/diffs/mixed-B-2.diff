+"""Schema definitions for apistub."""
+import dataclasses
+
+
+@dataclasses.dataclass
+class User:
+    id: int
+    name: str
+    email: str
+
+
+# Creation-payload contract: name first, then email.
+FIELDS = {"name": str, "email": str}
