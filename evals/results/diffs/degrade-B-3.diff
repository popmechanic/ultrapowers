diff --git a/confkit/config.py b/confkit/config.py
index 4bfd227..ec85a9e 100644
--- a/confkit/config.py
+++ b/confkit/config.py
@@ -1,6 +1,79 @@
+import re
+
 DEFAULTS = {"host": "localhost", "port": 8000, "debug": False}
 
 
-def get_config():
-    """Return a copy of the default configuration."""
-    return dict(DEFAULTS)
+def parse_value(raw):
+    """Convert a raw string to a typed Python value.
+
+    - "true" / "false" (case-insensitive) → bool
+    - Optional leading '-' followed by all digits → int
+    - Anything else → the string unchanged
+    """
+    if raw.lower() == "true":
+        return True
+    if raw.lower() == "false":
+        return False
+    if re.fullmatch(r"-?\d+", raw):
+        return int(raw)
+    return raw
+
+
+def load_env_overrides(environ):
+    """Return a dict of config overrides drawn from environment variables.
+
+    Only keys that start with 'CONFKIT_' are considered.  The prefix is
+    stripped and the remainder is lower-cased to form the config key.
+    Values are passed through :func:`parse_value` before being returned.
+    """
+    prefix = "CONFKIT_"
+    result = {}
+    for key, value in environ.items():
+        if key.startswith(prefix):
+            config_key = key[len(prefix):].lower()
+            result[config_key] = parse_value(value)
+    return result
+
+
+def load_file(path):
+    """Parse a key=value config file and return a dict.
+
+    Rules:
+    - Each line is stripped of leading/trailing whitespace.
+    - Blank lines and lines starting with '#' are skipped.
+    - All other lines must contain '=' or a ValueError is raised.
+    - The line is split on the FIRST '='; the key is the stripped left side
+      and the value is ``parse_value`` of the stripped right side.
+    """
+    result = {}
+    with open(path) as fh:
+        for line in fh:
+            line = line.strip()
+            if not line or line.startswith("#"):
+                continue
+            if "=" not in line:
+                raise ValueError("bad line")
+            key, _, raw_value = line.partition("=")
+            result[key.strip()] = parse_value(raw_value.strip())
+    return result
+
+
+def get_config(path=None, environ=None):
+    """Return a configuration dict merged from defaults, file, and environment.
+
+    Precedence (lowest → highest): defaults < file < environ.
+
+    Parameters
+    ----------
+    path:
+        Optional path to a key=value config file parsed by :func:`load_file`.
+    environ:
+        Optional mapping of environment variables passed to
+        :func:`load_env_overrides`.
+    """
+    config = dict(DEFAULTS)
+    if path is not None:
+        config.update(load_file(path))
+    if environ is not None:
+        config.update(load_env_overrides(environ))
+    return config
diff --git a/tests/test_env_overrides.py b/tests/test_env_overrides.py
new file mode 100644
index 0000000..fc0a1a6
--- /dev/null
+++ b/tests/test_env_overrides.py
@@ -0,0 +1,102 @@
+import pytest
+from confkit.config import parse_value, load_env_overrides
+
+
+# --- parse_value tests ---
+
+def test_parse_value_true_lowercase():
+    assert parse_value("true") is True
+
+
+def test_parse_value_true_uppercase():
+    assert parse_value("TRUE") is True
+
+
+def test_parse_value_true_mixed():
+    assert parse_value("True") is True
+
+
+def test_parse_value_false_lowercase():
+    assert parse_value("false") is False
+
+
+def test_parse_value_false_uppercase():
+    assert parse_value("FALSE") is False
+
+
+def test_parse_value_false_mixed():
+    assert parse_value("False") is False
+
+
+def test_parse_value_positive_integer():
+    assert parse_value("9000") == 9000
+    assert isinstance(parse_value("9000"), int)
+
+
+def test_parse_value_zero():
+    assert parse_value("0") == 0
+    assert isinstance(parse_value("0"), int)
+
+
+def test_parse_value_negative_integer():
+    assert parse_value("-42") == -42
+    assert isinstance(parse_value("-42"), int)
+
+
+def test_parse_value_string_passthrough():
+    assert parse_value("localhost") == "localhost"
+
+
+def test_parse_value_empty_string():
+    assert parse_value("") == ""
+
+
+def test_parse_value_float_string():
+    # Floats have non-digit chars — should stay as string
+    assert parse_value("3.14") == "3.14"
+
+
+def test_parse_value_mixed_string():
+    assert parse_value("8080abc") == "8080abc"
+
+
+# --- load_env_overrides tests ---
+
+def test_load_env_overrides_basic():
+    result = load_env_overrides({"CONFKIT_PORT": "9000", "PATH": "/bin"})
+    assert result == {"port": 9000}
+
+
+def test_load_env_overrides_ignores_non_confkit():
+    result = load_env_overrides({"PATH": "/usr/bin", "HOME": "/root"})
+    assert result == {}
+
+
+def test_load_env_overrides_multiple_keys():
+    result = load_env_overrides({
+        "CONFKIT_HOST": "example.com",
+        "CONFKIT_PORT": "4000",
+        "CONFKIT_DEBUG": "true",
+        "UNRELATED": "ignored",
+    })
+    assert result == {"host": "example.com", "port": 4000, "debug": True}
+
+
+def test_load_env_overrides_lowercases_key():
+    result = load_env_overrides({"CONFKIT_MY_KEY": "value"})
+    assert "my_key" in result
+    assert result["my_key"] == "value"
+
+
+def test_load_env_overrides_empty_environ():
+    assert load_env_overrides({}) == {}
+
+
+def test_load_env_overrides_parse_false():
+    result = load_env_overrides({"CONFKIT_DEBUG": "false"})
+    assert result == {"debug": False}
+
+
+def test_load_env_overrides_negative_int():
+    result = load_env_overrides({"CONFKIT_TIMEOUT": "-1"})
+    assert result == {"timeout": -1}
diff --git a/tests/test_file_layer.py b/tests/test_file_layer.py
new file mode 100644
index 0000000..0242722
--- /dev/null
+++ b/tests/test_file_layer.py
@@ -0,0 +1,187 @@
+import os
+import tempfile
+import pytest
+from confkit.config import load_file, get_config
+
+
+# --- load_file tests ---
+
+def _write_tmp(content):
+    """Write content to a temp file and return its path."""
+    f = tempfile.NamedTemporaryFile(mode="w", suffix=".conf", delete=False)
+    f.write(content)
+    f.close()
+    return f.name
+
+
+def test_load_file_basic():
+    path = _write_tmp("host=example.com\nport=9000\n")
+    try:
+        result = load_file(path)
+        assert result == {"host": "example.com", "port": 9000}
+    finally:
+        os.unlink(path)
+
+
+def test_load_file_skips_blank_lines():
+    path = _write_tmp("\nhost=example.com\n\n\nport=9000\n")
+    try:
+        result = load_file(path)
+        assert result == {"host": "example.com", "port": 9000}
+    finally:
+        os.unlink(path)
+
+
+def test_load_file_skips_comment_lines():
+    path = _write_tmp("# this is a comment\nhost=example.com\n# another comment\nport=9000\n")
+    try:
+        result = load_file(path)
+        assert result == {"host": "example.com", "port": 9000}
+    finally:
+        os.unlink(path)
+
+
+def test_load_file_bad_line_raises():
+    path = _write_tmp("host=example.com\nbadline\nport=9000\n")
+    try:
+        with pytest.raises(ValueError, match="bad line"):
+            load_file(path)
+    finally:
+        os.unlink(path)
+
+
+def test_load_file_splits_on_first_equals():
+    # Value contains '=' — should only split on first
+    path = _write_tmp("key=val=ue\n")
+    try:
+        result = load_file(path)
+        assert result == {"key": "val=ue"}
+    finally:
+        os.unlink(path)
+
+
+def test_load_file_strips_key_and_value():
+    path = _write_tmp("  host  =  example.com  \n")
+    try:
+        result = load_file(path)
+        assert result == {"host": "example.com"}
+    finally:
+        os.unlink(path)
+
+
+def test_load_file_bool_value():
+    path = _write_tmp("debug=true\n")
+    try:
+        result = load_file(path)
+        assert result == {"debug": True}
+    finally:
+        os.unlink(path)
+
+
+def test_load_file_empty_file():
+    path = _write_tmp("")
+    try:
+        result = load_file(path)
+        assert result == {}
+    finally:
+        os.unlink(path)
+
+
+def test_load_file_only_comments_and_blanks():
+    path = _write_tmp("# just a comment\n\n   \n# another\n")
+    try:
+        result = load_file(path)
+        assert result == {}
+    finally:
+        os.unlink(path)
+
+
+def test_load_file_integer_value():
+    path = _write_tmp("port=8080\n")
+    try:
+        result = load_file(path)
+        assert result == {"port": 8080}
+        assert isinstance(result["port"], int)
+    finally:
+        os.unlink(path)
+
+
+# --- get_config tests ---
+
+def test_get_config_no_args_returns_defaults():
+    result = get_config()
+    assert result == {"host": "localhost", "port": 8000, "debug": False}
+
+
+def test_get_config_no_args_returns_copy():
+    cfg = get_config()
+    cfg["port"] = 9999
+    assert get_config()["port"] == 8000
+
+
+def test_get_config_with_path_overrides_defaults():
+    path = _write_tmp("port=9001\nhost=example.com\n")
+    try:
+        result = get_config(path=path)
+        assert result["port"] == 9001
+        assert result["host"] == "example.com"
+        assert result["debug"] is False  # default preserved
+    finally:
+        os.unlink(path)
+
+
+def test_get_config_with_environ_overrides_defaults():
+    result = get_config(environ={"CONFKIT_PORT": "7777"})
+    assert result["port"] == 7777
+    assert result["host"] == "localhost"  # default preserved
+    assert result["debug"] is False
+
+
+def test_get_config_env_overrides_file():
+    # env takes precedence over file
+    path = _write_tmp("port=9001\nhost=filehost\n")
+    try:
+        result = get_config(path=path, environ={"CONFKIT_PORT": "5555"})
+        assert result["port"] == 5555       # env wins
+        assert result["host"] == "filehost"  # file wins over default
+        assert result["debug"] is False      # default preserved
+    finally:
+        os.unlink(path)
+
+
+def test_get_config_file_overrides_defaults_not_env():
+    path = _write_tmp("debug=true\n")
+    try:
+        result = get_config(path=path, environ={"CONFKIT_DEBUG": "false"})
+        # env (false) should beat file (true) for 'debug'
+        assert result["debug"] is False
+    finally:
+        os.unlink(path)
+
+
+def test_get_config_precedence_all_layers():
+    # defaults < file < env
+    path = _write_tmp("host=filehost\nport=2000\n")
+    try:
+        result = get_config(path=path, environ={"CONFKIT_HOST": "envhost"})
+        assert result["host"] == "envhost"   # env beats file
+        assert result["port"] == 2000        # file beats default
+        assert result["debug"] is False      # pure default
+    finally:
+        os.unlink(path)
+
+
+def test_get_config_only_path_no_environ():
+    path = _write_tmp("host=onlyfile\n")
+    try:
+        result = get_config(path=path)
+        assert result["host"] == "onlyfile"
+        assert result["port"] == 8000  # default
+    finally:
+        os.unlink(path)
+
+
+def test_get_config_only_environ_no_path():
+    result = get_config(environ={"CONFKIT_HOST": "envonly"})
+    assert result["host"] == "envonly"
+    assert result["port"] == 8000  # default
