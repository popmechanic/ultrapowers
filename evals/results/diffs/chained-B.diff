+import pytest
+from ledger.model import Entry
+
+
+def test_validate_empty_description():
+    """Raises ValueError('empty description') when description.strip() is empty."""
+    e = Entry(date="2026-01-15", description="", amount_cents=0)
+    with pytest.raises(ValueError) as excinfo:
+        e.validate()
+    assert str(excinfo.value) == "empty description"
+
+
+def test_validate_whitespace_only_description():
+    """Raises ValueError('empty description') when description is only whitespace."""
+    e = Entry(date="2026-01-15", description="   ", amount_cents=0)
+    with pytest.raises(ValueError) as excinfo:
+        e.validate()
+    assert str(excinfo.value) == "empty description"
+
+
+def test_validate_bad_date_format():
+    """Raises ValueError('bad date') unless date matches \\d{4}-\\d{2}-\\d{2}."""
+    # Test various bad date formats
+    bad_dates = [
+        "2026-1-15",      # single digit month
+        "26-01-15",       # two digit year
+        "2026-01-5",      # single digit day
+        "2026/01/15",     # wrong separator
+        "2026-01",        # missing day
+        "01-15",          # missing year
+        "2026-01-15-01",  # extra component
+        "not-a-date",     # invalid
+        "",               # empty
+    ]
+    for bad_date in bad_dates:
+        e = Entry(date=bad_date, description="coffee", amount_cents=0)
+        with pytest.raises(ValueError) as excinfo:
+            e.validate()
+        assert str(excinfo.value) == "bad date", f"Failed for date: {bad_date}"
+
+
+def test_validate_good_date_format():
+    """Does not raise for valid date format \\d{4}-\\d{2}-\\d{2}."""
+    e = Entry(date="2026-01-15", description="coffee", amount_cents=0)
+    result = e.validate()
+    assert result is None
+
+
+def test_validate_valid_entry():
+    """Returns None on a valid entry."""
+    e = Entry(date="2026-12-31", description="valid entry", amount_cents=100)
+    result = e.validate()
+    assert result is None
+
+
+def test_validate_valid_entry_with_whitespace_description():
+    """Valid entry with description containing spaces."""
+    e = Entry(date="2026-01-15", description="  valid description  ", amount_cents=-450)
+    result = e.validate()
+    assert result is None
+
+
+def test_validate_edge_case_dates():
+    """Test edge case valid dates."""
+    valid_dates = [
+        "0000-00-00",  # technically matches pattern
+        "9999-99-99",  # technically matches pattern
+        "2026-02-29",  # leap year
+    ]
+    for valid_date in valid_dates:
+        e = Entry(date=valid_date, description="test", amount_cents=0)
+        result = e.validate()
+        assert result is None
