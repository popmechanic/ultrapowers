+def running_balance(entries):
+    """Calculate running balance from a list of entries.
+
+    Args:
+        entries: A list of Entry objects with amount_cents attribute.
+
+    Returns:
+        A list of cumulative sums of amount_cents. Empty list if entries is empty.
+
+    Example:
+        >>> running_balance([Entry(..., amount_cents=1000), Entry(..., amount_cents=-450)])
+        [1000, 550]
+    """
+    result = []
+    cumulative = 0
+
+    for entry in entries:
+        cumulative += entry.amount_cents
+        result.append(cumulative)
+
+    return result
