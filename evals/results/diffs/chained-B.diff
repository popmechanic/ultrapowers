+import pytest
+from ledger.balance import running_balance
+from ledger.parse import parse_line
+
+
+class TestRunningBalance:
+    """Tests for running_balance function."""
+
+    def test_empty_list(self):
+        """Test that empty list returns empty list."""
+        result = running_balance([])
+        assert result == []
+
+    def test_single_positive_entry(self):
+        """Test with a single positive entry."""
+        entry = parse_line("2026-01-15|coffee|10.00")
+        result = running_balance([entry])
+        assert result == [1000]
+
+    def test_single_negative_entry(self):
+        """Test with a single negative entry."""
+        entry = parse_line("2026-01-15|expense|-4.50")
+        result = running_balance([entry])
+        assert result == [-450]
+
+    def test_multiple_positive_entries(self):
+        """Test with multiple positive entries."""
+        entries = [
+            parse_line("2026-01-15|salary|10.00"),
+            parse_line("2026-01-16|bonus|5.00"),
+            parse_line("2026-01-17|interest|1.00"),
+        ]
+        result = running_balance(entries)
+        assert result == [1000, 1500, 1600]
+
+    def test_mixed_positive_negative_entries(self):
+        """Test with mixed positive and negative amounts."""
+        entries = [
+            parse_line("2026-01-15|income|10.00"),
+            parse_line("2026-01-16|expense|-4.50"),
+            parse_line("2026-01-17|income|2.00"),
+        ]
+        result = running_balance(entries)
+        assert result == [1000, 550, 750]
+
+    def test_example_from_spec(self):
+        """Test the example from the task specification."""
+        # Example: amounts [1000, -450, 200] → [1000, 550, 750]
+        entries = [
+            parse_line("2026-01-15|a|10.00"),
+            parse_line("2026-01-16|b|-4.50"),
+            parse_line("2026-01-17|c|2.00"),
+        ]
+        result = running_balance(entries)
+        assert result == [1000, 550, 750]
+
+    def test_negative_balance(self):
+        """Test that balances can go negative."""
+        entries = [
+            parse_line("2026-01-15|expense|-5.00"),
+            parse_line("2026-01-16|expense|-3.00"),
+            parse_line("2026-01-17|income|6.00"),
+        ]
+        result = running_balance(entries)
+        assert result == [-500, -800, -200]
+
+    def test_zero_balance(self):
+        """Test balance with zero amount."""
+        entries = [
+            parse_line("2026-01-15|income|5.00"),
+            parse_line("2026-01-16|no-op|0.00"),
+            parse_line("2026-01-17|expense|-5.00"),
+        ]
+        result = running_balance(entries)
+        assert result == [500, 500, 0]
+
+    def test_large_amounts(self):
+        """Test with large amounts."""
+        entries = [
+            parse_line("2026-01-15|big|9999.99"),
+            parse_line("2026-01-16|bigger|1000000.00"),
+        ]
+        result = running_balance(entries)
+        assert result == [999999, 100999999]
+
+    def test_type_correctness(self):
+        """Test that result is a list of integers."""
+        entries = [
+            parse_line("2026-01-15|test|1.23"),
+            parse_line("2026-01-16|test|4.56"),
+        ]
+        result = running_balance(entries)
+        assert isinstance(result, list)
+        assert all(isinstance(x, int) for x in result)
+        assert len(result) == 2
+        assert result == [123, 579]
