+import re
+from decimal import Decimal
+
+from ledger.model import Entry
+
+
+def parse_line(line):
+    """Parse a ledger line into an Entry object.
+
+    Args:
+        line: A string in format "DATE|DESCRIPTION|AMOUNT"
+
+    Returns:
+        Entry: A validated Entry object
+
+    Raises:
+        ValueError: If the line format is invalid, amount format is invalid,
+                    or the entry fails validation.
+    """
+    # Split on '|'
+    parts = line.split('|')
+
+    # Check for exactly 3 fields
+    if len(parts) != 3:
+        raise ValueError("bad line")
+
+    date, description, amount_str = parts
+
+    # Validate amount format: -?\d+\.\d{2}
+    if not re.fullmatch(r'-?\d+\.\d{2}', amount_str):
+        raise ValueError("bad amount")
+
+    # Convert dollars to cents (as integer). Use Decimal to avoid IEEE-754
+    # float rounding errors (e.g. "0.29" -> 28 instead of 29).
+    amount_cents = int(Decimal(amount_str) * 100)
+
+    # Create Entry and validate
+    entry = Entry(date=date, description=description, amount_cents=amount_cents)
+    entry.validate()
+
+    return entry
