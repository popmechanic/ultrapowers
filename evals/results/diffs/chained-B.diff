+from ledger.balance import running_balance
+
+
+def format_cents(cents):
+    """Format an amount in cents as a dollar string.
+
+    Args:
+        cents: Integer amount in cents.
+
+    Returns:
+        Formatted string like "$10.00", "-$4.50", or "$0.00".
+
+    Examples:
+        >>> format_cents(1000)
+        '$10.00'
+        >>> format_cents(-450)
+        '-$4.50'
+        >>> format_cents(0)
+        '$0.00'
+    """
+    # Convert cents to dollars
+    dollars = cents / 100.0
+
+    # Handle negative amounts
+    if dollars < 0:
+        return f"-${abs(dollars):.2f}"
+    else:
+        return f"${dollars:.2f}"
+
+
+def format_report(entries):
+    """Format a report from a list of entries.
+
+    Args:
+        entries: A list of Entry objects.
+
+    Returns:
+        Formatted report string with one line per entry and a total line.
+        Lines are joined with "\n", no trailing newline.
+
+    Example:
+        >>> entries = [
+        ...     Entry(date="2026-01-15", description="coffee", amount_cents=-450),
+        ...     Entry(date="2026-01-16", description="salary", amount_cents=500000),
+        ... ]
+        >>> print(format_report(entries))
+        2026-01-15 coffee -$4.50
+        2026-01-16 salary $5000.00
+        TOTAL $4995.50
+    """
+    lines = []
+
+    # Format each entry
+    for entry in entries:
+        formatted_amount = format_cents(entry.amount_cents)
+        line = f"{entry.date} {entry.description} {formatted_amount}"
+        lines.append(line)
+
+    # Calculate total using running_balance
+    if entries:
+        balances = running_balance(entries)
+        total = balances[-1]  # Get the last (final) balance
+    else:
+        total = 0
+
+    # Add total line
+    formatted_total = format_cents(total)
+    lines.append(f"TOTAL {formatted_total}")
+
+    # Join with newline, no trailing newline
+    return "\n".join(lines)
