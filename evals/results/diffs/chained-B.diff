+import pytest
+from ledger.model import Entry
+from ledger.report import format_cents, format_report
+
+
+class TestFormatCents:
+    """Tests for format_cents function."""
+
+    def test_format_cents_positive(self):
+        """Test formatting positive amount in cents."""
+        assert format_cents(1000) == "$10.00"
+
+    def test_format_cents_negative(self):
+        """Test formatting negative amount in cents."""
+        assert format_cents(-450) == "-$4.50"
+
+    def test_format_cents_zero(self):
+        """Test formatting zero amount."""
+        assert format_cents(0) == "$0.00"
+
