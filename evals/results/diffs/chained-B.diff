+import pytest
+from ledger.parse import parse_line
+from ledger.model import Entry
+
+
+class TestParseLine:
+    """Tests for parse_line function."""
+
+    def test_valid_positive_amount(self):
+        """Test parsing a line with positive amount."""
+        result = parse_line("2026-01-15|coffee|4.50")
+        assert isinstance(result, Entry)
+        assert result.date == "2026-01-15"
+        assert result.description == "coffee"
+        assert result.amount_cents == 450
+
+    def test_valid_negative_amount(self):
+        """Test parsing a line with negative amount."""
+        result = parse_line("2026-01-15|coffee|-4.50")
+        assert isinstance(result, Entry)
+        assert result.date == "2026-01-15"
+        assert result.description == "coffee"
+        assert result.amount_cents == -450
+
+    def test_valid_zero_amount(self):
+        """Test parsing a line with zero amount."""
+        result = parse_line("2026-01-15|coffee|0.00")
+        assert isinstance(result, Entry)
+        assert result.date == "2026-01-15"
+        assert result.description == "coffee"
+        assert result.amount_cents == 0
+
+    def test_valid_large_amount(self):
+        """Test parsing a line with large amount."""
+        result = parse_line("2026-01-15|salary|1000.00")
+        assert isinstance(result, Entry)
+        assert result.amount_cents == 100000
+
+    def test_valid_large_negative_amount(self):
+        """Test parsing a line with large negative amount."""
+        result = parse_line("2026-01-15|expense|-999.99")
+        assert isinstance(result, Entry)
+        assert result.amount_cents == -99999
+
+    def test_float_rounding_cents_positive(self):
+        """Regression: 0.29 must be 29 cents, not 28 (float truncation)."""
+        result = parse_line("2026-01-15|x|0.29")
+        assert result.amount_cents == 29
+
+    def test_float_rounding_cents_negative(self):
+        """Regression: -655.31 must be -65531 cents, not -65530."""
+        result = parse_line("2026-01-15|x|-655.31")
+        assert result.amount_cents == -65531
+
+    def test_all_cents_convert_exactly(self):
+        """Every two-decimal amount in a range must convert to exact cents."""
+        for cents in range(-100000, 100001):
+            sign = "-" if cents < 0 else ""
+            whole, frac = divmod(abs(cents), 100)
+            amount_str = f"{sign}{whole}.{frac:02d}"
+            result = parse_line(f"2026-01-15|x|{amount_str}")
+            assert result.amount_cents == cents, amount_str
+
+    def test_bad_line_too_few_fields(self):
+        """Test that too few fields raises ValueError."""
+        with pytest.raises(ValueError, match="bad line"):
+            parse_line("2026-01-15|coffee")
+
+    def test_bad_line_too_many_fields(self):
+        """Test that too many fields raises ValueError."""
+        with pytest.raises(ValueError, match="bad line"):
+            parse_line("2026-01-15|coffee|4.50|extra")
+
+    def test_bad_line_empty(self):
+        """Test that empty line raises ValueError."""
+        with pytest.raises(ValueError, match="bad line"):
+            parse_line("")
+
+    def test_bad_line_single_field(self):
+        """Test that single field raises ValueError."""
+        with pytest.raises(ValueError, match="bad line"):
+            parse_line("2026-01-15")
+
+    def test_bad_amount_no_decimal(self):
+        """Test that amount without decimal raises ValueError."""
+        with pytest.raises(ValueError, match="bad amount"):
+            parse_line("2026-01-15|coffee|4")
+
+    def test_bad_amount_one_decimal_place(self):
+        """Test that amount with one decimal place raises ValueError."""
+        with pytest.raises(ValueError, match="bad amount"):
+            parse_line("2026-01-15|coffee|4.5")
+
+    def test_bad_amount_three_decimal_places(self):
+        """Test that amount with three decimal places raises ValueError."""
+        with pytest.raises(ValueError, match="bad amount"):
+            parse_line("2026-01-15|coffee|4.500")
+
+    def test_bad_amount_no_leading_digits(self):
+        """Test that amount without leading digits raises ValueError."""
+        with pytest.raises(ValueError, match="bad amount"):
+            parse_line("2026-01-15|coffee|.50")
+
+    def test_bad_amount_invalid_characters(self):
+        """Test that amount with invalid characters raises ValueError."""
+        with pytest.raises(ValueError, match="bad amount"):
+            parse_line("2026-01-15|coffee|4.5a")
+
+    def test_bad_amount_multiple_minuses(self):
+        """Test that amount with multiple minuses raises ValueError."""
+        with pytest.raises(ValueError, match="bad amount"):
+            parse_line("2026-01-15|coffee|--4.50")
+
+    def test_bad_amount_minus_not_leading(self):
+        """Test that minus not at start raises ValueError."""
+        with pytest.raises(ValueError, match="bad amount"):
+            parse_line("2026-01-15|coffee|4.-50")
+
+    def test_bad_date_raises_from_validate(self):
+        """Test that invalid date raises from validate method."""
+        with pytest.raises(ValueError, match="bad date"):
+            parse_line("2026-1-15|coffee|4.50")
+
+    def test_empty_description_raises_from_validate(self):
+        """Test that empty description raises from validate method."""
+        with pytest.raises(ValueError, match="empty description"):
+            parse_line("2026-01-15||4.50")
+
+    def test_whitespace_only_description_raises_from_validate(self):
+        """Test that whitespace-only description raises from validate method."""
+        with pytest.raises(ValueError, match="empty description"):
+            parse_line("2026-01-15|   |4.50")
