+import pytest
+from ledger.cli import main
+
+
+class TestMain:
+    """Test the CLI main function."""
+
+    def test_main_success_simple(self, tmp_path, capsys):
+        """Test main with a simple valid ledger file."""
+        # Create a temporary ledger file
+        ledger_file = tmp_path / "ledger.txt"
+        ledger_file.write_text("2026-01-15|coffee|-4.50\n2026-01-16|salary|5000.00\n")
+
+        # Call main
+        result = main([str(ledger_file)])
+
+        # Check return code
+        assert result == 0
+
+        # Check stdout
+        captured = capsys.readouterr()
+        lines = captured.out.strip().split("\n")
+        assert len(lines) == 3
+        assert lines[0] == "2026-01-15 coffee -$4.50"
+        assert lines[1] == "2026-01-16 salary $5000.00"
+        assert lines[2] == "TOTAL $4995.50"
+
+    def test_main_with_blank_lines(self, tmp_path, capsys):
+        """Test that main skips blank lines."""
+        ledger_file = tmp_path / "ledger.txt"
+        ledger_file.write_text(
+            "2026-01-15|coffee|-4.50\n"
+            "\n"  # blank line
+            "  \n"  # whitespace-only line
+            "2026-01-16|salary|5000.00\n"
+        )
+
+        result = main([str(ledger_file)])
+
+        assert result == 0
+
+        captured = capsys.readouterr()
+        lines = captured.out.strip().split("\n")
+        assert len(lines) == 3
+        assert lines[0] == "2026-01-15 coffee -$4.50"
+        assert lines[1] == "2026-01-16 salary $5000.00"
+        assert lines[2] == "TOTAL $4995.50"
+
+    def test_main_empty_file(self, tmp_path, capsys):
+        """Test main with an empty file."""
+        ledger_file = tmp_path / "ledger.txt"
+        ledger_file.write_text("")
+
+        result = main([str(ledger_file)])
+
+        assert result == 0
+
+        captured = capsys.readouterr()
+        # Should just have the TOTAL line
+        assert captured.out == "TOTAL $0.00\n"
+
+    def test_main_only_blank_lines(self, tmp_path, capsys):
+        """Test main with only blank lines."""
+        ledger_file = tmp_path / "ledger.txt"
+        ledger_file.write_text("  \n\n  \n")
+
+        result = main([str(ledger_file)])
+
+        assert result == 0
+
+        captured = capsys.readouterr()
+        assert captured.out == "TOTAL $0.00\n"
+
+    def test_main_bad_line_format(self, tmp_path, capsys):
+        """Test that main returns 1 and prints error on bad line format."""
+        ledger_file = tmp_path / "ledger.txt"
+        ledger_file.write_text("2026-01-15|coffee\n")  # Missing amount
+
+        result = main([str(ledger_file)])
+
+        assert result == 1
+
+        captured = capsys.readouterr()
+        assert "error: bad line" in captured.err
+
+    def test_main_bad_amount(self, tmp_path, capsys):
+        """Test that main returns 1 on bad amount format."""
+        ledger_file = tmp_path / "ledger.txt"
+        ledger_file.write_text("2026-01-15|coffee|bad\n")
+
+        result = main([str(ledger_file)])
+
+        assert result == 1
+
+        captured = capsys.readouterr()
+        assert "error: bad amount" in captured.err
+
+    def test_main_bad_date(self, tmp_path, capsys):
+        """Test that main returns 1 on bad date format."""
+        ledger_file = tmp_path / "ledger.txt"
+        ledger_file.write_text("01-15-2026|coffee|-4.50\n")  # Wrong date format
+
+        result = main([str(ledger_file)])
+
+        assert result == 1
+
+        captured = capsys.readouterr()
+        assert "error: bad date" in captured.err
+
+    def test_main_empty_description(self, tmp_path, capsys):
+        """Test that main returns 1 on empty description."""
+        ledger_file = tmp_path / "ledger.txt"
+        ledger_file.write_text("2026-01-15||-4.50\n")  # Empty description
+
+        result = main([str(ledger_file)])
+
+        assert result == 1
+
+        captured = capsys.readouterr()
+        assert "error: empty description" in captured.err
+
+    def test_main_whitespace_only_description(self, tmp_path, capsys):
+        """Test that main returns 1 on whitespace-only description."""
+        ledger_file = tmp_path / "ledger.txt"
+        ledger_file.write_text("2026-01-15|   |-4.50\n")  # Whitespace-only description
+
+        result = main([str(ledger_file)])
+
+        assert result == 1
+
+        captured = capsys.readouterr()
+        assert "error: empty description" in captured.err
+
+    def test_main_multiple_entries(self, tmp_path, capsys):
+        """Test main with multiple entries."""
+        ledger_file = tmp_path / "ledger.txt"
+        ledger_file.write_text(
+            "2026-01-15|coffee|-4.50\n"
+            "2026-01-16|breakfast|-10.00\n"
+            "2026-01-17|salary|5000.00\n"
+            "2026-01-18|groceries|-50.25\n"
+        )
+
+        result = main([str(ledger_file)])
+
+        assert result == 0
+
+        captured = capsys.readouterr()
+        lines = captured.out.strip().split("\n")
+        assert len(lines) == 5
+        assert lines[0] == "2026-01-15 coffee -$4.50"
+        assert lines[1] == "2026-01-16 breakfast -$10.00"
+        assert lines[2] == "2026-01-17 salary $5000.00"
+        assert lines[3] == "2026-01-18 groceries -$50.25"
+        assert lines[4] == "TOTAL $4935.25"
+
+    def test_main_error_stops_processing(self, tmp_path, capsys):
+        """Test that main stops processing on the first error."""
+        ledger_file = tmp_path / "ledger.txt"
+        ledger_file.write_text(
+            "2026-01-15|coffee|-4.50\n"
+            "2026-01-16|bad line without pipe\n"  # Error on second line
+            "2026-01-17|salary|5000.00\n"  # This shouldn't be processed
+        )
+
+        result = main([str(ledger_file)])
+
+        assert result == 1
+
+        captured = capsys.readouterr()
+        assert "error: bad line" in captured.err
