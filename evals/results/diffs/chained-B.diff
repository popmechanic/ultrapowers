+import sys
+from ledger.parse import parse_line
+from ledger.report import format_report
+
+
+def main(argv):
+    """Main CLI entry point for the ledger application.
+
+    Args:
+        argv: A list where the first element is a path to a ledger file.
+
+    Returns:
+        0 on success, 1 on error.
+
+    Behavior:
+        - Reads the file specified in argv[0]
+        - Skips blank (whitespace-only) lines
+        - Parses each remaining line using parse_line()
+        - Prints the formatted report to stdout
+        - On any ValueError, prints "error: {message}" to stderr
+    """
+    # Get the ledger file path from argv
+    ledger_file = argv[0]
+
+    try:
+        # Read the file
+        with open(ledger_file, 'r') as f:
+            lines = f.readlines()
+
+        # Parse entries, skipping blank lines
+        entries = []
+        for line in lines:
+            # Skip blank (whitespace-only) lines
+            if not line.strip():
+                continue
+
+            # Parse the line
+            entry = parse_line(line.rstrip('\n'))
+            entries.append(entry)
+
+        # Format and print the report
+        report = format_report(entries)
+        print(report)
+
+        return 0
+
+    except ValueError as e:
+        # Print error message to stderr
+        print(f"error: {e}", file=sys.stderr)
+        return 1
