+import pytest
+from textkit.word_count import word_count
+
+
+def test_basic_example():
+    result = word_count("The cat and the hat")
+    assert result == {"the": 2, "cat": 1, "and": 1, "hat": 1}
+
+
+def test_empty_string():
+    assert word_count("") == {}
+
+
+def test_no_word_characters():
+    assert word_count("!!! ???") == {}
+
+
+def test_punctuation_splits_words():
+    # "Don't" → "don" and "t"
+    result = word_count("Don't")
+    assert result == {"don": 1, "t": 1}
+
+
+def test_lowercasing():
+    result = word_count("Hello HELLO hello")
+    assert result == {"hello": 3}
+
+
+def test_numbers_counted():
+    result = word_count("abc 123 abc 123 123")
+    assert result == {"abc": 2, "123": 3}
+
+
+def test_mixed_alphanumeric():
+    result = word_count("abc1 abc1 abc2")
+    assert result == {"abc1": 2, "abc2": 1}
+
+
+def test_single_word():
+    assert word_count("word") == {"word": 1}
+
+
+def test_only_non_alpha():
+    assert word_count("---") == {}
+
+
+def test_newlines_and_tabs():
+    result = word_count("one\ntwo\ttwo")
+    assert result == {"one": 1, "two": 2}
