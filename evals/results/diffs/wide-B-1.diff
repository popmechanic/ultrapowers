@@ -0,0 +1,7 @@
+def reverse_words(text):
+    """Split on whitespace, reverse word order, join with single spaces.
+
+    Empty or whitespace-only input returns an empty string.
+    """
+    words = text.split()
+    return " ".join(reversed(words))
diff --git a/textkit/titlecase.py b/textkit/titlecase.py
new file mode 100644
index 0000000..bef22b0
--- /dev/null
+++ b/textkit/titlecase.py
@@ -0,0 +1,34 @@
+"""titlecase: capitalize words in a string following English title-case rules."""
+
+MINOR_WORDS = frozenset(
+    ["a", "an", "and", "as", "at", "but", "by", "for",
+     "in", "of", "on", "or", "the", "to"]
+)
+
+
+def titlecase(text: str) -> str:
+    """Return *text* formatted in title case.
+
+    Rules:
+    - Tokens are split on whitespace and rejoined with single spaces.
+    - Each word is capitalized (first letter upper, rest lower), except minor
+      words (``a an and as at but by for in of on or the to``), which are
+      fully lowercased.
+    - The first and last words are always capitalized regardless of whether
+      they are minor words.
+    - Empty or whitespace-only input returns ``""``.
+    """
+    words = text.split()
+    if not words:
+        return ""
+
+    result = []
+    last_index = len(words) - 1
+    for i, word in enumerate(words):
+        lower = word.lower()
+        if i == 0 or i == last_index or lower not in MINOR_WORDS:
+            result.append(lower.capitalize())
+        else:
+            result.append(lower)
+
+    return " ".join(result)
diff --git a/textkit/truncate.py b/textkit/truncate.py
new file mode 100644
index 0000000..d62abee
--- /dev/null
+++ b/textkit/truncate.py
@@ -0,0 +1,16 @@
+def truncate(text: str, limit: int, ellipsis: str = "...") -> str:
+    """Return *text* truncated to *limit* characters.
+
+    If ``len(text) <= limit`` the original text is returned unchanged.
+    Otherwise the text is sliced to ``limit - len(ellipsis)`` characters,
+    right-stripped of whitespace, and the ellipsis is appended.
+
+    Raises ``ValueError`` if *limit* is less than ``len(ellipsis)``.
+    """
+    if limit < len(ellipsis):
+        raise ValueError(
+            f"limit ({limit}) must be >= len(ellipsis) ({len(ellipsis)})"
+        )
+    if len(text) <= limit:
+        return text
+    return text[: limit - len(ellipsis)].rstrip() + ellipsis
diff --git a/textkit/word_count.py b/textkit/word_count.py
new file mode 100644
index 0000000..0f3f6de
--- /dev/null
+++ b/textkit/word_count.py
@@ -0,0 +1,13 @@
+import re
+
+
+def word_count(text: str) -> dict:
+    """Return a dict mapping each word to its count.
+
+    Words are maximal runs matching [a-z0-9]+ after lowercasing the input.
+    """
+    words = re.findall(r'[a-z0-9]+', text.lower())
+    counts: dict = {}
+    for word in words:
+        counts[word] = counts.get(word, 0) + 1
+    return counts
