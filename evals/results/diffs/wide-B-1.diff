@@ -0,0 +1,79 @@
+import pytest
+from textkit.titlecase import titlecase
+
+
+def test_basic_example():
+    assert titlecase("the lord of the rings") == "The Lord of the Rings"
+
+
+def test_empty_string():
+    assert titlecase("") == ""
+
+
+def test_whitespace_only():
+    assert titlecase("   ") == ""
+
+
+def test_single_word_minor():
+    """Single word, even a minor word, is always capitalized (first AND last)."""
+    assert titlecase("the") == "The"
+
+
+def test_single_word_normal():
+    assert titlecase("hello") == "Hello"
+
+
+def test_first_word_minor():
+    """First word always capitalized even if minor."""
+    assert titlecase("a tale of two cities") == "A Tale of Two Cities"
+
+
+def test_last_word_minor():
+    """Last word always capitalized even if minor."""
+    assert titlecase("what it is") == "What It Is"
+
+
+def test_all_minor_words():
+    """All words are minor, but first and last must be capitalized."""
+    assert titlecase("the and the") == "The and The"
+
+
+def test_extra_whitespace_collapsed():
+    """Multiple spaces between words are collapsed to single spaces."""
+    assert titlecase("hello   world") == "Hello World"
+
+
+def test_leading_trailing_whitespace():
+    """Leading/trailing whitespace is ignored."""
+    assert titlecase("  hello world  ") == "Hello World"
+
+
+def test_minor_words_lowercased():
+    """Minor words in the middle are lowercased."""
+    assert titlecase("War and Peace") == "War and Peace"
+
+
+def test_uppercase_input_normalized():
+    """Input words with mixed or all-uppercase are normalized."""
+    assert titlecase("THE LORD OF THE RINGS") == "The Lord of the Rings"
+
+
+def test_all_minor_word_list():
+    """Each minor word in the middle is lowercased."""
+    minor_words = ["a", "an", "and", "as", "at", "but", "by", "for",
+                   "in", "of", "on", "or", "the", "to"]
+    for word in minor_words:
+        result = titlecase(f"start {word} end")
+        assert result == f"Start {word} End", (
+            f"Minor word '{word}' should be lowercase in middle, got: {result}"
+        )
+
+
+def test_non_minor_words_capitalized():
+    """Non-minor words are capitalized (first letter upper, rest lower)."""
+    assert titlecase("gone with the wind") == "Gone With the Wind"
+
+
+def test_two_words():
+    """Two words: both are first and last, so both capitalized."""
+    assert titlecase("the end") == "The End"
