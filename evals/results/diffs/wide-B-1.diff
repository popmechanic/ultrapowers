new file mode 100644
index 0000000..75d3e59
--- /dev/null
+++ b/textkit/ngrams.py
@@ -0,0 +1,17 @@
+def ngrams(tokens, n):
+    """Return a list of n-gram tuples from tokens.
+
+    Args:
+        tokens: A list of tokens.
+        n: The size of each n-gram (must be >= 1).
+
+    Returns:
+        A list of tuples, each containing n consecutive tokens.
+        Returns [] when n > len(tokens).
+
+    Raises:
+        ValueError: If n < 1.
+    """
+    if n < 1:
+        raise ValueError(f"n must be >= 1, got {n}")
+    return [tuple(tokens[i:i + n]) for i in range(len(tokens) - n + 1)]
diff --git a/textkit/redact.py b/textkit/redact.py
new file mode 100644
index 0000000..bf25b9d
--- /dev/null
+++ b/textkit/redact.py
@@ -0,0 +1,9 @@
+import re
+
+
+def redact(text, words):
+    """Replace whole-word, case-insensitive occurrences of each word with '*' repeated to match length."""
+    for word in words:
+        pattern = re.compile(r"\b" + re.escape(word) + r"\b", re.IGNORECASE)
+        text = pattern.sub(lambda m: "*" * len(m.group()), text)
+    return text
