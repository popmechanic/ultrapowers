index 0000000..af13d6f
--- /dev/null
+++ b/tests/test_redact.py
@@ -0,0 +1,36 @@
+from textkit.redact import redact
+
+
+def test_basic_redact():
+    assert redact("Tell Alice that ALICE called", ["alice"]) == "Tell ***** that ***** called"
+
+
+def test_whole_word_boundary_with_punctuation():
+    # "scandal!" — the ! is not a word char, so boundary is respected
+    assert redact("scandal!", ["scandal"]) == "*******!"
+
+
+def test_no_partial_match():
+    # "scandals" does not have a word boundary after "scandal"
+    assert redact("scandals", ["scandal"]) == "scandals"
+
+
+def test_empty_words_unchanged():
+    assert redact("Hello world", []) == "Hello world"
+
+
+def test_multiple_words():
+    assert redact("foo and bar", ["foo", "bar"]) == "*** and ***"
+
+
+def test_case_insensitive():
+    assert redact("FOO foo Foo", ["foo"]) == "*** *** ***"
+
+
+def test_no_match_unchanged():
+    assert redact("hello world", ["xyz"]) == "hello world"
+
+
+def test_stars_match_length():
+    assert redact("hi", ["hi"]) == "**"
+    assert redact("hello", ["hello"]) == "*****"
