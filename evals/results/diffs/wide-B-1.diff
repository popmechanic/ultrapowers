@@ -0,0 +1,47 @@
+import pytest
+from textkit.truncate import truncate
+
+
+def test_short_text_unchanged():
+    assert truncate("hello", 10) == "hello"
+
+
+def test_exact_limit_unchanged():
+    assert truncate("hello", 5) == "hello"
+
+
+def test_truncate_with_default_ellipsis():
+    assert truncate("hello brave world", 10) == "hello b..."
+
+
+def test_truncate_with_custom_ellipsis():
+    assert truncate("hello brave world", 10, ellipsis="..!") == "hello b..!"
+
+
+def test_truncate_rstrips_before_ellipsis():
+    # "hello " (6 chars) rstripped is "hello"
+    assert truncate("hello world", 9) == "hello..."
+
+
+def test_raises_value_error_if_limit_less_than_ellipsis():
+    with pytest.raises(ValueError):
+        truncate("hello", 2)
+
+
+def test_raises_value_error_limit_equals_ellipsis_minus_one():
+    with pytest.raises(ValueError):
+        truncate("hello world", 2, ellipsis="...")
+
+
+def test_limit_equals_ellipsis_length_no_error():
+    # limit == len(ellipsis) is valid (returns just the ellipsis when text is long)
+    result = truncate("hello world", 3)
+    assert result == "..."
+
+
+def test_empty_string():
+    assert truncate("", 5) == ""
+
+
+def test_custom_ellipsis_empty():
+    assert truncate("hello world", 5, ellipsis="") == "hello"
