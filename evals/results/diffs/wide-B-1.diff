@@ -0,0 +1,36 @@
+import pytest
+from textkit.ngrams import ngrams
+
+
+def test_basic_bigrams():
+    assert ngrams(["a", "b", "c"], 2) == [("a", "b"), ("b", "c")]
+
+
+def test_trigrams():
+    assert ngrams(["a", "b", "c", "d"], 3) == [("a", "b", "c"), ("b", "c", "d")]
+
+
+def test_unigrams():
+    assert ngrams(["a", "b", "c"], 1) == [("a",), ("b",), ("c",)]
+
+
+def test_n_equals_len():
+    assert ngrams(["a", "b", "c"], 3) == [("a", "b", "c")]
+
+
+def test_n_greater_than_len_returns_empty():
+    assert ngrams(["a", "b"], 3) == []
+
+
+def test_empty_tokens_returns_empty():
+    assert ngrams([], 1) == []
+
+
+def test_n_less_than_1_raises_value_error():
+    with pytest.raises(ValueError):
+        ngrams(["a", "b", "c"], 0)
+
+
+def test_negative_n_raises_value_error():
+    with pytest.raises(ValueError):
+        ngrams(["a", "b", "c"], -1)
diff --git a/tests/test_redact.py b/tests/test_redact.py
