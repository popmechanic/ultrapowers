+"""Router for the apistub API."""
+import json
+import re
+from typing import Optional, Tuple
+
+from apistub.handlers import create_user, get_user
+from apistub.store import MemoryStore
+
+_GET_USER_RE = re.compile(r"^/users/(\d+)$")
+
+_NO_ROUTE = (404, json.dumps({"errors": ["no route"]}))
+
+
+def route(
+    store: MemoryStore,
+    method: str,
+    path: str,
+    payload: Optional[dict] = None,
+) -> Tuple[int, str]:
+    """Dispatch *method* + *path* to the appropriate handler.
+
+    Routes:
+        POST  /users          → create_user(store, payload)
+        GET   /users/<digits> → get_user(store, int(<digits>))
+        *     *               → (404, {"errors": ["no route"]})
+    """
+    if method == "POST" and path == "/users":
+        return create_user(store, payload)
+
+    if method == "GET":
+        match = _GET_USER_RE.fullmatch(path)
+        if match:
+            user_id = int(match.group(1))
+            return get_user(store, user_id)
+
+    return _NO_ROUTE
