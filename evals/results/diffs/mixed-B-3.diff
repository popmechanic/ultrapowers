+"""Payload validation for the apistub users API."""
+from apistub import schema
+
+
+def validate_payload(payload: dict) -> list[str]:
+    """Validate *payload* against the declared schema fields.
+
+    Returns a list of error strings in the order they are detected:
+    - ``"missing: <key>"`` when a required field is absent.
+    - ``"wrong type: <key>"`` when a field is present but has the wrong type.
+    - ``"invalid: email"`` when ``email`` is a ``str`` but contains no ``"@"``.
+    An empty list means the payload is valid.
+    Unknown keys are silently ignored.
+    """
+    errors: list[str] = []
+
+    for key, expected_type in schema.FIELDS.items():
+        if key not in payload:
+            errors.append(f"missing: {key}")
+        elif not isinstance(payload[key], expected_type):
+            errors.append(f"wrong type: {key}")
+
+    email = payload.get("email")
+    if isinstance(email, str) and "@" not in email:
+        errors.append("invalid: email")
+
+    return errors
