+"""Serialization utilities for apistub."""
+import json
+
+from apistub.schema import User
+
+
+def to_json(user: User) -> str:
+    """Serialize a User to a JSON string.
+
+    Keys are in insertion order: id, name, email.
+    Uses default separators (', ' and ': ').
+    """
+    data = {"id": user.id, "name": user.name, "email": user.email}
+    return json.dumps(data)
