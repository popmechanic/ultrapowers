+"""Tests for apistub.serialize.to_json."""
+import json
+
+import pytest
+
+from apistub.schema import User
+from apistub.serialize import to_json
+
+
+def test_to_json_basic():
+    user = User(1, "Ada", "ada@ex.com")
+    result = to_json(user)
+    assert result == '{"id": 1, "name": "Ada", "email": "ada@ex.com"}'
+
+
+def test_to_json_returns_string():
+    user = User(42, "Bob", "bob@example.com")
+    result = to_json(user)
+    assert isinstance(result, str)
+
+
+def test_to_json_key_order():
+    user = User(7, "Carol", "carol@test.org")
+    result = to_json(user)
+    parsed = json.loads(result)
+    assert list(parsed.keys()) == ["id", "name", "email"]
+
+
+def test_to_json_values():
+    user = User(99, "Dave", "dave@place.net")
+    result = to_json(user)
+    parsed = json.loads(result)
+    assert parsed["id"] == 99
+    assert parsed["name"] == "Dave"
+    assert parsed["email"] == "dave@place.net"
+
+
+def test_to_json_default_separators():
+    # Default separators are (', ', ': ') which produces standard JSON spacing.
+    # Compact separators (',', ':') would produce no spaces.
+    user = User(1, "Ada", "ada@ex.com")
+    result = to_json(user)
+    # The result should contain ': ' and ', ' (default separators)
+    assert ": " in result
+    assert ", " in result
+
+
+def test_to_json_integer_id():
+    user = User(0, "Zero", "zero@example.com")
+    result = to_json(user)
+    parsed = json.loads(result)
+    assert parsed["id"] == 0
+    assert isinstance(parsed["id"], int)
