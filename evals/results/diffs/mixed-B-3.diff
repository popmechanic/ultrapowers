+"""In-memory user store."""
+from __future__ import annotations
+
+from typing import List, Optional
+
+from apistub import schema
+
+
+class MemoryStore:
+    """Thread-unsafe in-memory store for User objects."""
+
+    def __init__(self) -> None:
+        self._users: List[schema.User] = []
+        self._next_id: int = 1
+
+    def add(self, name: str, email: str) -> schema.User:
+        """Create a User with an auto-incrementing id and store it."""
+        user = schema.User(id=self._next_id, name=name, email=email)
+        self._users.append(user)
+        self._next_id += 1
+        return user
+
+    def get(self, user_id: int) -> Optional[schema.User]:
+        """Return the User with the given id, or None if not found."""
+        for user in self._users:
+            if user.id == user_id:
+                return user
+        return None
+
+    def list(self) -> List[schema.User]:
+        """Return all users in insertion order."""
+        return list(self._users)
