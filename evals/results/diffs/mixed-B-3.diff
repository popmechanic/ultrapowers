+"""Request handlers for the apistub users API."""
+import json
+from typing import Tuple
+
+from apistub.serialize import to_json
+from apistub.store import MemoryStore
+from apistub.validate import validate_payload
+
+
+def create_user(store: MemoryStore, payload: dict) -> Tuple[int, str]:
+    """Validate *payload* and, if valid, add a user to *store*.
+
+    Returns:
+        ``(201, to_json(user))`` on success.
+        ``(400, json.dumps({"errors": errors}))`` when validation fails.
+    """
+    errors = validate_payload(payload)
+    if errors:
+        return (400, json.dumps({"errors": errors}))
+    user = store.add(name=payload["name"], email=payload["email"])
+    return (201, to_json(user))
+
+
+def get_user(store: MemoryStore, user_id: int) -> Tuple[int, str]:
+    """Look up a user by *user_id* in *store*.
+
+    Returns:
+        ``(200, to_json(user))`` when found.
+        ``(404, json.dumps({"errors": ["not found"]}))`` when missing.
+    """
+    user = store.get(user_id)
+    if user is None:
+        return (404, json.dumps({"errors": ["not found"]}))
+    return (200, to_json(user))
