@@ -0,0 +1,54 @@
+import pytest
+
+from ledger.model import Entry
+from ledger.parse import parse_line
+
+
+def test_parse_line_returns_entry_with_expected_fields():
+    entry = parse_line("2026-01-15|coffee|-4.50")
+    assert isinstance(entry, Entry)
+    assert (entry.date, entry.description, entry.amount_cents) == (
+        "2026-01-15",
+        "coffee",
+        -450,
+    )
+
+
+def test_parse_line_converts_positive_amount_to_cents():
+    entry = parse_line("2026-01-15|salary|1234.56")
+    assert entry.amount_cents == 123456
+
+
+def test_parse_line_raises_on_too_few_fields():
+    with pytest.raises(ValueError, match="bad line"):
+        parse_line("2026-01-15|coffee")
+
+
+def test_parse_line_raises_on_too_many_fields():
+    with pytest.raises(ValueError, match="bad line"):
+        parse_line("2026-01-15|coffee|-4.50|extra")
+
+
+def test_parse_line_raises_on_bad_amount_missing_decimals():
+    with pytest.raises(ValueError, match="bad amount"):
+        parse_line("2026-01-15|coffee|-4.5")
+
+
+def test_parse_line_raises_on_bad_amount_non_numeric():
+    with pytest.raises(ValueError, match="bad amount"):
+        parse_line("2026-01-15|coffee|free")
+
+
+def test_parse_line_raises_on_bad_amount_too_many_decimals():
+    with pytest.raises(ValueError, match="bad amount"):
+        parse_line("2026-01-15|coffee|-4.500")
+
+
+def test_parse_line_raises_on_bad_date_from_entry_validate():
+    with pytest.raises(ValueError, match="bad date"):
+        parse_line("2026-1-15|coffee|-4.50")
+
+
+def test_parse_line_raises_on_empty_description_from_entry_validate():
+    with pytest.raises(ValueError, match="empty description"):
+        parse_line("2026-01-15|   |-4.50")
