@@ -0,0 +1,20 @@
+from ledger.balance import running_balance
+from ledger.parse import parse_line
+
+
+def test_running_balance_returns_cumulative_sums():
+    entries = [
+        parse_line("2026-01-15|coffee|10.00"),
+        parse_line("2026-01-16|refund|-4.50"),
+        parse_line("2026-01-17|tip|2.00"),
+    ]
+    assert running_balance(entries) == [1000, 550, 750]
+
+
+def test_running_balance_returns_empty_list_for_empty_input():
+    assert running_balance([]) == []
+
+
+def test_running_balance_single_entry():
+    entries = [parse_line("2026-01-15|coffee|-4.50")]
+    assert running_balance(entries) == [-450]
