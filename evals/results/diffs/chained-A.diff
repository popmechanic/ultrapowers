+from ledger.cli import main
+
+
+def test_main_prints_report_and_returns_zero(tmp_path, capsys):
+    ledger_file = tmp_path / "ledger.txt"
+    ledger_file.write_text(
+        "2026-01-15|coffee|10.00\n"
+        "2026-01-16|refund|-4.50\n"
+    )
+
+    exit_code = main([str(ledger_file)])
+
+    captured = capsys.readouterr()
+    assert exit_code == 0
+    assert captured.out == (
+        "2026-01-15 coffee $10.00\n"
+        "2026-01-16 refund -$4.50\n"
+        "TOTAL $5.50\n"
+    )
+    assert captured.err == ""
+
+
+def test_main_skips_blank_lines(tmp_path, capsys):
+    ledger_file = tmp_path / "ledger.txt"
+    ledger_file.write_text(
+        "2026-01-15|coffee|10.00\n"
+        "\n"
+        "   \n"
+        "2026-01-16|refund|-4.50\n"
+    )
+
+    exit_code = main([str(ledger_file)])
+
+    captured = capsys.readouterr()
+    assert exit_code == 0
+    assert captured.out == (
+        "2026-01-15 coffee $10.00\n"
+        "2026-01-16 refund -$4.50\n"
+        "TOTAL $5.50\n"
+    )
+
+
+def test_main_handles_empty_file(tmp_path, capsys):
+    ledger_file = tmp_path / "ledger.txt"
+    ledger_file.write_text("")
+
+    exit_code = main([str(ledger_file)])
+
+    captured = capsys.readouterr()
+    assert exit_code == 0
+    assert captured.out == "TOTAL $0.00\n"
+    assert captured.err == ""
+
+
+def test_main_returns_one_and_prints_error_on_bad_line(tmp_path, capsys):
+    ledger_file = tmp_path / "ledger.txt"
+    ledger_file.write_text("2026-01-15|coffee\n")
+
+    exit_code = main([str(ledger_file)])
+
+    captured = capsys.readouterr()
+    assert exit_code == 1
+    assert captured.err == "error: bad line\n"
