@@ -0,0 +1,39 @@
+from ledger.parse import parse_line
+from ledger.report import format_cents, format_report
+
+
+def test_format_cents_positive():
+    assert format_cents(1000) == "$10.00"
+
+
+def test_format_cents_negative():
+    assert format_cents(-450) == "-$4.50"
+
+
+def test_format_cents_zero():
+    assert format_cents(0) == "$0.00"
+
+
+def test_format_report_multiple_entries():
+    entries = [
+        parse_line("2026-01-15|coffee|10.00"),
+        parse_line("2026-01-16|refund|-4.50"),
+        parse_line("2026-01-17|tip|2.00"),
+    ]
+    expected = (
+        "2026-01-15 coffee $10.00\n"
+        "2026-01-16 refund -$4.50\n"
+        "2026-01-17 tip $2.00\n"
+        "TOTAL $7.50"
+    )
+    assert format_report(entries) == expected
+
+
+def test_format_report_empty_entries():
+    assert format_report([]) == "TOTAL $0.00"
+
+
+def test_format_report_single_entry():
+    entries = [parse_line("2026-01-15|coffee|-4.50")]
+    expected = "2026-01-15 coffee -$4.50\nTOTAL -$4.50"
+    assert format_report(entries) == expected
