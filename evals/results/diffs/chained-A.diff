--- /dev/null
+++ b/ledger/parse.py
@@ -0,0 +1,24 @@
+import re
+
+from ledger.model import Entry
+
+_AMOUNT_RE = re.compile(r"-?\d+\.\d{2}")
+
+
+def parse_line(line: str) -> Entry:
+    fields = line.split("|")
+    if len(fields) != 3:
+        raise ValueError("bad line")
+
+    date, description, amount = fields
+
+    if not _AMOUNT_RE.fullmatch(amount):
+        raise ValueError("bad amount")
+
+    sign = -1 if amount.startswith("-") else 1
+    digits = amount.lstrip("-").replace(".", "")
+    amount_cents = sign * int(digits)
+
+    entry = Entry(date=date, description=description, amount_cents=amount_cents)
+    entry.validate()
+    return entry
diff --git a/ledger/report.py b/ledger/report.py
