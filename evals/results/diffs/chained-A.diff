new file mode 100644
index 0000000..fd37c7e
--- /dev/null
+++ b/tests/test_validate.py
@@ -0,0 +1,32 @@
+import pytest
+
+from ledger.model import Entry
+
+
+def test_validate_raises_on_empty_description():
+    e = Entry(date="2026-01-15", description="   ", amount_cents=100)
+    with pytest.raises(ValueError, match="empty description"):
+        e.validate()
+
+
+def test_validate_raises_on_bad_date():
+    e = Entry(date="2026-1-15", description="coffee", amount_cents=100)
+    with pytest.raises(ValueError, match="bad date"):
+        e.validate()
+
+
+def test_validate_raises_on_non_numeric_date():
+    e = Entry(date="not-a-date", description="coffee", amount_cents=100)
+    with pytest.raises(ValueError, match="bad date"):
+        e.validate()
+
+
+def test_validate_raises_on_partial_date_match():
+    e = Entry(date="2026-01-15x", description="coffee", amount_cents=100)
+    with pytest.raises(ValueError, match="bad date"):
+        e.validate()
+
+
+def test_validate_returns_none_on_valid_entry():
+    e = Entry(date="2026-01-15", description="coffee", amount_cents=-450)
+    assert e.validate() is None
