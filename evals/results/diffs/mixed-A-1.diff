+"""In-memory storage for users."""
+from __future__ import annotations
+
+from apistub.schema import User
+
+
+class MemoryStore:
+    """In-memory store for User objects with auto-incrementing IDs."""
+
+    def __init__(self):
+        """Initialize a new MemoryStore with empty users and id counter at 1."""
+        self._users: dict[int, User] = {}
+        self._next_id = 1
+
+    def add(self, name: str, email: str) -> User:
+        """Add a new user to the store and return the created User.
+
+        Args:
+            name: The user's name.
+            email: The user's email.
+
+        Returns:
+            A User instance with auto-incremented id.
+        """
+        user = User(id=self._next_id, name=name, email=email)
+        self._users[self._next_id] = user
+        self._next_id += 1
+        return user
+
+    def get(self, user_id: int) -> User | None:
+        """Retrieve a user by id.
+
+        Args:
+            user_id: The id of the user to retrieve.
+
+        Returns:
+            The User instance if found, None otherwise.
+        """
+        return self._users.get(user_id)
+
+    def list(self) -> list[User]:
+        """Return all users in insertion order.
+
+        Returns:
+            A list of all User instances in the order they were added.
+        """
+        return list(self._users.values())
