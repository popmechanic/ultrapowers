+"""Tests for the handlers module."""
+import json
+
+from apistub.store import MemoryStore
+from apistub.handlers import create_user, get_user
+
+
+class TestCreateUser:
+    """Tests for create_user handler."""
+
+    def test_valid_payload_returns_201_with_user_json(self):
+        """Valid payload should create a user and return (201, user JSON)."""
+        store = MemoryStore()
+        status, body = create_user(store, {"name": "Ada", "email": "ada@ex.com"})
+        assert status == 201
+        data = json.loads(body)
+        assert data["id"] == 1
+        assert data["name"] == "Ada"
+        assert data["email"] == "ada@ex.com"
+
+    def test_valid_payload_stores_user(self):
+        """create_user with valid payload should persist the user in the store."""
+        store = MemoryStore()
+        create_user(store, {"name": "Ada", "email": "ada@ex.com"})
+        user = store.get(1)
+        assert user is not None
+        assert user.name == "Ada"
+        assert user.email == "ada@ex.com"
+
+    def test_invalid_payload_returns_400_with_errors(self):
+        """An invalid payload should return (400, errors JSON) from validate_payload."""
+        store = MemoryStore()
+        status, body = create_user(store, {"email": "ada@ex.com"})
+        assert status == 400
+        data = json.loads(body)
+        assert "errors" in data
+        assert "missing: name" in data["errors"]
+
+    def test_invalid_payload_does_not_store_user(self):
+        """Invalid payload should not add any user to the store."""
+        store = MemoryStore()
+        create_user(store, {"email": "ada@ex.com"})
+        assert store.list() == []
+
+    def test_extra_fields_in_payload_are_ignored(self):
+        """Extra keys in the payload beyond name/email should be ignored."""
+        store = MemoryStore()
+        status, body = create_user(
+            store, {"name": "Ada", "email": "ada@ex.com", "role": "admin"}
+        )
+        assert status == 201
+        data = json.loads(body)
+        assert "role" not in data
+
+
+class TestGetUser:
+    """Tests for get_user handler."""
+
+    def test_existing_user_returns_200_with_user_json(self):
+        """Requesting an existing user id should return (200, user JSON)."""
+        store = MemoryStore()
+        store.add("Ada", "ada@ex.com")
+        status, body = get_user(store, 1)
+        assert status == 200
+        data = json.loads(body)
+        assert data["id"] == 1
+        assert data["name"] == "Ada"
+        assert data["email"] == "ada@ex.com"
+
+    def test_missing_user_returns_404_with_errors(self):
+        """Requesting a non-existent user id should return (404, errors JSON)."""
+        store = MemoryStore()
+        status, body = get_user(store, 999)
+        assert status == 404
+        data = json.loads(body)
+        assert "errors" in data
+        assert data["errors"] == ["not found"]
+
+    def test_get_correct_user_among_multiple(self):
+        """get_user should return the correct user when multiple exist."""
+        store = MemoryStore()
+        store.add("Ada", "ada@ex.com")
+        store.add("Bob", "bob@ex.com")
+        status, body = get_user(store, 2)
+        assert status == 200
+        data = json.loads(body)
+        assert data["name"] == "Bob"
+        assert data["id"] == 2
