+"""Router for the users API."""
+from __future__ import annotations
+
+import json
+
+from apistub.handlers import create_user, get_user
+
+
+def route(store, method: str, path: str, payload=None) -> tuple[int, str]:
+    """Route an HTTP request to the appropriate handler.
+
+    Args:
+        store: A MemoryStore instance.
+        method: HTTP method (e.g. "GET", "POST").
+        path: URL path (e.g. "/users", "/users/1").
+        payload: Request body dict (for POST requests); None is treated
+            as an empty body.
+
+    Returns:
+        A (status, body) tuple where status is an int and body is a JSON string.
+        - POST /users → create_user(store, payload)
+        - GET /users/<digits> → get_user(store, int(<digits>))
+        - Anything else → (404, json.dumps({"errors": ["no route"]}))
+    """
+    # Handle POST /users (a None payload validates like an empty body)
+    if method == "POST" and path == "/users":
+        return create_user(store, payload if payload is not None else {})
+
+    # Handle GET /users/<digits>
+    if method == "GET" and path.startswith("/users/"):
+        user_id_str = path.removeprefix("/users/")
+        # Match only non-empty ASCII digits: isdigit() alone also accepts
+        # characters like "²" that int() rejects. isdigit() is False for "".
+        if user_id_str.isascii() and user_id_str.isdigit():
+            user_id = int(user_id_str)
+            return get_user(store, user_id)
+
+    # No route matched
+    return (404, json.dumps({"errors": ["no route"]}))
