+"""Tests for the validate module."""
+from apistub.validate import validate_payload
+
+
+class TestValidatePayload:
+    """Tests for the validate_payload function."""
+
+    def test_empty_payload_missing_all_fields(self):
+        """An empty dict should return missing errors for all fields in FIELDS order."""
+        assert validate_payload({}) == ["missing: name", "missing: email"]
+
+    def test_valid_payload_with_all_fields(self):
+        """A payload with all valid fields should return []."""
+        payload = {"name": "Alice", "email": "alice@example.com"}
+        assert validate_payload(payload) == []
+
+    def test_missing_name(self):
+        """A payload missing 'name' should return ["missing: name"]."""
+        payload = {"email": "alice@example.com"}
+        assert validate_payload(payload) == ["missing: name"]
+
+    def test_missing_email(self):
+        """A payload missing 'email' should return ["missing: email"]."""
+        payload = {"name": "Alice"}
+        assert validate_payload(payload) == ["missing: email"]
+
+    def test_wrong_type_name(self):
+        """A payload with name of wrong type should return ["wrong type: name"]."""
+        payload = {"name": 123, "email": "alice@example.com"}
+        assert validate_payload(payload) == ["wrong type: name"]
+
+    def test_wrong_type_both_fields(self):
+        """A payload with both fields of wrong type should return errors in FIELDS order."""
+        payload = {"name": 123, "email": 456}
+        assert validate_payload(payload) == ["wrong type: name", "wrong type: email"]
+
+    def test_missing_and_wrong_type(self):
+        """A payload with one missing and one wrong type should report in FIELDS order."""
+        payload = {"name": 123}
+        assert validate_payload(payload) == ["wrong type: name", "missing: email"]
+
+    def test_invalid_email_no_at_sign(self):
+        """An email without '@' should return ["invalid: email"]."""
+        payload = {"name": "Alice", "email": "aliceexample.com"}
+        assert validate_payload(payload) == ["invalid: email"]
+
+    def test_invalid_email_with_missing_fields(self):
+        """Invalid email is checked after field loop, so field errors come first."""
+        payload = {"email": "invalid"}
+        assert validate_payload(payload) == ["missing: name", "invalid: email"]
+
+    def test_email_at_start_is_valid(self):
+        """An email with '@' at any position should be valid."""
+        payload = {"name": "Alice", "email": "@example.com"}
+        assert validate_payload(payload) == []
+
+    def test_email_at_end_is_valid(self):
+        """An email with '@' at any position should be valid."""
+        payload = {"name": "Alice", "email": "alice@"}
+        assert validate_payload(payload) == []
+
+    def test_email_multiple_at_signs_is_valid(self):
+        """An email with multiple '@' should be valid (only checks for presence)."""
+        payload = {"name": "Alice", "email": "alice@@example.com"}
+        assert validate_payload(payload) == []
+
+    def test_invalid_email_check_only_if_string(self):
+        """Invalid email check should only run if email is a string."""
+        payload = {"name": "Alice", "email": 123}
+        assert validate_payload(payload) == ["wrong type: email"]
+
+    def test_unknown_keys_ignored(self):
+        """Unknown keys in payload should be ignored."""
+        payload = {"name": "Alice", "email": "alice@example.com", "age": 30, "extra": "data"}
+        assert validate_payload(payload) == []
+
+    def test_unknown_keys_with_errors(self):
+        """Unknown keys should be ignored, but field errors should still be reported."""
+        payload = {"email": "alice@example.com", "age": 30}
+        assert validate_payload(payload) == ["missing: name"]
+
+    def test_none_as_name(self):
+        """None is not an instance of str, so should be wrong type."""
+        payload = {"name": None, "email": "alice@example.com"}
+        assert validate_payload(payload) == ["wrong type: name"]
+
+    def test_none_as_email(self):
+        """None is not an instance of str, so should be wrong type."""
+        payload = {"name": "Alice", "email": None}
+        assert validate_payload(payload) == ["wrong type: email"]
+
+    def test_list_as_name(self):
+        """A list is not an instance of str, so should be wrong type."""
+        payload = {"name": [], "email": "alice@example.com"}
+        assert validate_payload(payload) == ["wrong type: name"]
+
+    def test_dict_as_email(self):
+        """A dict is not an instance of str, so should be wrong type."""
+        payload = {"name": "Alice", "email": {}}
+        assert validate_payload(payload) == ["wrong type: email"]
+
+    def test_bool_as_name(self):
+        """bool is a subclass of int but not str, so should be wrong type."""
+        payload = {"name": True, "email": "alice@example.com"}
+        assert validate_payload(payload) == ["wrong type: name"]
