+
+class TestMemoryStoreGet:
+    """Tests for the MemoryStore.get method."""
+
+    def test_get_existing_user(self):
+        """get() should return the User with the given id."""
+        store = MemoryStore()
+        store.add("Alice", "alice@example.com")
+        retrieved_user = store.get(1)
+        assert retrieved_user is not None
