+"""Serialization utilities for the users API."""
+import json
+
+from apistub.schema import User
+
+
+def to_json(user: User) -> str:
+    """Convert a User to a JSON string.
+
+    Args:
+        user: A User instance to serialize.
+
+    Returns:
+        A JSON string with keys in order: id, name, email.
+    """
+    data = {
+        "id": user.id,
+        "name": user.name,
+        "email": user.email,
+    }
+    return json.dumps(data)
