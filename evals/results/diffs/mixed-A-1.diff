+"""Tests for the serialize module."""
+import json
+
+from apistub.serialize import to_json
+from apistub.schema import User
+
+
+class TestToJson:
+    """Tests for the to_json function."""
+
+    def test_to_json_key_order(self):
+        """to_json should have keys in exactly the order: id, name, email."""
+        user = User(1, "Ada", "ada@ex.com")
+        result = to_json(user)
+        parsed = json.loads(result)
+        assert list(parsed.keys()) == ["id", "name", "email"]
+
+    def test_to_json_exact_output(self):
+        """to_json should produce the exact expected output format."""
+        user = User(1, "Ada", "ada@ex.com")
+        result = to_json(user)
+        expected = '{"id": 1, "name": "Ada", "email": "ada@ex.com"}'
+        assert result == expected
+
+    def test_to_json_with_different_user(self):
+        """to_json should work with different user data."""
+        user = User(42, "Bob", "bob@example.com")
+        result = to_json(user)
+        expected = '{"id": 42, "name": "Bob", "email": "bob@example.com"}'
+        assert result == expected
+
+    def test_to_json_with_special_characters_in_name(self):
+        """to_json should properly escape special characters."""
+        user = User(2, "Charlie \"the boss\"", "charlie@example.com")
+        result = to_json(user)
+        parsed = json.loads(result)
+        assert parsed["name"] == 'Charlie "the boss"'
