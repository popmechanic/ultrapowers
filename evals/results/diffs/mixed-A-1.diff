+        store = MemoryStore()
+        user = store.add("Alice", "alice@example.com")
+        assert isinstance(user, User)
+        assert user.id == 1
+        assert user.name == "Alice"
+        assert user.email == "alice@example.com"
+
+    def test_add_second_user_increments_id(self):
+        """The second add() should return a User with id=2."""
+        store = MemoryStore()
+        user1 = store.add("Alice", "alice@example.com")
+        user2 = store.add("Bob", "bob@example.com")
+        assert user1.id == 1
+        assert user2.id == 2
+        assert user2.name == "Bob"
+        assert user2.email == "bob@example.com"
+
+    def test_add_multiple_users_increments_sequentially(self):
+        """Multiple add() calls should increment id sequentially."""
+        store = MemoryStore()
+        user1 = store.add("Alice", "alice@example.com")
+        user2 = store.add("Bob", "bob@example.com")
+        user3 = store.add("Charlie", "charlie@example.com")
+        assert user1.id == 1
+        assert user2.id == 2
+        assert user3.id == 3
