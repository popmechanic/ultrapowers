+"""Handler functions for the users API."""
+from __future__ import annotations
+
+import json
+
+from apistub.validate import validate_payload
+from apistub.serialize import to_json
+
+
+def create_user(store, payload) -> tuple[int, str]:
+    """Handle a create-user request.
+
+    Args:
+        store: A MemoryStore instance.
+        payload: A dict with the request body fields.
+
+    Returns:
+        A (status, body) tuple where status is an int and body is a JSON string.
+        Returns (400, errors JSON) if validation fails.
+        Returns (201, user JSON) on success.
+    """
+    errors = validate_payload(payload)
+    if errors:
+        return (400, json.dumps({"errors": errors}))
+    user = store.add(payload["name"], payload["email"])
+    return (201, to_json(user))
+
+
+def get_user(store, user_id) -> tuple[int, str]:
+    """Handle a get-user request.
+
+    Args:
+        store: A MemoryStore instance.
+        user_id: The integer id of the user to retrieve.
+
+    Returns:
+        A (status, body) tuple where status is an int and body is a JSON string.
+        Returns (200, user JSON) if found.
+        Returns (404, errors JSON) if not found.
+    """
+    user = store.get(user_id)
+    if user is None:
+        return (404, json.dumps({"errors": ["not found"]}))
+    return (200, to_json(user))
