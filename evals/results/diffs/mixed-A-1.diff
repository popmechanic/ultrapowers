+"""Tests for the schema module."""
+import dataclasses
+
+from apistub.schema import User, FIELDS
+
+
+class TestUser:
+    """Tests for the User dataclass."""
+
+    def test_user_is_dataclass(self):
+        """User must be a dataclass."""
+        assert dataclasses.is_dataclass(User)
+
+    def test_user_field_order(self):
+        """User fields must be declared in the order id, name, email."""
+        assert [f.name for f in dataclasses.fields(User)] == ["id", "name", "email"]
+
+    def test_user_positional_construction(self):
+        """User must support positional construction (id, name, email)."""
+        user = User(1, "Ada", "ada@ex.com")
+        assert user.id == 1
+        assert user.name == "Ada"
+        assert user.email == "ada@ex.com"
+
+    def test_user_has_id_field(self):
+        """User should have an id field of type int."""
+        user = User(id=1, name="Alice", email="alice@example.com")
+        assert user.id == 1
+
+    def test_user_has_name_field(self):
+        """User should have a name field of type str."""
+        user = User(id=1, name="Alice", email="alice@example.com")
+        assert user.name == "Alice"
+
+    def test_user_has_email_field(self):
+        """User should have an email field of type str."""
+        user = User(id=1, name="Alice", email="alice@example.com")
+        assert user.email == "alice@example.com"
+
+    def test_user_creation(self):
+        """User should be creatable with id, name, and email."""
+        user = User(id=42, name="Bob", email="bob@example.com")
+        assert user.id == 42
+        assert user.name == "Bob"
+        assert user.email == "bob@example.com"
+
+
+class TestFields:
+    """Tests for the FIELDS constant."""
+
+    def test_fields_is_dict(self):
+        """FIELDS must be a dict."""
+        assert isinstance(FIELDS, dict)
+
+    def test_fields_contains_name_and_email(self):
+        """FIELDS should contain name and email keys."""
+        assert "name" in FIELDS
+        assert "email" in FIELDS
+
+    def test_fields_name_is_str(self):
+        """FIELDS['name'] should be str type."""
+        assert FIELDS["name"] is str
+
+    def test_fields_email_is_str(self):
+        """FIELDS['email'] should be str type."""
+        assert FIELDS["email"] is str
+
+    def test_fields_insertion_order(self):
+        """FIELDS should have name before email (insertion order matters)."""
+        keys = list(FIELDS.keys())
+        assert keys == ["name", "email"]
+
+    def test_fields_does_not_contain_id(self):
+        """FIELDS should not contain id (it's not part of creation payload)."""
+        assert "id" not in FIELDS
