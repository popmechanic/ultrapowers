+"""Validation for API payloads."""
+from apistub import schema
+
+
+def validate_payload(payload):
+    """Validate a user payload.
+
+    Args:
+        payload: A dict to validate against FIELDS schema.
+
+    Returns:
+        A list of error strings. Empty list if valid.
+        Errors include:
+        - "missing: <key>" for missing fields
+        - "wrong type: <key>" for fields with incorrect types
+        - "invalid: email" if email is present, is a str, but lacks "@"
+    """
+    errors = []
+
+    # Check each field in FIELDS (in order)
+    for key, expected_type in schema.FIELDS.items():
+        if key not in payload:
+            errors.append(f"missing: {key}")
+        elif not isinstance(payload[key], expected_type):
+            errors.append(f"wrong type: {key}")
+
+    # Check email validity (only if email is present and a string)
+    email = payload.get("email")
+    if isinstance(email, str) and "@" not in email:
+        errors.append("invalid: email")
+
+    return errors
