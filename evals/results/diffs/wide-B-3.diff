new file mode 100644
index 0000000..75d3e59
--- /dev/null
+++ b/textkit/ngrams.py
@@ -0,0 +1,17 @@
+def ngrams(tokens, n):
+    """Return a list of n-gram tuples from tokens.
+
+    Args:
+        tokens: A list of tokens.
+        n: The size of each n-gram (must be >= 1).
+
+    Returns:
+        A list of tuples, each containing n consecutive tokens.
+        Returns [] when n > len(tokens).
+
+    Raises:
+        ValueError: If n < 1.
+    """
+    if n < 1:
+        raise ValueError(f"n must be >= 1, got {n}")
+    return [tuple(tokens[i:i + n]) for i in range(len(tokens) - n + 1)]
diff --git a/textkit/redact.py b/textkit/redact.py
new file mode 100644
index 0000000..ad910cc
--- /dev/null
+++ b/textkit/redact.py
@@ -0,0 +1,18 @@
+import re
+
+
+def redact(text: str, words) -> str:
+    """Replace whole-word occurrences of each word in *words* with '*' characters.
+
+    Matching is case-insensitive and honours regex word boundaries so that
+    partial matches inside longer tokens are left untouched.
+    """
+    words = list(words)
+    if not words:
+        return text
+
+    def _replace(match: re.Match) -> str:
+        return "*" * len(match.group())
+
+    pattern = "|".join(r"\b" + re.escape(w) + r"\b" for w in words)
+    return re.sub(pattern, _replace, text, flags=re.IGNORECASE)
