+import pytest
+from textkit.redact import redact
+
+
+def test_basic_redact():
+    assert redact("Tell Alice that ALICE called", ["alice"]) == "Tell ***** that ***** called"
+
+
+def test_whole_word_with_punctuation():
+    assert redact("scandal!", ["scandal"]) == "*******!"
+
+
+def test_no_partial_match():
+    assert redact("scandals", ["scandal"]) == "scandals"
+
+
+def test_empty_words_returns_unchanged():
+    assert redact("hello world", []) == "hello world"
+
+
+def test_empty_text():
+    assert redact("", ["alice"]) == ""
+
+
+def test_multiple_words():
+    assert redact("Bob and Alice went to the store", ["bob", "alice"]) == "*** and ***** went to the store"
+
+
+def test_case_insensitive():
+    assert redact("HELLO hello Hello", ["hello"]) == "***** ***** *****"
+
+
+def test_word_not_present():
+    assert redact("hello world", ["foo"]) == "hello world"
+
+
+def test_redact_preserves_surrounding_text():
+    assert redact("pre-scandal-post", ["scandal"]) == "pre-*******-post"
+
+
+def test_redact_with_newlines():
+    assert redact("alice\nalice", ["alice"]) == "*****\n*****"
