@@ -0,0 +1,72 @@
+import pytest
+from textkit.titlecase import titlecase
+
+
+def test_basic_example():
+    assert titlecase("the lord of the rings") == "The Lord of the Rings"
+
+
+def test_first_word_always_capitalized():
+    assert titlecase("a tale of two cities") == "A Tale of Two Cities"
+
+
+def test_last_word_always_capitalized():
+    assert titlecase("to be or not to be") == "To Be or Not to Be"
+
+
+def test_minor_words_lowercase_in_middle():
+    assert titlecase("cat and dog") == "Cat and Dog"
+    assert titlecase("fish or fowl") == "Fish or Fowl"
+
+
+def test_all_minor_words():
+    # "a an and as at but by for in of on or the to"
+    assert titlecase("the cat in the hat") == "The Cat in the Hat"
+    assert titlecase("gone with the wind") == "Gone With the Wind"
+
+
+def test_empty_string():
+    assert titlecase("") == ""
+
+
+def test_whitespace_only():
+    assert titlecase("   ") == ""
+    assert titlecase("\t\n") == ""
+
+
+def test_single_word():
+    assert titlecase("hello") == "Hello"
+
+
+def test_single_minor_word():
+    # Single word is both first and last — must be capitalized
+    assert titlecase("the") == "The"
+    assert titlecase("a") == "A"
+
+
+def test_multiple_spaces_collapsed():
+    assert titlecase("the  lord   of  the  rings") == "The Lord of the Rings"
+
+
+def test_mixed_case_input():
+    assert titlecase("THE LORD OF THE RINGS") == "The Lord of the Rings"
+    assert titlecase("tHe LoRd") == "The Lord"
+
+
+def test_every_minor_word():
+    minor = ["a", "an", "and", "as", "at", "but", "by", "for", "in", "of", "on", "or", "the", "to"]
+    for word in minor:
+        # Surrounded by non-minor words so it stays lowercase in the middle
+        sentence = f"cat {word} dog"
+        result = titlecase(sentence)
+        parts = result.split()
+        assert parts[1] == word, f"Expected '{word}' to remain lowercase in middle of '{sentence}', got '{result}'"
+
+
+def test_two_words_both_capitalized():
+    # First and last are both capitalized even if both minor
+    assert titlecase("a to") == "A To"
+
+
+def test_last_word_minor():
+    assert titlecase("waiting for the") == "Waiting for The"
