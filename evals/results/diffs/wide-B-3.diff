@@ -0,0 +1,8 @@
+def reverse_words(text: str) -> str:
+    """Reverse the order of words in text, splitting on whitespace.
+
+    Multiple consecutive whitespace characters are treated as a single
+    delimiter. Empty or whitespace-only input returns an empty string.
+    """
+    words = text.split()
+    return " ".join(reversed(words))
diff --git a/textkit/titlecase.py b/textkit/titlecase.py
new file mode 100644
index 0000000..9e03d01
--- /dev/null
+++ b/textkit/titlecase.py
@@ -0,0 +1,34 @@
+"""titlecase — title-case a string, keeping minor words lowercase."""
+
+MINOR_WORDS = frozenset(
+    ["a", "an", "and", "as", "at", "but", "by", "for", "in", "of", "on", "or", "the", "to"]
+)
+
+
+def titlecase(text: str) -> str:
+    """Return *text* in title case.
+
+    Rules:
+    - Split on whitespace; rejoin with a single space.
+    - Each word is capitalized (first letter upper, rest lower).
+    - Minor words (a, an, and, as, at, but, by, for, in, of, on, or, the, to)
+      are left fully lowercase, except:
+    - The first and last words are always capitalized.
+    - Empty or whitespace-only input returns "".
+    """
+    words = text.split()
+    if not words:
+        return ""
+
+    result = []
+    last_index = len(words) - 1
+    for i, word in enumerate(words):
+        normalized = word.lower()
+        if i == 0 or i == last_index:
+            result.append(normalized.capitalize())
+        elif normalized in MINOR_WORDS:
+            result.append(normalized)
+        else:
+            result.append(normalized.capitalize())
+
+    return " ".join(result)
diff --git a/textkit/truncate.py b/textkit/truncate.py
new file mode 100644
index 0000000..4b495df
--- /dev/null
+++ b/textkit/truncate.py
@@ -0,0 +1,17 @@
+def truncate(text: str, limit: int, ellipsis: str = "...") -> str:
+    """Truncate *text* to at most *limit* characters.
+
+    If ``len(text) <= limit`` the text is returned unchanged.
+    Otherwise the text is cut so that the result (including *ellipsis*)
+    is exactly *limit* characters long, with any trailing whitespace
+    before the ellipsis stripped.
+
+    Raises ``ValueError`` if *limit* is smaller than ``len(ellipsis)``.
+    """
+    if limit < len(ellipsis):
+        raise ValueError(
+            f"limit ({limit}) must be >= len(ellipsis) ({len(ellipsis)})"
+        )
+    if len(text) <= limit:
+        return text
+    return text[: limit - len(ellipsis)].rstrip() + ellipsis
diff --git a/textkit/word_count.py b/textkit/word_count.py
new file mode 100644
index 0000000..134f17d
--- /dev/null
+++ b/textkit/word_count.py
@@ -0,0 +1,13 @@
+import re
+
+
+def word_count(text: str) -> dict[str, int]:
+    """Return a dict mapping each word to its frequency in text.
+
+    Words are maximal runs of [a-z0-9]+ after lowercasing the input.
+    """
+    words = re.findall(r"[a-z0-9]+", text.lower())
+    counts: dict[str, int] = {}
+    for word in words:
+        counts[word] = counts.get(word, 0) + 1
+    return counts
