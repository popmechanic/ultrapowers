@@ -0,0 +1,94 @@
+import pytest
+from ledger.parse import parse_line
+from ledger.model import Entry
+
+
+# --- Happy path ---
+
+def test_parse_line_basic():
+    entry = parse_line("2026-01-15|coffee|-4.50")
+    assert isinstance(entry, Entry)
+    assert entry.date == "2026-01-15"
+    assert entry.description == "coffee"
+    assert entry.amount_cents == -450
+
+
+def test_parse_line_positive_amount():
+    entry = parse_line("2026-06-01|salary|3000.00")
+    assert entry.amount_cents == 300000
+
+
+def test_parse_line_zero_amount():
+    entry = parse_line("2026-03-10|adjustment|0.00")
+    assert entry.amount_cents == 0
+
+
+def test_parse_line_large_amount():
+    entry = parse_line("2026-01-01|rent|-1500.75")
+    assert entry.amount_cents == -150075
+
+
+# --- Bad line (wrong number of fields) ---
+
+def test_parse_line_too_few_fields():
+    with pytest.raises(ValueError, match="bad line"):
+        parse_line("2026-01-15|coffee")
+
+
+def test_parse_line_too_many_fields():
+    with pytest.raises(ValueError, match="bad line"):
+        parse_line("2026-01-15|coffee|-4.50|extra")
+
+
+def test_parse_line_no_separators():
+    with pytest.raises(ValueError, match="bad line"):
+        parse_line("nodatanodesc")
+
+
+def test_parse_line_empty_string():
+    with pytest.raises(ValueError, match="bad line"):
+        parse_line("")
+
+
+# --- Bad amount ---
+
+def test_parse_line_amount_no_decimal():
+    with pytest.raises(ValueError, match="bad amount"):
+        parse_line("2026-01-15|coffee|-450")
+
+
+def test_parse_line_amount_one_decimal_place():
+    with pytest.raises(ValueError, match="bad amount"):
+        parse_line("2026-01-15|coffee|-4.5")
+
+
+def test_parse_line_amount_three_decimal_places():
+    with pytest.raises(ValueError, match="bad amount"):
+        parse_line("2026-01-15|coffee|-4.500")
+
+
+def test_parse_line_amount_letters():
+    with pytest.raises(ValueError, match="bad amount"):
+        parse_line("2026-01-15|coffee|abc")
+
+
+def test_parse_line_amount_empty():
+    with pytest.raises(ValueError, match="bad amount"):
+        parse_line("2026-01-15|coffee|")
+
+
+def test_parse_line_amount_double_minus():
+    with pytest.raises(ValueError, match="bad amount"):
+        parse_line("2026-01-15|coffee|--4.50")
+
+
+# --- Validate() propagation ---
+
+def test_parse_line_bad_date_propagates():
+    with pytest.raises(ValueError, match="bad date"):
+        parse_line("01-15-2026|coffee|-4.50")
+
+
+def test_parse_line_empty_description_propagates():
+    with pytest.raises(ValueError, match="empty description"):
+        parse_line("2026-01-15||-4.50")
