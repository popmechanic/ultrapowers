+from typing import List
+from ledger.model import Entry
+from ledger.balance import running_balance
+
+
+def format_cents(cents: int) -> str:
+    """Format an integer number of cents as a dollar string.
+
+    Examples:
+        format_cents(1000) -> "$10.00"
+        format_cents(-450) -> "-$4.50"
+        format_cents(0)    -> "$0.00"
+    """
+    if cents < 0:
+        return f"-${-cents / 100:.2f}"
+    return f"${cents / 100:.2f}"
+
+
+def format_report(entries: List[Entry]) -> str:
+    """Format a list of entries as a multi-line report string.
+
+    Each entry produces one line: "{date} {description} {formatted_amount}".
+    A final line "TOTAL {formatted_total}" is appended, where the total is
+    the last value of running_balance (or 0 for an empty list).
+    Lines are joined with "\\n"; there is no trailing newline.
+    """
+    balances = running_balance(entries)
+    total = balances[-1] if balances else 0
+
+    lines = [
+        f"{entry.date} {entry.description} {format_cents(entry.amount_cents)}"
+        for entry in entries
+    ]
+    lines.append(f"TOTAL {format_cents(total)}")
+
+    return "\n".join(lines)
