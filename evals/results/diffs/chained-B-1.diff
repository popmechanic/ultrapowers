+import pytest
+from ledger.parse import parse_line
+from ledger.balance import running_balance
+
+
+def make_entry(amount_str: str):
+    """Helper: build an Entry via parse_line with a fixed date and description."""
+    return parse_line(f"2024-01-01|test|{amount_str}")
+
+
+def test_empty_list_returns_empty():
+    assert running_balance([]) == []
+
+
+def test_single_entry():
+    entries = [make_entry("10.00")]
+    assert running_balance(entries) == [1000]
+
+
+def test_example_from_spec():
+    # amounts [1000, -450, 200] → [1000, 550, 750]
+    entries = [make_entry("10.00"), make_entry("-4.50"), make_entry("2.00")]
+    assert running_balance(entries) == [1000, 550, 750]
+
+
+def test_all_positive():
+    entries = [make_entry("1.00"), make_entry("2.00"), make_entry("3.00")]
+    assert running_balance(entries) == [100, 300, 600]
+
+
+def test_all_negative():
+    entries = [make_entry("-1.00"), make_entry("-2.00"), make_entry("-3.00")]
+    assert running_balance(entries) == [-100, -300, -600]
+
+
+def test_balance_crosses_zero():
+    entries = [make_entry("5.00"), make_entry("-10.00"), make_entry("7.00")]
+    assert running_balance(entries) == [500, -500, 200]
+
+
+def test_result_length_matches_input():
+    entries = [make_entry("1.00")] * 5
+    result = running_balance(entries)
+    assert len(result) == 5
+
+
+def test_original_list_not_mutated():
+    entries = [make_entry("10.00"), make_entry("-4.50")]
+    original_amounts = [e.amount_cents for e in entries]
+    running_balance(entries)
+    assert [e.amount_cents for e in entries] == original_amounts
