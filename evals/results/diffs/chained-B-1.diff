@@ -0,0 +1,29 @@
+import re
+from ledger.model import Entry
+
+_AMOUNT_RE = re.compile(r'^-?\d+\.\d{2}$')
+
+
+def parse_line(line: str) -> Entry:
+    """Parse a ledger line in DATE|DESCRIPTION|AMOUNT format.
+
+    Raises:
+        ValueError("bad line")   – if the line does not have exactly 3 pipe-separated fields.
+        ValueError("bad amount") – if AMOUNT does not match -?\\d+\\.\\d{2}.
+        ValueError              – propagated from Entry.validate() for bad date or empty description.
+    """
+    fields = line.split("|")
+    if len(fields) != 3:
+        raise ValueError("bad line")
+
+    date, description, amount_str = fields
+
+    if not _AMOUNT_RE.match(amount_str):
+        raise ValueError("bad amount")
+
+    # Convert dollars to cents; multiply by 100 and round to avoid float imprecision
+    amount_cents = round(float(amount_str) * 100)
+
+    entry = Entry(date=date, description=description, amount_cents=amount_cents)
+    entry.validate()
+    return entry
