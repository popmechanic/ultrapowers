+import pytest
+from ledger.cli import main
+
+
+def test_main_returns_0_and_prints_report(tmp_path, capsys):
+    ledger_file = tmp_path / "ledger.txt"
+    ledger_file.write_text(
+        "2024-01-01|Groceries|50.00\n"
+        "2024-01-02|Rent|1200.00\n"
+    )
+    result = main([str(ledger_file)])
+    assert result == 0
+    captured = capsys.readouterr()
+    assert "2024-01-01 Groceries $50.00" in captured.out
+    assert "2024-01-02 Rent $1200.00" in captured.out
+    assert "TOTAL" in captured.out
+    assert captured.err == ""
+
+
+def test_main_skips_blank_lines(tmp_path, capsys):
+    ledger_file = tmp_path / "ledger.txt"
+    ledger_file.write_text(
+        "2024-01-01|Groceries|50.00\n"
+        "\n"
+        "   \n"
+        "2024-01-02|Rent|1200.00\n"
+    )
+    result = main([str(ledger_file)])
+    assert result == 0
+    captured = capsys.readouterr()
+    assert "2024-01-01 Groceries $50.00" in captured.out
+    assert "2024-01-02 Rent $1200.00" in captured.out
+    assert captured.err == ""
+
+
+def test_main_empty_file(tmp_path, capsys):
+    ledger_file = tmp_path / "ledger.txt"
+    ledger_file.write_text("")
+    result = main([str(ledger_file)])
+    assert result == 0
+    captured = capsys.readouterr()
+    assert "TOTAL $0.00" in captured.out
+    assert captured.err == ""
+
+
+def test_main_bad_amount_returns_1_and_prints_to_stderr(tmp_path, capsys):
+    ledger_file = tmp_path / "ledger.txt"
+    ledger_file.write_text("2024-01-01|Groceries|bad\n")
+    result = main([str(ledger_file)])
+    assert result == 1
+    captured = capsys.readouterr()
+    assert captured.out == ""
+    assert captured.err.startswith("error: ")
+
+
+def test_main_bad_line_returns_1_and_prints_to_stderr(tmp_path, capsys):
+    ledger_file = tmp_path / "ledger.txt"
+    ledger_file.write_text("not a valid line\n")
+    result = main([str(ledger_file)])
+    assert result == 1
+    captured = capsys.readouterr()
+    assert captured.out == ""
+    assert captured.err.startswith("error: ")
+
+
+def test_main_bad_date_returns_1_and_prints_to_stderr(tmp_path, capsys):
+    ledger_file = tmp_path / "ledger.txt"
+    ledger_file.write_text("not-a-date|Groceries|50.00\n")
+    result = main([str(ledger_file)])
+    assert result == 1
+    captured = capsys.readouterr()
+    assert captured.out == ""
+    assert captured.err.startswith("error: ")
+
+
+def test_main_empty_description_returns_1_and_prints_to_stderr(tmp_path, capsys):
+    ledger_file = tmp_path / "ledger.txt"
+    ledger_file.write_text("2024-01-01|   |50.00\n")
+    result = main([str(ledger_file)])
+    assert result == 1
+    captured = capsys.readouterr()
+    assert captured.out == ""
+    assert captured.err.startswith("error: ")
+
+
+def test_main_error_message_format(tmp_path, capsys):
+    ledger_file = tmp_path / "ledger.txt"
+    ledger_file.write_text("bad line\n")
+    result = main([str(ledger_file)])
+    assert result == 1
+    captured = capsys.readouterr()
+    assert captured.err == "error: bad line\n"
+
+
+def test_main_report_output_ends_with_newline(tmp_path, capsys):
+    ledger_file = tmp_path / "ledger.txt"
+    ledger_file.write_text("2024-01-01|Coffee|3.50\n")
+    result = main([str(ledger_file)])
+    assert result == 0
+    captured = capsys.readouterr()
+    assert captured.out.endswith("\n")
+
+
+def test_main_only_blank_lines(tmp_path, capsys):
+    ledger_file = tmp_path / "ledger.txt"
+    ledger_file.write_text("\n\n   \n\t\n")
+    result = main([str(ledger_file)])
+    assert result == 0
+    captured = capsys.readouterr()
+    assert "TOTAL $0.00" in captured.out
+    assert captured.err == ""
