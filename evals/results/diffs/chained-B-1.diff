+import pytest
+from ledger.model import Entry
+
+
+def test_validate_valid_entry():
+    e = Entry(date="2026-01-15", description="coffee", amount_cents=-450)
+    assert e.validate() is None
+
+
+def test_validate_empty_description():
+    e = Entry(date="2026-01-15", description="", amount_cents=100)
+    with pytest.raises(ValueError, match="empty description"):
+        e.validate()
+
+
+def test_validate_whitespace_only_description():
+    e = Entry(date="2026-01-15", description="   ", amount_cents=100)
+    with pytest.raises(ValueError, match="empty description"):
+        e.validate()
+
+
+def test_validate_bad_date_missing():
+    e = Entry(date="", description="coffee", amount_cents=100)
+    with pytest.raises(ValueError, match="bad date"):
+        e.validate()
+
+
+def test_validate_bad_date_wrong_format():
+    e = Entry(date="01-15-2026", description="coffee", amount_cents=100)
+    with pytest.raises(ValueError, match="bad date"):
+        e.validate()
+
+
+def test_validate_bad_date_partial():
+    e = Entry(date="2026-1-5", description="coffee", amount_cents=100)
+    with pytest.raises(ValueError, match="bad date"):
+        e.validate()
+
+
+def test_validate_bad_date_extra_chars():
+    e = Entry(date="X2026-01-15", description="coffee", amount_cents=100)
+    with pytest.raises(ValueError, match="bad date"):
+        e.validate()
