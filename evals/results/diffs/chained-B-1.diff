+from typing import List
+from ledger.model import Entry
+
+
+def running_balance(entries: List[Entry]) -> List[int]:
+    """Return cumulative sums of amount_cents for the given entries.
+
+    Args:
+        entries: A list of Entry objects.
+
+    Returns:
+        A list of the same length where each element is the sum of
+        amount_cents from the first entry up to and including that entry.
+        Returns an empty list for an empty input.
+    """
+    result: List[int] = []
+    total = 0
+    for entry in entries:
+        total += entry.amount_cents
+        result.append(total)
+    return result
