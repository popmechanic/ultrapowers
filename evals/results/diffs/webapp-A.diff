+import { test } from 'node:test';
+import assert from 'node:assert/strict';
+import { validateLink } from '../src/validate.js';
+
+test('valid http input passes with trimmed fields', () => {
+  const result = validateLink({ url: '  http://example.com  ', title: '  Example  ' });
+  assert.deepEqual(result, {
+    ok: true,
+    value: { url: 'http://example.com', title: 'Example' },
+  });
+});
+
+test('valid https input passes with trimmed fields', () => {
+  const result = validateLink({ url: '  https://example.com/page  ', title: '  Example Page  ' });
+  assert.deepEqual(result, {
+    ok: true,
+    value: { url: 'https://example.com/page', title: 'Example Page' },
+  });
+});
+
+test('rejects non-object input: null', () => {
+  const result = validateLink(null);
+  assert.equal(result.ok, false);
+  assert.equal(typeof result.error, 'string');
+  assert.notEqual(result.error.length, 0);
+});
+
+test('rejects non-object input: array', () => {
+  const result = validateLink([]);
+  assert.equal(result.ok, false);
+  assert.equal(typeof result.error, 'string');
+  assert.notEqual(result.error.length, 0);
+});
+
+test('rejects non-object input: string', () => {
+  const result = validateLink('not a url');
+  assert.equal(result.ok, false);
+  assert.equal(typeof result.error, 'string');
+  assert.notEqual(result.error.length, 0);
+});
+
+test('rejects non-object input: number', () => {
+  const result = validateLink(42);
+  assert.equal(result.ok, false);
+  assert.equal(typeof result.error, 'string');
+  assert.notEqual(result.error.length, 0);
+});
+
+test('rejects non-object input: undefined', () => {
+  const result = validateLink(undefined);
+  assert.equal(result.ok, false);
+  assert.equal(typeof result.error, 'string');
+  assert.notEqual(result.error.length, 0);
+});
+
+test('rejects missing url', () => {
+  const result = validateLink({ title: 'Example' });
+  assert.equal(result.ok, false);
+  assert.equal(typeof result.error, 'string');
+  assert.notEqual(result.error.length, 0);
+});
+
+test('rejects non-string url', () => {
+  const result = validateLink({ url: 123, title: 'Example' });
+  assert.equal(result.ok, false);
+  assert.equal(typeof result.error, 'string');
+  assert.notEqual(result.error.length, 0);
+});
+
+test('rejects empty url', () => {
+  const result = validateLink({ url: '   ', title: 'Example' });
+  assert.equal(result.ok, false);
+  assert.equal(typeof result.error, 'string');
+  assert.notEqual(result.error.length, 0);
+});
+
+test('rejects missing title', () => {
+  const result = validateLink({ url: 'https://example.com' });
+  assert.equal(result.ok, false);
+  assert.equal(typeof result.error, 'string');
+  assert.notEqual(result.error.length, 0);
+});
+
+test('rejects non-string title', () => {
+  const result = validateLink({ url: 'https://example.com', title: true });
+  assert.equal(result.ok, false);
+  assert.equal(typeof result.error, 'string');
+  assert.notEqual(result.error.length, 0);
+});
+
+test('rejects empty title', () => {
+  const result = validateLink({ url: 'https://example.com', title: '   ' });
+  assert.equal(result.ok, false);
+  assert.equal(typeof result.error, 'string');
+  assert.notEqual(result.error.length, 0);
+});
+
+test('rejects url not parseable by new URL()', () => {
+  const result = validateLink({ url: 'not a url', title: 'Example' });
+  assert.equal(result.ok, false);
+  assert.equal(typeof result.error, 'string');
+  assert.notEqual(result.error.length, 0);
+});
+
+test('rejects ftp scheme', () => {
+  const result = validateLink({ url: 'ftp://example.com', title: 'Example' });
+  assert.equal(result.ok, false);
+  assert.equal(typeof result.error, 'string');
+  assert.notEqual(result.error.length, 0);
+});
+
+test('rejects other non-http(s) schemes', () => {
+  const result = validateLink({ url: 'mailto:test@example.com', title: 'Example' });
+  assert.equal(result.ok, false);
+  assert.equal(typeof result.error, 'string');
+  assert.notEqual(result.error.length, 0);
+});
