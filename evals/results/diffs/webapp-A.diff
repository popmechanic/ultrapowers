+import { test } from 'node:test';
+import assert from 'node:assert/strict';
+import { createStore } from '../src/store.js';
+
+test('add() returns a link with unique id, given fields, and ISO-8601 createdAt', () => {
+  const store = createStore();
+  const link = store.add({ url: 'https://example.com', title: 'Example' });
+
+  assert.equal(typeof link.id, 'string');
+  assert.ok(link.id.length > 0);
+  assert.equal(link.url, 'https://example.com');
+  assert.equal(link.title, 'Example');
+  assert.equal(typeof link.createdAt, 'string');
+  assert.equal(new Date(link.createdAt).toISOString(), link.createdAt);
+
+  const link2 = store.add({ url: 'https://example.org', title: 'Example 2' });
+  assert.notEqual(link.id, link2.id);
+});
+
+test('list() returns links in insertion order; empty store returns []', () => {
+  const store = createStore();
+  assert.deepEqual(store.list(), []);
+
+  const a = store.add({ url: 'https://a.example', title: 'A' });
+  const b = store.add({ url: 'https://b.example', title: 'B' });
+  const c = store.add({ url: 'https://c.example', title: 'C' });
+
+  assert.deepEqual(store.list(), [a, b, c]);
+});
+
+test('get(id) returns the matching link; unknown id returns undefined', () => {
+  const store = createStore();
+  const link = store.add({ url: 'https://example.com', title: 'Example' });
+
+  assert.deepEqual(store.get(link.id), link);
+  assert.equal(store.get('nonexistent-id'), undefined);
+});
