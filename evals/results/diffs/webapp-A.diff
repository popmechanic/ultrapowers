+++ b/src/app.js
@@ -0,0 +1,51 @@
+import http from 'node:http';
+
+function sendJson(res, status, payload) {
+  const body = JSON.stringify(payload);
+  res.writeHead(status, { 'content-type': 'application/json' });
+  res.end(body);
+}
+
+/**
+ * Create an http.Server that routes exact-match "METHOD /path" keys to
+ * handlers of the shape (req, res, body) => void.
+ *
+ * The request body is read and, when present, parsed as JSON before the
+ * handler is invoked. Invalid JSON yields a 400 response. Unmatched routes
+ * yield a 404 response.
+ *
+ * @param {Record<string, (req, res, body) => void>} handlers
+ * @returns {http.Server}
+ */
+export function createApp(handlers) {
+  return http.createServer((req, res) => {
+    const chunks = [];
+    req.on('data', (chunk) => chunks.push(chunk));
+    req.on('end', () => {
+      const raw = Buffer.concat(chunks).toString('utf8');
+      let body;
+      if (raw.length > 0) {
+        try {
+          body = JSON.parse(raw);
+        } catch {
+          sendJson(res, 400, { error: 'invalid json' });
+          return;
+        }
+      }
+
+      const path = (req.url || '/').split('?')[0];
+      const key = `${req.method} ${path}`;
+      const handler = handlers[key];
+
+      if (!handler) {
+        sendJson(res, 404, { error: 'not found' });
+        return;
+      }
+
+      handler(req, res, body);
+    });
+    req.on('error', () => {
+      sendJson(res, 400, { error: 'invalid json' });
+    });
+  });
+}
