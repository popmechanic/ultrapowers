@@ -0,0 +1,35 @@
+function isValidScheme(url) {
+  return url.protocol === 'http:' || url.protocol === 'https:';
+}
+
+export function validateLink(input) {
+  if (typeof input !== 'object' || input === null || Array.isArray(input)) {
+    return { ok: false, error: 'input must be an object' };
+  }
+
+  const { url, title } = input;
+
+  if (typeof url !== 'string' || url.trim() === '') {
+    return { ok: false, error: 'url must be a non-empty string' };
+  }
+
+  if (typeof title !== 'string' || title.trim() === '') {
+    return { ok: false, error: 'title must be a non-empty string' };
+  }
+
+  const trimmedUrl = url.trim();
+  const trimmedTitle = title.trim();
+
+  let parsedUrl;
+  try {
+    parsedUrl = new URL(trimmedUrl);
+  } catch {
+    return { ok: false, error: 'url must be a valid URL' };
+  }
+
+  if (!isValidScheme(parsedUrl)) {
+    return { ok: false, error: 'url must use http or https' };
+  }
+
+  return { ok: true, value: { url: trimmedUrl, title: trimmedTitle } };
+}
diff --git a/tests/api.test.js b/tests/api.test.js
new file mode 100644
index 0000000..1898e4a
--- /dev/null
+++ b/tests/api.test.js
@@ -0,0 +1,89 @@
+import { test } from 'node:test';
+import assert from 'node:assert/strict';
+import http from 'node:http';
+import { createServer } from '../src/api.js';
+
+function request(server, { method = 'GET', path = '/', body } = {}) {
+  return new Promise((resolve, reject) => {
+    const { port } = server.address();
+    const payload = body === undefined ? undefined : (typeof body === 'string' ? body : JSON.stringify(body));
+    const req = http.request(
+      { host: '127.0.0.1', port, method, path, headers: payload ? { 'content-type': 'application/json' } : {} },
+      (res) => {
+        let data = '';
+        res.on('data', (chunk) => { data += chunk; });
+        res.on('end', () => {
+          resolve({ status: res.statusCode, headers: res.headers, body: data });
+        });
+      }
+    );
+    req.on('error', reject);
+    if (payload) req.write(payload);
+    req.end();
+  });
+}
+
+async function startServer(t) {
+  const server = createServer();
+  server.listen(0);
+  t.after(() => server.close());
+  await new Promise((resolve) => server.once('listening', resolve));
+  return server;
+}
+
+test('GET /links on a fresh server returns 200 and an empty JSON array', async (t) => {
+  const server = await startServer(t);
+
+  const res = await request(server, { method: 'GET', path: '/links' });
+  assert.equal(res.status, 200);
+  assert.deepEqual(JSON.parse(res.body), []);
+});
+
+test('POST /links with valid input returns 201 with the created link, and it appears in a following GET', async (t) => {
+  const server = await startServer(t);
+
+  const createRes = await request(server, {
+    method: 'POST',
+    path: '/links',
+    body: { url: 'https://example.com', title: 'Example' },
+  });
+  assert.equal(createRes.status, 201);
+  const created = JSON.parse(createRes.body);
+  assert.equal(created.url, 'https://example.com');
+  assert.equal(created.title, 'Example');
+  assert.ok(created.id);
+  assert.ok(created.createdAt);
+
+  const listRes = await request(server, { method: 'GET', path: '/links' });
+  assert.equal(listRes.status, 200);
+  const links = JSON.parse(listRes.body);
+  assert.equal(links.length, 1);
+  assert.deepEqual(links[0], created);
+});
+
+test('POST /links with invalid input returns 422 with an error string', async (t) => {
+  const server = await startServer(t);
+
+  const res = await request(server, {
+    method: 'POST',
+    path: '/links',
+    body: { url: 'ftp://x', title: '' },
+  });
+  assert.equal(res.status, 422);
+  const parsed = JSON.parse(res.body);
+  assert.equal(typeof parsed.error, 'string');
+  assert.ok(parsed.error.length > 0);
+
+  const listRes = await request(server, { method: 'GET', path: '/links' });
+  assert.deepEqual(JSON.parse(listRes.body), []);
+});
+
+test('GET / returns 200, text/html, and the board UI page', async (t) => {
+  const server = await startServer(t);
+
+  const res = await request(server, { method: 'GET', path: '/' });
+  assert.equal(res.status, 200);
+  assert.ok(res.headers['content-type'].includes('text/html'));
+  assert.ok(res.body.includes('<!doctype html>'));
+  assert.ok(res.body.includes('linkboard'));
+});
