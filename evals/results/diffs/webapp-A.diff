@@ -0,0 +1,28 @@
+import { randomUUID } from 'node:crypto';
+
+export function createStore() {
+  const links = [];
+  const byId = new Map();
+
+  function add({ url, title }) {
+    const link = {
+      id: randomUUID(),
+      url,
+      title,
+      createdAt: new Date().toISOString(),
+    };
+    links.push(link);
+    byId.set(link.id, link);
+    return link;
+  }
+
+  function list() {
+    return links.slice();
+  }
+
+  function get(id) {
+    return byId.get(id);
+  }
+
+  return { add, list, get };
+}
