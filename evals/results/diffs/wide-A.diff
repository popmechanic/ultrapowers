new file mode 100644
index 0000000..38b713f
--- /dev/null
+++ b/textkit/ngrams.py
@@ -0,0 +1,8 @@
+def ngrams(tokens, n):
+    """Return a list of tuples of n consecutive tokens.
+
+    Raises ValueError if n < 1. Returns [] when n > len(tokens).
+    """
+    if n < 1:
+        raise ValueError("n must be >= 1")
+    return [tuple(tokens[i:i + n]) for i in range(len(tokens) - n + 1)]
diff --git a/textkit/redact.py b/textkit/redact.py
new file mode 100644
index 0000000..a3aeeda
--- /dev/null
+++ b/textkit/redact.py
@@ -0,0 +1,12 @@
+import re
+
+
+def redact(text, words):
+    """Replace each whole-word, case-insensitive occurrence of any word in
+    `words` with "*" repeated to the match's length."""
+    words = list(words)
+    if not words:
+        return text
+
+    pattern = r"\b(?:" + "|".join(re.escape(word) for word in words) + r")\b"
+    return re.sub(pattern, lambda m: "*" * len(m.group(0)), text, flags=re.IGNORECASE)
diff --git a/textkit/reverse_words.py b/textkit/reverse_words.py
new file mode 100644
index 0000000..60969cc
--- /dev/null
+++ b/textkit/reverse_words.py
@@ -0,0 +1,6 @@
+def reverse_words(text):
+    """Split on whitespace, reverse word order, join with single spaces.
+
+    Empty or whitespace-only input returns "".
+    """
+    return " ".join(reversed(text.split()))
diff --git a/textkit/titlecase.py b/textkit/titlecase.py
new file mode 100644
index 0000000..ba11988
--- /dev/null
+++ b/textkit/titlecase.py
@@ -0,0 +1,18 @@
+MINOR_WORDS = {"a", "an", "and", "as", "at", "but", "by", "for", "in", "of", "on", "or", "the", "to"}
+
+
+def titlecase(text):
+    """Title-case text, lowercasing minor words except at the start or end."""
+    words = text.split()
+    if not words:
+        return ""
+
+    last_index = len(words) - 1
+    result = []
+    for index, word in enumerate(words):
+        lowered = word.lower()
+        if index in (0, last_index) or lowered not in MINOR_WORDS:
+            result.append(lowered[:1].upper() + lowered[1:])
+        else:
+            result.append(lowered)
+    return " ".join(result)
diff --git a/textkit/truncate.py b/textkit/truncate.py
new file mode 100644
index 0000000..3867cc9
--- /dev/null
+++ b/textkit/truncate.py
@@ -0,0 +1,7 @@
+def truncate(text, limit, ellipsis="..."):
+    """Truncate ``text`` to ``limit`` characters, appending ``ellipsis`` if cut short."""
+    if limit < len(ellipsis):
+        raise ValueError("limit must be at least as long as the ellipsis")
+    if len(text) <= limit:
+        return text
+    return text[: limit - len(ellipsis)].rstrip() + ellipsis
diff --git a/textkit/word_count.py b/textkit/word_count.py
new file mode 100644
index 0000000..2163dd5
--- /dev/null
+++ b/textkit/word_count.py
@@ -0,0 +1,13 @@
+import re
+
+
+def word_count(text):
+    """Return a dict mapping each word to its count.
+
+    Words are maximal runs matching [a-z0-9]+ after lowercasing the input,
+    so "Don't" yields "don" and "t" as separate words.
+    """
+    counts = {}
+    for word in re.findall(r"[a-z0-9]+", text.lower()):
+        counts[word] = counts.get(word, 0) + 1
+    return counts
