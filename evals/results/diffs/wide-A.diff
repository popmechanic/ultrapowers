+import pytest
+
+from textkit.truncate import truncate
+
+
+def test_returns_unchanged_when_within_limit():
+    assert truncate("hello", 10) == "hello"
+
+
+def test_returns_unchanged_when_exactly_at_limit():
+    assert truncate("hello", 5) == "hello"
+
+
+def test_truncates_and_appends_default_ellipsis():
+    assert truncate("hello brave world", 10) == "hello b..."
+
+
+def test_truncates_with_custom_ellipsis():
+    assert truncate("hello brave world", 10, ellipsis=">>") == "hello br>>"
+
+
+def test_rstrips_trailing_whitespace_before_ellipsis():
+    assert truncate("hello      world", 8) == "hello..."
+
+
+def test_raises_value_error_when_limit_less_than_ellipsis_length():
+    with pytest.raises(ValueError):
+        truncate("hello world", 2)
+
+
+def test_limit_equal_to_ellipsis_length_is_allowed():
+    assert truncate("hello world", 3) == "..."
