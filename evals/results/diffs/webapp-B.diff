+import { test } from 'node:test';
+import assert from 'node:assert/strict';
+import { createServer } from '../src/api.js';
+
+function listen(server) {
+  return new Promise((resolve) => {
+    server.listen(0, () => resolve(server.address().port));
+  });
+}
+
+function close(server) {
+  return new Promise((resolve) => server.close(resolve));
+}
+
+test('GET /links on a fresh server returns 200 and []', async () => {
+  const server = createServer();
+  const port = await listen(server);
+  try {
+    const res = await fetch(`http://127.0.0.1:${port}/links`);
+    assert.equal(res.status, 200);
+    assert.equal(res.headers.get('content-type'), 'application/json');
+    const body = await res.json();
+    assert.deepEqual(body, []);
+  } finally {
+    await close(server);
+  }
+});
+
+test('POST /links with valid input returns 201 with created link, then appears in GET /links', async () => {
+  const server = createServer();
+  const port = await listen(server);
+  try {
+    const res = await fetch(`http://127.0.0.1:${port}/links`, {
+      method: 'POST',
+      headers: { 'content-type': 'application/json' },
+      body: JSON.stringify({ url: 'https://example.com', title: 'Example' }),
+    });
+    assert.equal(res.status, 201);
+    const created = await res.json();
+    assert.equal(created.url, 'https://example.com');
+    assert.equal(created.title, 'Example');
+    assert.equal(typeof created.id, 'string');
+    assert.equal(typeof created.createdAt, 'string');
+
+    const listRes = await fetch(`http://127.0.0.1:${port}/links`);
+    assert.equal(listRes.status, 200);
+    const list = await listRes.json();
+    assert.deepEqual(list, [created]);
+  } finally {
+    await close(server);
+  }
+});
+
+test('POST /links with invalid input returns 422 with an error string', async () => {
+  const server = createServer();
+  const port = await listen(server);
+  try {
+    const res = await fetch(`http://127.0.0.1:${port}/links`, {
+      method: 'POST',
+      headers: { 'content-type': 'application/json' },
+      body: JSON.stringify({ url: 'ftp://x', title: '' }),
+    });
+    assert.equal(res.status, 422);
+    const body = await res.json();
+    assert.equal(typeof body.error, 'string');
+    assert.ok(body.error.length > 0);
+
+    const listRes = await fetch(`http://127.0.0.1:${port}/links`);
+    const list = await listRes.json();
+    assert.deepEqual(list, []);
+  } finally {
+    await close(server);
+  }
+});
+
+test('GET / returns 200, text/html, and the rendered board page', async () => {
+  const server = createServer();
+  const port = await listen(server);
+  try {
+    const res = await fetch(`http://127.0.0.1:${port}/`);
+    assert.equal(res.status, 200);
+    assert.match(res.headers.get('content-type'), /text\/html/);
+    const html = await res.text();
+    assert.match(html, /<!doctype html>/i);
+    assert.match(html, /Linkboard/);
+  } finally {
+    await close(server);
+  }
+});
