@@ -0,0 +1,41 @@
+import { createApp } from './app.js';
+import { createStore } from './store.js';
+import { validateLink } from './validate.js';
+import { renderPage } from './page.js';
+
+function sendJson(res, status, payload) {
+  res.writeHead(status, { 'content-type': 'application/json' });
+  res.end(JSON.stringify(payload));
+}
+
+/**
+ * Creates an http.Server wiring the link store, request routing, and
+ * validation together into the linkboard REST API and board UI.
+ *
+ * @returns {import('node:http').Server}
+ */
+export function createServer() {
+  const store = createStore();
+
+  return createApp({
+    'GET /links': (req, res) => {
+      sendJson(res, 200, store.list());
+    },
+
+    'POST /links': (req, res, body) => {
+      const result = validateLink(body);
+      if (!result.ok) {
+        sendJson(res, 422, { error: result.error });
+        return;
+      }
+      const link = store.add(result.value);
+      sendJson(res, 201, link);
+    },
+
+    'GET /': (req, res) => {
+      const html = renderPage();
+      res.writeHead(200, { 'content-type': 'text/html' });
+      res.end(html);
+    },
+  });
+}
