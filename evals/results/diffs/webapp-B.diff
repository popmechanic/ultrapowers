+import test from 'node:test';
+import assert from 'node:assert/strict';
+import { validateLink } from '../src/validate.js';
+
+test('validateLink: valid http URL with trimmed fields', () => {
+  const result = validateLink({
+    url: '  https://example.com  ',
+    title: '  Example Title  '
+  });
+
+  assert.deepEqual(result, {
+    ok: true,
+    value: {
+      url: 'https://example.com',
+      title: 'Example Title'
+    }
+  });
+});
+
+test('validateLink: valid https URL', () => {
+  const result = validateLink({
+    url: 'https://example.com',
+    title: 'Example'
+  });
+
+  assert.equal(result.ok, true);
+  assert.equal(result.value.url, 'https://example.com');
+  assert.equal(result.value.title, 'Example');
+});
+
+test('validateLink: rejects non-object input', () => {
+  assert.equal(validateLink('string').ok, false);
+  assert.equal(typeof validateLink('string').error, 'string');
+  assert(validateLink('string').error.length > 0);
+
+  assert.equal(validateLink(null).ok, false);
+  assert.equal(typeof validateLink(null).error, 'string');
+  assert(validateLink(null).error.length > 0);
+
+  assert.equal(validateLink(123).ok, false);
+  assert.equal(typeof validateLink(123).error, 'string');
+  assert(validateLink(123).error.length > 0);
+});
+
+test('validateLink: rejects missing url', () => {
+  const result = validateLink({
+    title: 'Example'
+  });
+
+  assert.equal(result.ok, false);
+  assert.equal(typeof result.error, 'string');
+  assert(result.error.length > 0);
+});
+
+test('validateLink: rejects missing title', () => {
+  const result = validateLink({
+    url: 'https://example.com'
+  });
+
+  assert.equal(result.ok, false);
+  assert.equal(typeof result.error, 'string');
+  assert(result.error.length > 0);
+});
+
+test('validateLink: rejects non-string url', () => {
+  const result = validateLink({
+    url: 123,
+    title: 'Example'
+  });
+
+  assert.equal(result.ok, false);
+  assert.equal(typeof result.error, 'string');
+  assert(result.error.length > 0);
+});
+
+test('validateLink: rejects non-string title', () => {
+  const result = validateLink({
+    url: 'https://example.com',
+    title: 123
+  });
+
+  assert.equal(result.ok, false);
+  assert.equal(typeof result.error, 'string');
+  assert(result.error.length > 0);
+});
+
+test('validateLink: rejects empty url', () => {
+  const result = validateLink({
+    url: '',
+    title: 'Example'
+  });
+
+  assert.equal(result.ok, false);
+  assert.equal(typeof result.error, 'string');
+  assert(result.error.length > 0);
+});
+
+test('validateLink: rejects empty title', () => {
+  const result = validateLink({
+    url: 'https://example.com',
+    title: ''
+  });
+
+  assert.equal(result.ok, false);
+  assert.equal(typeof result.error, 'string');
+  assert(result.error.length > 0);
+});
+
+test('validateLink: rejects URL with non-http/https scheme', () => {
+  const result = validateLink({
+    url: 'ftp://example.com',
+    title: 'FTP Server'
+  });
+
+  assert.equal(result.ok, false);
+  assert.equal(typeof result.error, 'string');
+  assert(result.error.length > 0);
+});
+
+test('validateLink: rejects unparseable URL', () => {
+  const result = validateLink({
+    url: 'not a url',
+    title: 'Invalid URL'
+  });
+
+  assert.equal(result.ok, false);
+  assert.equal(typeof result.error, 'string');
+  assert(result.error.length > 0);
