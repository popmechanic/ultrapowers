+++ b/src/store.js
@@ -0,0 +1,26 @@
+import { randomUUID } from 'node:crypto';
+
+export function createStore() {
+  const links = [];
+
+  return {
+    add({ url, title }) {
+      const link = {
+        id: randomUUID(),
+        url,
+        title,
+        createdAt: new Date().toISOString(),
+      };
+      links.push(link);
+      return link;
+    },
+
+    list() {
+      return links;
+    },
+
+    get(id) {
+      return links.find(link => link.id === id);
+    },
+  };
+}
