+import { test } from 'node:test';
+import assert from 'node:assert';
+import { createStore } from '../src/store.js';
+
+test('createStore() - add returns a link with id, url, title, and createdAt', () => {
+  const store = createStore();
+  const link = store.add({ url: 'https://example.com', title: 'Example' });
+
+  assert.strictEqual(typeof link.id, 'string');
+  assert.strictEqual(link.url, 'https://example.com');
+  assert.strictEqual(link.title, 'Example');
+  assert.strictEqual(typeof link.createdAt, 'string');
+  // Verify ISO-8601 format by parsing
+  const date = new Date(link.createdAt);
+  assert.strictEqual(date.toISOString(), link.createdAt);
+});
+
+test('createStore() - add generates unique ids', () => {
+  const store = createStore();
+  const link1 = store.add({ url: 'https://example.com', title: 'Example 1' });
+  const link2 = store.add({ url: 'https://example.org', title: 'Example 2' });
+
+  assert.notStrictEqual(link1.id, link2.id);
+});
+
+test('createStore() - list returns empty array for new store', () => {
+  const store = createStore();
+  const links = store.list();
+
+  assert.deepStrictEqual(links, []);
+});
+
+test('createStore() - list returns links in insertion order', () => {
+  const store = createStore();
+  const link1 = store.add({ url: 'https://example.com', title: 'Example 1' });
+  const link2 = store.add({ url: 'https://example.org', title: 'Example 2' });
+  const link3 = store.add({ url: 'https://example.net', title: 'Example 3' });
+
+  const links = store.list();
+  assert.strictEqual(links.length, 3);
+  assert.strictEqual(links[0].id, link1.id);
+  assert.strictEqual(links[1].id, link2.id);
+  assert.strictEqual(links[2].id, link3.id);
+});
+
+test('createStore() - get returns the matching link', () => {
+  const store = createStore();
+  const link = store.add({ url: 'https://example.com', title: 'Example' });
+
+  const retrieved = store.get(link.id);
+  assert.deepStrictEqual(retrieved, link);
+});
+
+test('createStore() - get returns undefined for unknown id', () => {
+  const store = createStore();
+  store.add({ url: 'https://example.com', title: 'Example' });
+
+  const retrieved = store.get('nonexistent-id');
+  assert.strictEqual(retrieved, undefined);
+});
