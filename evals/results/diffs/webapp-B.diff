@@ -0,0 +1,76 @@
+export function validateLink(input) {
+  // Reject non-object input
+  if (typeof input !== 'object' || input === null) {
+    return {
+      ok: false,
+      error: 'Input must be an object'
+    };
+  }
+
+  // Extract url and title
+  const { url, title } = input;
+
+  // Check url is present and is a string
+  if (typeof url !== 'string') {
+    return {
+      ok: false,
+      error: 'url must be a string'
+    };
+  }
+
+  // Check title is present and is a string
+  if (typeof title !== 'string') {
+    return {
+      ok: false,
+      error: 'title must be a string'
+    };
+  }
+
+  // Trim whitespace
+  const trimmedUrl = url.trim();
+  const trimmedTitle = title.trim();
+
+  // Check url is not empty after trimming
+  if (trimmedUrl.length === 0) {
+    return {
+      ok: false,
+      error: 'url cannot be empty'
+    };
+  }
+
+  // Check title is not empty after trimming
+  if (trimmedTitle.length === 0) {
+    return {
+      ok: false,
+      error: 'title cannot be empty'
+    };
+  }
+
+  // Try to parse the URL
+  let parsedUrl;
+  try {
+    parsedUrl = new URL(trimmedUrl);
+  } catch (error) {
+    return {
+      ok: false,
+      error: 'url must be a valid URL'
+    };
+  }
+
+  // Check that the scheme is http or https
+  if (parsedUrl.protocol !== 'http:' && parsedUrl.protocol !== 'https:') {
+    return {
+      ok: false,
+      error: 'url scheme must be http or https'
+    };
+  }
+
+  // Return success with trimmed fields
+  return {
+    ok: true,
+    value: {
+      url: trimmedUrl,
+      title: trimmedTitle
+    }
+  };
+}
