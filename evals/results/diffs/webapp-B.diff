+import { test } from 'node:test';
+import assert from 'node:assert/strict';
+import { createServer } from '../src/api.js';
+
+function listen(server) {
+  return new Promise((resolve) => {
+    server.listen(0, () => resolve(server.address().port));
+  });
+}
+
+function close(server) {
+  return new Promise((resolve) => server.close(resolve));
+}
+
+test('end-to-end: GET / renders the board and POSTed links show up in order via GET /links', async () => {
+  const server = createServer();
+  const port = await listen(server);
+  const base = `http://127.0.0.1:${port}`;
+  try {
+    const homeRes = await fetch(`${base}/`);
+    assert.equal(homeRes.status, 200);
+    assert.match(homeRes.headers.get('content-type'), /^text\/html/);
+    const html = await homeRes.text();
+    assert.match(html, /id="links"/);
+
+    const first = await fetch(`${base}/links`, {
+      method: 'POST',
+      headers: { 'content-type': 'application/json' },
+      body: JSON.stringify({ url: 'https://example.com/first', title: 'First Link' }),
+    });
+    assert.equal(first.status, 201);
+    const firstLink = await first.json();
+
+    const second = await fetch(`${base}/links`, {
+      method: 'POST',
+      headers: { 'content-type': 'application/json' },
+      body: JSON.stringify({ url: 'https://example.com/second', title: 'Second Link' }),
+    });
+    assert.equal(second.status, 201);
+    const secondLink = await second.json();
+
+    const listRes = await fetch(`${base}/links`);
+    assert.equal(listRes.status, 200);
+    const list = await listRes.json();
+    assert.deepEqual(list, [firstLink, secondLink]);
+  } finally {
+    await close(server);
+  }
+});
