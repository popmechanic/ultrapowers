+import { test } from 'node:test';
+import assert from 'node:assert/strict';
+import { createApp } from '../src/app.js';
+
+function listen(server) {
+  return new Promise((resolve) => {
+    server.listen(0, () => resolve(server.address().port));
+  });
+}
+
+function close(server) {
+  return new Promise((resolve) => server.close(resolve));
+}
+
+test('registered GET handler is invoked and can respond 200', async () => {
+  const app = createApp({
+    'GET /ping': (req, res) => {
+      res.writeHead(200, { 'content-type': 'application/json' });
+      res.end(JSON.stringify({ ok: true }));
+    },
+  });
+  const port = await listen(app);
+  try {
+    const res = await fetch(`http://127.0.0.1:${port}/ping`);
+    assert.equal(res.status, 200);
+    const body = await res.json();
+    assert.deepEqual(body, { ok: true });
+  } finally {
+    await close(app);
+  }
+});
+
+test('unregistered path returns 404 with error body', async () => {
+  const app = createApp({});
+  const port = await listen(app);
+  try {
+    const res = await fetch(`http://127.0.0.1:${port}/nope`);
+    assert.equal(res.status, 404);
+    const body = await res.json();
+    assert.deepEqual(body, { error: 'not found' });
+  } finally {
+    await close(app);
+  }
+});
+
+test('POST with malformed JSON body returns 400 with error body', async () => {
+  const app = createApp({
+    'POST /echo': (req, res, body) => {
+      res.writeHead(200, { 'content-type': 'application/json' });
+      res.end(JSON.stringify(body));
+    },
+  });
+  const port = await listen(app);
+  try {
+    const res = await fetch(`http://127.0.0.1:${port}/echo`, {
+      method: 'POST',
+      headers: { 'content-type': 'application/json' },
+      body: '{ not valid json',
+    });
+    assert.equal(res.status, 400);
+    const body = await res.json();
+    assert.deepEqual(body, { error: 'invalid json' });
+  } finally {
+    await close(app);
+  }
+});
+
+test('POST with valid JSON body passes parsed body to handler', async () => {
+  const app = createApp({
+    'POST /echo': (req, res, body) => {
+      res.writeHead(200, { 'content-type': 'application/json' });
+      res.end(JSON.stringify(body));
+    },
+  });
+  const port = await listen(app);
+  try {
+    const res = await fetch(`http://127.0.0.1:${port}/echo`, {
+      method: 'POST',
+      headers: { 'content-type': 'application/json' },
+      body: JSON.stringify({ hello: 'world' }),
+    });
+    assert.equal(res.status, 200);
+    const body = await res.json();
+    assert.deepEqual(body, { hello: 'world' });
+  } finally {
+    await close(app);
+  }
+});
