@@ -0,0 +1,21 @@
+import pytest
+
+from textkit.ngrams import ngrams
+
+
+def test_basic_bigrams():
+    assert ngrams(["a", "b", "c"], 2) == [("a", "b"), ("b", "c")]
+
+
+def test_n_greater_than_len_returns_empty():
+    assert ngrams(["a", "b"], 3) == []
+
+
+def test_n_less_than_one_raises_value_error():
+    with pytest.raises(ValueError):
+        ngrams(["a", "b", "c"], 0)
+
+
+def test_n_negative_raises_value_error():
+    with pytest.raises(ValueError):
+        ngrams(["a", "b", "c"], -1)
