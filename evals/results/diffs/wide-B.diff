@@ -0,0 +1,3 @@
+def reverse_words(text):
+    """Split on whitespace, reverse the word order, join with single spaces."""
+    return " ".join(reversed(text.split()))
diff --git a/textkit/titlecase.py b/textkit/titlecase.py
new file mode 100644
index 0000000..982bf7b
--- /dev/null
+++ b/textkit/titlecase.py
@@ -0,0 +1,19 @@
+MINOR_WORDS = {"a", "an", "and", "as", "at", "but", "by", "for", "in", "of", "on", "or", "the", "to"}
+
+
+def titlecase(text):
+    """Title-case text, lowercasing minor words except first/last word."""
+    words = text.split()
+    if not words:
+        return ""
+
+    last_index = len(words) - 1
+    result = []
+    for index, word in enumerate(words):
+        lower = word.lower()
+        if index in (0, last_index) or lower not in MINOR_WORDS:
+            result.append(lower[:1].upper() + lower[1:])
+        else:
+            result.append(lower)
+
+    return " ".join(result)
diff --git a/textkit/truncate.py b/textkit/truncate.py
new file mode 100644
index 0000000..ac05880
--- /dev/null
+++ b/textkit/truncate.py
@@ -0,0 +1,16 @@
+def truncate(text, limit, ellipsis="..."):
+    """Truncate text to at most limit characters, appending ellipsis if cut short.
+
+    If text already fits within limit, it is returned unchanged. Otherwise the
+    text is cut so that the result (including the ellipsis) fits within limit,
+    trailing whitespace before the ellipsis is stripped.
+
+    Raises ValueError if limit is smaller than the length of the ellipsis.
+    """
+    if limit < len(ellipsis):
+        raise ValueError("limit must be at least as long as the ellipsis")
+
+    if len(text) <= limit:
+        return text
+
+    return text[: limit - len(ellipsis)].rstrip() + ellipsis
diff --git a/textkit/word_count.py b/textkit/word_count.py
new file mode 100644
index 0000000..5d9eac6
--- /dev/null
+++ b/textkit/word_count.py
@@ -0,0 +1,12 @@
+import re
+
+
+def word_count(text):
+    """Return a dict mapping each word to its count.
+
+    Words are maximal runs matching [a-z0-9]+ after lowercasing the input.
+    """
+    counts = {}
+    for word in re.findall(r"[a-z0-9]+", text.lower()):
+        counts[word] = counts.get(word, 0) + 1
+    return counts
