new file mode 100644
index 0000000..570f399
--- /dev/null
+++ b/textkit/ngrams.py
@@ -0,0 +1,8 @@
+def ngrams(tokens, n):
+    """Return a list of tuples of n consecutive tokens.
+
+    Raises ValueError when n < 1. Returns [] when n > len(tokens).
+    """
+    if n < 1:
+        raise ValueError("n must be >= 1")
+    return [tuple(tokens[i : i + n]) for i in range(len(tokens) - n + 1)]
diff --git a/textkit/redact.py b/textkit/redact.py
new file mode 100644
index 0000000..c2a7ee4
--- /dev/null
+++ b/textkit/redact.py
@@ -0,0 +1,16 @@
+import re
+
+
+def redact(text, words):
+    """Replace each whole-word, case-insensitive occurrence of any word in
+    `words` with "*" repeated to the match's length."""
+    words = list(words)
+    if not words:
+        return text
+
+    pattern = r"\b(?:" + "|".join(re.escape(word) for word in words) + r")\b"
+
+    def _replace(match):
+        return "*" * len(match.group(0))
+
+    return re.sub(pattern, _replace, text, flags=re.IGNORECASE)
