+from textkit.titlecase import titlecase
+
+
+def test_basic_example():
+    assert titlecase("the lord of the rings") == "The Lord of the Rings"
+
+
+def test_minor_words_lowercased_in_middle():
+    assert titlecase("a tale of two cities") == "A Tale of Two Cities"
+
+
+def test_first_and_last_word_always_capitalized_even_if_minor():
+    assert titlecase("of mice and men") == "Of Mice and Men"
+    assert titlecase("the cat sat on the") == "The Cat Sat on The"
+
+
+def test_collapses_whitespace():
+    assert titlecase("the   lord   of the rings") == "The Lord of the Rings"
+    assert titlecase("  the lord of the rings  ") == "The Lord of the Rings"
+
+
+def test_normalizes_case_of_input():
+    assert titlecase("THE LORD OF THE RINGS") == "The Lord of the Rings"
+
+
+def test_single_word():
+    assert titlecase("the") == "The"
+    assert titlecase("hello") == "Hello"
+
+
+def test_empty_or_whitespace_only_returns_empty_string():
+    assert titlecase("") == ""
