+"""Tests for apistub.validate.validate_payload."""
+import pytest
+from apistub.validate import validate_payload
+
+
+def test_valid_payload_returns_empty_list():
+    assert validate_payload({"name": "Alice", "email": "alice@example.com"}) == []
+
+
+def test_missing_name():
+    errors = validate_payload({"email": "alice@example.com"})
+    assert "missing: name" in errors
+
+
+def test_missing_email():
+    errors = validate_payload({"name": "Alice"})
+    assert "missing: email" in errors
+
+
+def test_missing_both_fields():
+    errors = validate_payload({})
+    assert errors == ["missing: name", "missing: email"]
+
+
+def test_wrong_type_name():
+    errors = validate_payload({"name": 123, "email": "alice@example.com"})
+    assert "wrong type: name" in errors
+
+
+def test_wrong_type_email():
+    errors = validate_payload({"name": "Alice", "email": 456})
+    assert "wrong type: email" in errors
+
+
+def test_field_errors_in_fields_order():
+    """Errors should appear in FIELDS order: name then email."""
+    errors = validate_payload({})
+    assert errors.index("missing: name") < errors.index("missing: email")
+
+
+def test_email_missing_at_symbol():
+    errors = validate_payload({"name": "Alice", "email": "aliceexample.com"})
+    assert "invalid: email" in errors
+
+
+def test_email_with_at_symbol_is_valid():
+    errors = validate_payload({"name": "Alice", "email": "a@b"})
+    assert "invalid: email" not in errors
+
+
+def test_email_invalid_only_appended_after_field_loop():
+    """invalid: email should come after field-level errors."""
+    errors = validate_payload({"name": 123, "email": "noemail"})
+    # wrong type: email would be set for wrong type, but here email is str
+    # so "invalid: email" should appear
+    assert "wrong type: name" in errors
+    assert "invalid: email" in errors
+    # "invalid: email" must appear after "wrong type: name"
+    assert errors.index("wrong type: name") < errors.index("invalid: email")
+
+
+def test_unknown_keys_ignored():
+    errors = validate_payload({"name": "Alice", "email": "alice@example.com", "extra": "ignored"})
+    assert errors == []
+
+
+def test_email_wrong_type_does_not_trigger_invalid_email():
+    """If email is present but not a str, invalid: email should NOT be appended."""
+    errors = validate_payload({"name": "Alice", "email": 123})
+    assert "wrong type: email" in errors
+    assert "invalid: email" not in errors
+
+
+def test_empty_string_email_without_at():
+    errors = validate_payload({"name": "Alice", "email": ""})
+    assert "invalid: email" in errors
