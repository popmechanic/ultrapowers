+"""Tests for the in-memory store."""
+
+from apistub.schema import User
+from apistub.store import MemoryStore
+
+
+def test_add_creates_user_with_auto_increment_id():
+    """add() creates and returns a User with auto-incrementing id starting at 1."""
+    store = MemoryStore()
+
+    user1 = store.add("Alice", "alice@example.com")
+    assert isinstance(user1, User)
+    assert user1.id == 1
+    assert user1.name == "Alice"
+    assert user1.email == "alice@example.com"
+
+    user2 = store.add("Bob", "bob@example.com")
+    assert user2.id == 2
+    assert user2.name == "Bob"
+    assert user2.email == "bob@example.com"
+
+    user3 = store.add("Charlie", "charlie@example.com")
+    assert user3.id == 3
+    assert user3.name == "Charlie"
+    assert user3.email == "charlie@example.com"
+
+
+def test_get_returns_user_or_none():
+    """get(user_id) returns the User or None."""
+    store = MemoryStore()
+
+    # User doesn't exist yet
+    assert store.get(1) is None
+
+    # Add a user and get it
+    user = store.add("Alice", "alice@example.com")
+    retrieved = store.get(1)
+    assert retrieved is not None
+    assert retrieved.id == 1
+    assert retrieved.name == "Alice"
+    assert retrieved.email == "alice@example.com"
+
+    # Get a user that doesn't exist
+    assert store.get(999) is None
+
+
+def test_list_returns_all_users_in_insertion_order():
+    """list() returns all users in insertion order."""
+    store = MemoryStore()
+
+    # Empty store
+    assert store.list() == []
+
+    # Add users
+    user1 = store.add("Alice", "alice@example.com")
+    user2 = store.add("Bob", "bob@example.com")
+    user3 = store.add("Charlie", "charlie@example.com")
+
+    # Verify list returns in insertion order
+    users = store.list()
+    assert len(users) == 3
+    assert users[0].id == 1
+    assert users[0].name == "Alice"
+    assert users[1].id == 2
+    assert users[1].name == "Bob"
+    assert users[2].id == 3
+    assert users[2].name == "Charlie"
