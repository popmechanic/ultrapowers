+"""Serialization utilities for the apistub API."""
+import json
+from apistub.schema import User
+
+
+def to_json(user: User) -> str:
+    """Convert a User to a JSON string.
+
+    Args:
+        user: A User instance to serialize.
+
+    Returns:
+        A JSON string representation of the user with keys in the order:
+        id, name, email. Uses default separators.
+    """
+    data = {
+        "id": user.id,
+        "name": user.name,
+        "email": user.email,
+    }
+    return json.dumps(data)
