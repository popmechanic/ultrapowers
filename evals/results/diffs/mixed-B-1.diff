+"""Request handlers for the apistub API."""
+import json
+from typing import Tuple
+
+from apistub.validate import validate_payload
+from apistub.serialize import to_json
+from apistub.store import MemoryStore
+
+
+def create_user(store: MemoryStore, payload: dict) -> Tuple[int, str]:
+    """Create a new user.
+
+    Validates the payload and, if valid, adds the user to the store.
+
+    Args:
+        store: The MemoryStore instance.
+        payload: A dict containing the user fields.
+
+    Returns:
+        A (status, body) tuple where status is an HTTP status code and
+        body is a JSON string. Returns (400, ...) on validation failure
+        or (201, ...) on success.
+    """
+    errors = validate_payload(payload)
+    if errors:
+        return (400, json.dumps({"errors": errors}))
+
+    user = store.add(name=payload["name"], email=payload["email"])
+    return (201, to_json(user))
+
+
+def get_user(store: MemoryStore, user_id: int) -> Tuple[int, str]:
+    """Retrieve a user by ID.
+
+    Args:
+        store: The MemoryStore instance.
+        user_id: The ID of the user to retrieve.
+
+    Returns:
+        A (status, body) tuple where status is an HTTP status code and
+        body is a JSON string. Returns (200, ...) when the user is found
+        or (404, ...) when the user does not exist.
+    """
+    user = store.get(user_id)
+    if user is None:
+        return (404, json.dumps({"errors": ["not found"]}))
+    return (200, to_json(user))
