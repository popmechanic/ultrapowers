+"""Tests for the serialize module."""
+import json
+from apistub.schema import User
+from apistub.serialize import to_json
+
+
+def test_to_json_basic():
+    """to_json should convert a User to JSON string."""
+    user = User(1, "Ada", "ada@ex.com")
+    result = to_json(user)
+    assert isinstance(result, str)
+    assert result == '{"id": 1, "name": "Ada", "email": "ada@ex.com"}'
+
+
+def test_to_json_different_values():
+    """to_json should work with different user values."""
+    user = User(42, "Bob", "bob@example.com")
+    result = to_json(user)
+    assert result == '{"id": 42, "name": "Bob", "email": "bob@example.com"}'
+
+
+def test_to_json_key_order():
+    """to_json should maintain insertion order: id, name, email."""
+    user = User(1, "Alice", "alice@example.com")
+    result = to_json(user)
+    # Parse back to verify the order is preserved in the JSON string
+    parsed = json.loads(result)
+    keys = list(parsed.keys())
+    assert keys == ["id", "name", "email"]
+
+
+def test_to_json_default_separators():
+    """to_json should use default separators (', ' and ': ')."""
+    user = User(1, "Ada", "ada@ex.com")
+    result = to_json(user)
+    # Default separators include spaces: ', ' and ': '
+    assert ": " in result  # colon followed by space
+    assert ", " in result  # comma followed by space
