+"""In-memory store for users."""
+
+from typing import Optional
+
+from apistub.schema import User
+
+
+class MemoryStore:
+    """An in-memory store for users with auto-incrementing IDs."""
+
+    def __init__(self):
+        """Initialize the store."""
+        self._users: dict[int, User] = {}
+        self._next_id: int = 1
+
+    def add(self, name: str, email: str) -> User:
+        """Create and return a new User with an auto-incrementing id starting at 1.
+
+        Args:
+            name: The user's name.
+            email: The user's email.
+
+        Returns:
+            The created User.
+        """
+        user = User(id=self._next_id, name=name, email=email)
+        self._users[self._next_id] = user
+        self._next_id += 1
+        return user
+
+    def get(self, user_id: int) -> Optional[User]:
+        """Get a user by ID.
+
+        Args:
+            user_id: The user's ID.
+
+        Returns:
+            The User if found, None otherwise.
+        """
+        return self._users.get(user_id)
+
+    def list(self) -> list[User]:
+        """Return all users in insertion order.
+
+        Returns:
+            A list of all users in the order they were added.
+        """
+        return list(self._users.values())
