+
+        status, body = route(store, "GET", "/users/12")
+        assert status == 200
+        data = json.loads(body)
+        assert data["id"] == 12
+
+
+# ---------------------------------------------------------------------------
+# Unmatched routes return 404 with {"errors": ["no route"]}
+# ---------------------------------------------------------------------------
+
+class TestNoRoute:
+    def test_unknown_path(self, store):
+        status, body = route(store, "GET", "/unknown")
+        assert status == 404
+        data = json.loads(body)
+        assert data == {"errors": ["no route"]}
+
+    def test_delete_method(self, store):
+        status, body = route(store, "DELETE", "/users/1")
+        assert status == 404
+        data = json.loads(body)
+        assert data == {"errors": ["no route"]}
+
+    def test_get_users_list_not_implemented(self, store):
+        # GET /users (no id) is not a defined route
+        status, body = route(store, "GET", "/users")
+        assert status == 404
+        data = json.loads(body)
+        assert data == {"errors": ["no route"]}
+
+    def test_path_with_non_digits(self, store):
+        status, body = route(store, "GET", "/users/abc")
+        assert status == 404
+        data = json.loads(body)
+        assert data == {"errors": ["no route"]}
+
+    def test_patch_method(self, store):
+        status, body = route(store, "PATCH", "/users/1")
+        assert status == 404
+        data = json.loads(body)
