+"""Payload validation for the apistub API."""
+from typing import List
+from apistub.schema import FIELDS
+
+
+def validate_payload(payload: dict) -> List[str]:
+    """Validate a payload dict against the schema FIELDS.
+
+    Returns a list of error strings, empty when valid.
+    Errors are appended in FIELDS order for field-level checks, then email format.
+    Unknown keys in the payload are ignored.
+    """
+    errors: List[str] = []
+
+    for key, expected_type in FIELDS.items():
+        if key not in payload:
+            errors.append(f"missing: {key}")
+        elif not isinstance(payload[key], expected_type):
+            errors.append(f"wrong type: {key}")
+
+    # After the field loop: check email format if present and a str
+    if "email" in payload and isinstance(payload["email"], str):
+        if "@" not in payload["email"]:
+            errors.append("invalid: email")
+
+    return errors
