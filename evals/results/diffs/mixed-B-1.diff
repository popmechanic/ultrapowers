+        payload = {"name": "Alice", "email": "alice@example.com"}
+        status, body = route(store, "POST", "/users", payload)
+        assert status == 201
+        data = json.loads(body)
+        assert data["name"] == "Alice"
+        assert data["email"] == "alice@example.com"
+        assert "id" in data
+
+    def test_invalid_payload_returns_400(self, store):
+        payload = {"name": "", "email": "bad"}
+        status, body = route(store, "POST", "/users", payload)
+        assert status == 400
+        data = json.loads(body)
+        assert "errors" in data
+
+    def test_missing_payload_uses_none_or_empty(self, store):
+        # Calling without a payload should still delegate to create_user
+        status, body = route(store, "POST", "/users")
+        assert status == 400  # missing fields → validation error
+
+
+# ---------------------------------------------------------------------------
+# GET /users/<id> routes to get_user
+# ---------------------------------------------------------------------------
+
+class TestGetUser:
+    def test_existing_user_returns_200(self, store):
+        # Create a user first via the handler directly to seed the store
+        from apistub.handlers import create_user
+        create_user(store, {"name": "Bob", "email": "bob@example.com"})
+
+        status, body = route(store, "GET", "/users/1")
