+"""URL router for the apistub API."""
+import json
+import re
+from typing import Optional, Tuple
+
+from apistub.handlers import create_user, get_user
+from apistub.store import MemoryStore
+
+_NO_ROUTE = (404, json.dumps({"errors": ["no route"]}))
+_GET_USER_RE = re.compile(r"^/users/(\d+)$")
+
+
+def route(
+    store: MemoryStore,
+    method: str,
+    path: str,
+    payload: Optional[dict] = None,
+) -> Tuple[int, str]:
+    """Dispatch a request to the appropriate handler.
+
+    Args:
+        store: The MemoryStore instance shared across all handlers.
+        method: HTTP method string, e.g. "GET" or "POST".
+        path: URL path string, e.g. "/users" or "/users/42".
+        payload: Optional request body as a dict (used for POST).
+
+    Returns:
+        A (status_code, json_body) tuple.
+    """
+    if method == "POST" and path == "/users":
+        return create_user(store, payload if payload is not None else {})
+
+    if method == "GET":
+        m = _GET_USER_RE.match(path)
+        if m:
+            return get_user(store, int(m.group(1)))
+
+    return _NO_ROUTE
