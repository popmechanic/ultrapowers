+import pytest
+from ledger.parse import parse_line
+from ledger.model import Entry
+
+
+def test_parse_valid_positive_amount():
+    entry = parse_line("2026-01-15|coffee|4.50")
+    assert entry.date == "2026-01-15"
+    assert entry.description == "coffee"
+    assert entry.amount_cents == 450
+
+
+def test_parse_valid_negative_amount():
+    entry = parse_line("2026-01-15|coffee|-4.50")
+    assert entry.date == "2026-01-15"
+    assert entry.description == "coffee"
+    assert entry.amount_cents == -450
+
+
+def test_parse_returns_entry_instance():
+    entry = parse_line("2026-01-15|coffee|10.00")
+    assert isinstance(entry, Entry)
+
+
+def test_parse_too_few_fields_raises():
+    with pytest.raises(ValueError, match="bad line"):
+        parse_line("2026-01-15|coffee")
+
+
+def test_parse_too_many_fields_raises():
+    with pytest.raises(ValueError, match="bad line"):
+        parse_line("2026-01-15|coffee|-4.50|extra")
+
+
+def test_parse_empty_string_raises():
+    with pytest.raises(ValueError, match="bad line"):
+        parse_line("")
+
+
+def test_parse_single_field_raises():
+    with pytest.raises(ValueError, match="bad line"):
+        parse_line("2026-01-15")
+
+
+def test_parse_amount_no_decimal_raises():
+    with pytest.raises(ValueError, match="bad amount"):
+        parse_line("2026-01-15|coffee|-4")
+
+
+def test_parse_amount_one_decimal_place_raises():
+    with pytest.raises(ValueError, match="bad amount"):
+        parse_line("2026-01-15|coffee|-4.5")
+
+
+def test_parse_amount_three_decimal_places_raises():
+    with pytest.raises(ValueError, match="bad amount"):
+        parse_line("2026-01-15|coffee|-4.500")
+
+
+def test_parse_amount_non_numeric_raises():
+    with pytest.raises(ValueError, match="bad amount"):
+        parse_line("2026-01-15|coffee|abc")
+
+
+def test_parse_amount_letters_mixed_raises():
+    with pytest.raises(ValueError, match="bad amount"):
+        parse_line("2026-01-15|coffee|4.5x")
+
+
+def test_parse_amount_empty_raises():
+    with pytest.raises(ValueError, match="bad amount"):
+        parse_line("2026-01-15|coffee|")
+
+
+def test_parse_large_amount():
+    entry = parse_line("2026-01-15|salary|1000.00")
+    assert entry.amount_cents == 100000
+
+
+def test_parse_zero_amount():
+    entry = parse_line("2026-01-15|adjustment|0.00")
+    assert entry.amount_cents == 0
+
+
+def test_parse_calls_validate_bad_date_raises():
+    with pytest.raises(ValueError, match="bad date"):
+        parse_line("26-01-15|coffee|-4.50")
+
+
+def test_parse_calls_validate_empty_description_raises():
+    with pytest.raises(ValueError, match="empty description"):
+        parse_line("2026-01-15||-4.50")
