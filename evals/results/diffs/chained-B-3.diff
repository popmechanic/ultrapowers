+from typing import List
+from ledger.model import Entry
+
+
+def running_balance(entries: List[Entry]) -> List[int]:
+    """Return the cumulative sum of amount_cents for each entry."""
+    result = []
+    total = 0
+    for entry in entries:
+        total += entry.amount_cents
+        result.append(total)
+    return result
