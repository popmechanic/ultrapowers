+import pytest
+from ledger.parse import parse_line
+from ledger.balance import running_balance
+
+
+def make_entry(amount_str: str):
+    """Helper to build an Entry via parse_line for a given amount string."""
+    return parse_line(f"2024-01-01|test description|{amount_str}")
+
+
+def test_empty_list_returns_empty():
+    assert running_balance([]) == []
+
+
+def test_single_entry():
+    entry = make_entry("10.00")
+    assert running_balance([entry]) == [1000]
+
+
+def test_example_from_spec():
+    # amounts [1000, -450, 200] cents → [1000, 550, 750]
+    entries = [
+        make_entry("10.00"),   # 1000 cents
+        make_entry("-4.50"),   # -450 cents
+        make_entry("2.00"),    # 200 cents
+    ]
+    assert running_balance(entries) == [1000, 550, 750]
+
+
+def test_all_positive():
+    entries = [make_entry("1.00"), make_entry("2.00"), make_entry("3.00")]
+    assert running_balance(entries) == [100, 300, 600]
+
+
+def test_all_negative():
+    entries = [make_entry("-1.00"), make_entry("-2.00"), make_entry("-3.00")]
+    assert running_balance(entries) == [-100, -300, -600]
+
+
+def test_net_zero():
+    entries = [make_entry("5.00"), make_entry("-5.00")]
+    assert running_balance(entries) == [500, 0]
+
+
+def test_does_not_mutate_entries():
+    entries = [make_entry("1.00"), make_entry("2.00")]
+    result = running_balance(entries)
+    assert entries[0].amount_cents == 100
+    assert entries[1].amount_cents == 200
+    assert result == [100, 300]
