@@ -0,0 +1,23 @@
+from typing import List
+from ledger.model import Entry
+from ledger.balance import running_balance
+
+
+def format_cents(cents: int) -> str:
+    """Format an integer number of cents as a dollar string, e.g. 1000 -> '$10.00'."""
+    if cents < 0:
+        return f"-${-cents // 100}.{(-cents) % 100:02d}"
+    return f"${cents // 100}.{cents % 100:02d}"
+
+
+def format_report(entries: List[Entry]) -> str:
+    """Return a formatted multi-line report of entries with a running total line."""
+    if not entries:
+        return f"TOTAL {format_cents(0)}"
+
+    balances = running_balance(entries)
+    lines = []
+    for entry, balance in zip(entries, balances):
+        lines.append(f"{entry.date} {entry.description} {format_cents(entry.amount_cents)}")
+    lines.append(f"TOTAL {format_cents(balances[-1])}")
+    return "\n".join(lines)
