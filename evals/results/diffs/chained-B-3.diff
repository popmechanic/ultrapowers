+import pytest
+from ledger.model import Entry
+
+
+def test_validate_empty_description_raises():
+    e = Entry(date="2026-01-15", description="", amount_cents=100)
+    with pytest.raises(ValueError, match="empty description"):
+        e.validate()
+
+
+def test_validate_whitespace_only_description_raises():
+    e = Entry(date="2026-01-15", description="   ", amount_cents=100)
+    with pytest.raises(ValueError, match="empty description"):
+        e.validate()
+
+
+def test_validate_bad_date_raises():
+    e = Entry(date="26-01-15", description="coffee", amount_cents=100)
+    with pytest.raises(ValueError, match="bad date"):
+        e.validate()
+
+
+def test_validate_bad_date_with_extra_chars_raises():
+    e = Entry(date="2026-01-15X", description="coffee", amount_cents=100)
+    with pytest.raises(ValueError, match="bad date"):
+        e.validate()
+
+
+def test_validate_bad_date_non_numeric_raises():
+    e = Entry(date="YYYY-MM-DD", description="coffee", amount_cents=100)
+    with pytest.raises(ValueError, match="bad date"):
+        e.validate()
+
+
+def test_validate_valid_entry_returns_none():
+    e = Entry(date="2026-01-15", description="coffee", amount_cents=-450)
+    result = e.validate()
+    assert result is None
