@@ -0,0 +1,100 @@
+import pytest
+from ledger.cli import main
+
+
+def test_main_returns_zero_on_valid_file(tmp_path, capsys):
+    ledger_file = tmp_path / "ledger.txt"
+    ledger_file.write_text(
+        "2024-01-01|Coffee|5.00\n"
+        "2024-01-02|Lunch|12.50\n"
+    )
+    result = main([str(ledger_file)])
+    assert result == 0
+    captured = capsys.readouterr()
+    assert "2024-01-01 Coffee $5.00" in captured.out
+    assert "2024-01-02 Lunch $12.50" in captured.out
+    assert "TOTAL" in captured.out
+    assert captured.err == ""
+
+
+def test_main_skips_blank_lines(tmp_path, capsys):
+    ledger_file = tmp_path / "ledger.txt"
+    ledger_file.write_text(
+        "2024-01-01|Coffee|5.00\n"
+        "\n"
+        "   \n"
+        "2024-01-02|Tea|3.00\n"
+    )
+    result = main([str(ledger_file)])
+    assert result == 0
+    captured = capsys.readouterr()
+    assert "2024-01-01 Coffee $5.00" in captured.out
+    assert "2024-01-02 Tea $3.00" in captured.out
+
+
+def test_main_empty_file(tmp_path, capsys):
+    ledger_file = tmp_path / "empty.txt"
+    ledger_file.write_text("")
+    result = main([str(ledger_file)])
+    assert result == 0
+    captured = capsys.readouterr()
+    assert "TOTAL $0.00" in captured.out
+
+
+def test_main_only_blank_lines(tmp_path, capsys):
+    ledger_file = tmp_path / "blank.txt"
+    ledger_file.write_text("\n   \n\t\n")
+    result = main([str(ledger_file)])
+    assert result == 0
+    captured = capsys.readouterr()
+    assert "TOTAL $0.00" in captured.out
+
+
+def test_main_returns_one_on_bad_line(tmp_path, capsys):
+    ledger_file = tmp_path / "bad.txt"
+    ledger_file.write_text("not-a-valid-line\n")
+    result = main([str(ledger_file)])
+    assert result == 1
+    captured = capsys.readouterr()
+    assert captured.out == ""
+    assert captured.err.startswith("error: ")
+
+
+def test_main_returns_one_on_bad_amount(tmp_path, capsys):
+    ledger_file = tmp_path / "bad_amount.txt"
+    ledger_file.write_text("2024-01-01|Coffee|abc\n")
+    result = main([str(ledger_file)])
+    assert result == 1
+    captured = capsys.readouterr()
+    assert captured.err.startswith("error: ")
+
+
+def test_main_returns_one_on_bad_date(tmp_path, capsys):
+    ledger_file = tmp_path / "bad_date.txt"
+    ledger_file.write_text("not-a-date|Coffee|5.00\n")
+    result = main([str(ledger_file)])
+    assert result == 1
+    captured = capsys.readouterr()
+    assert captured.err.startswith("error: ")
+
+
+def test_main_error_message_contains_valueerror_message(tmp_path, capsys):
+    ledger_file = tmp_path / "bad.txt"
+    ledger_file.write_text("only-two|fields\n")
+    result = main([str(ledger_file)])
+    assert result == 1
+    captured = capsys.readouterr()
+    # The error message format should be "error: <message>"
+    assert captured.err.strip().startswith("error:")
+    # stderr should have some message after "error: "
+    assert len(captured.err.strip()) > len("error:")
+
+
+def test_main_prints_to_stdout_not_stderr(tmp_path, capsys):
+    ledger_file = tmp_path / "ledger.txt"
+    ledger_file.write_text("2024-03-15|Groceries|42.00\n")
+    result = main([str(ledger_file)])
+    assert result == 0
+    captured = capsys.readouterr()
+    assert captured.err == ""
+    assert "TOTAL" in captured.out
