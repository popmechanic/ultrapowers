+import re
 from dataclasses import dataclass
 
+_DATE_RE = re.compile(r"^\d{4}-\d{2}-\d{2}$")
+
 
 @dataclass
 class Entry:
     date: str
     description: str
     amount_cents: int
+
+    def validate(self) -> None:
+        if not self.description.strip():
+            raise ValueError("empty description")
