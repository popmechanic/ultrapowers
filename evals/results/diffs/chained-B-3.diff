--- /dev/null
+++ b/ledger/parse.py
@@ -0,0 +1,22 @@
+import re
+from ledger.model import Entry
+
+_AMOUNT_RE = re.compile(r"^-?\d+\.\d{2}$")
+
+
+def parse_line(line: str) -> Entry:
+    fields = line.split("|")
+    if len(fields) != 3:
+        raise ValueError("bad line")
+
+    date, description, amount_str = fields
+
+    if not _AMOUNT_RE.match(amount_str):
+        raise ValueError("bad amount")
+
+    # Convert dollars with two decimal places to integer cents
+    amount_cents = round(float(amount_str) * 100)
+
+    entry = Entry(date=date, description=description, amount_cents=amount_cents)
+    entry.validate()
+    return entry
